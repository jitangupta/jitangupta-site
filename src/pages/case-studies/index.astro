---
import BaseHead from "../../components/BaseHead.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { getCollection } from "astro:content";

const title = "Case Studies — Jitan Gupta";
const description = "Production engineering work: Kubernetes, identity, multi-tenant SaaS, legacy modernization.";

const allCaseStudies = await getCollection("caseStudies");

interface CsMeta {
  year: string;
  domain: string;
  tags: string[];
  metrics: { k: string; v: string }[];
  lesson: string;
}

const csMeta: Record<string, CsMeta> = {
  "probabilistic-deployment-orchestration": {
    year: "2024 — Present",
    domain: "Multi-tenant SaaS",
    tags: ["Probabilistic models", "Release engineering", "Multi-tenant", ".NET / Azure"],
    metrics: [
      { k: "Annual savings", v: "$17K" },
      { k: "Decision automation", v: "~80%" },
      { k: "Failed deploys avoided", v: "Significant" },
      { k: "Tenants", v: "400+" },
    ],
    lesson: "The hardest part wasn't the model. It was getting on-call engineers to trust a probability score at 3am. That trust gap is exactly what AI-assisted dev is wrestling with today.",
  },
  "multi-tenant-aks-migration": {
    year: "2024 — Present",
    domain: "Platform migration",
    tags: ["AKS", "Kubernetes", "Multi-tenant", "Migration"],
    metrics: [
      { k: "Tenants migrated", v: "400+" },
      { k: "Downtime per tenant", v: "0s" },
      { k: "Version lock-in", v: "Solved" },
      { k: "Rollback path", v: "Always" },
    ],
    lesson: "We did tenant-by-tenant validation manually. Today I'd put an agent on it — but only with the 5-Check between the agent's signal and a green light to advance.",
  },
  "university-credit-system-migration": {
    year: "2021 — 2024",
    domain: "Higher ed",
    tags: ["Legacy modernization", "Payments", "Cloud-native", "Azure"],
    metrics: [
      { k: "Revenue uplift", v: "+30%" },
      { k: "Legacy systems retired", v: "Several" },
      { k: "Stakeholders aligned", v: "Many" },
      { k: "Domain complexity", v: "High" },
    ],
    lesson: "This is the class of domain where AI-generated code stubs its toe on day one. The system has thirty years of edge cases — none of which are in any training set.",
  },
  "user-management-migration": {
    year: "2024 — Present",
    domain: "Identity",
    tags: ["Identity", "ASP.NET Identity", "Migration", "Security"],
    metrics: [
      { k: "Daily authentications", v: "50K+" },
      { k: "Security incidents", v: "0" },
      { k: "Identity drift", v: "0" },
      { k: "Downtime", v: "0s" },
    ],
    lesson: "Identity is where I learned the rule: AI accelerates the boring parts, but a human owns the critical path. That rule sits behind everything I build today.",
  },
};

const order = Object.keys(csMeta);

const caseStudies = allCaseStudies
  .filter((cs) => !cs.data.draft && csMeta[cs.id])
  .sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <style>
      :root,
      html[data-theme="paper"] {
        --bg: oklch(0.985 0.008 80);
        --bg-tint: oklch(0.965 0.012 80);
        --ink: oklch(0.18 0.012 60);
        --ink-2: oklch(0.30 0.012 60);
        --muted: oklch(0.50 0.012 60);
        --hairline: oklch(0.88 0.010 80);
        --hairline-strong: oklch(0.78 0.012 80);
        --accent: oklch(0.62 0.20 32);
        --accent-ink: oklch(0.98 0.005 80);
        --selection: oklch(0.85 0.14 32 / 0.45);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Geist", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: "ss01","ss02","cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
      }

      ::selection { background: var(--selection); }
      body { min-height: 100vh; overflow-x: hidden; }

      a {
        color: inherit;
        text-decoration: none;
        text-underline-offset: 3px;
        transition: color 150ms ease, opacity 150ms ease;
      }
      a:hover { color: var(--accent); }

      p { margin: 0; }
      ul, ol { margin: 0; padding: 0; list-style: none; }
      img { max-width: 100%; display: block; }

      .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
      @media (max-width: 540px) { .wrap { padding: 0 20px; } }

      .mono {
        font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;
        font-feature-settings: "ss01","ss02";
      }

      .eyebrow {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .eyebrow::before {
        content: "";
        width: 18px;
        height: 1px;
        background: var(--hairline-strong);
      }

      h1, h2, h3, h4 { margin: 0; font-weight: 500; letter-spacing: -0.02em; }

      .display {
        font-size: clamp(48px, 7.2vw, 104px);
        line-height: 0.98;
        letter-spacing: -0.035em;
        font-weight: 500;
        text-wrap: balance;
      }

      .h2 {
        font-size: clamp(32px, 4.4vw, 56px);
        line-height: 1.02;
        letter-spacing: -0.028em;
        text-wrap: balance;
        font-weight: 500;
      }

      .lede {
        font-size: clamp(18px, 1.4vw, 22px);
        line-height: 1.5;
        color: var(--ink-2);
        text-wrap: pretty;
        max-width: 62ch;
      }

      .body { font-size: 17px; line-height: 1.6; color: var(--ink-2); text-wrap: pretty; }
      .small { font-size: 14px; color: var(--muted); }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in oklch, var(--bg) 88%, transparent);
        backdrop-filter: saturate(140%) blur(12px);
        -webkit-backdrop-filter: saturate(140%) blur(12px);
        border-bottom: 1px solid color-mix(in oklch, var(--hairline) 60%, transparent);
      }
      .site-header .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
        letter-spacing: -0.01em;
      }
      .brand .dot {
        width: 9px; height: 9px;
        background: var(--accent);
        border-radius: 50%;
        display: inline-block;
      }
      .nav { display: flex; align-items: center; gap: 28px; font-size: 14.5px; }
      .nav a { color: var(--ink-2); }
      .nav a.active { color: var(--ink); }
      .nav a:hover { color: var(--ink); }
      @media (max-width: 720px) {
        .nav { gap: 18px; font-size: 13.5px; }
        .nav a.nav-hide-sm { display: none; }
      }

      section { padding: 96px 0; position: relative; }
      section.tight { padding: 64px 0; }
      @media (max-width: 720px) { section { padding: 64px 0; } }

      .tag {
        display: inline-block;
        padding: 4px 9px;
        border: 1px solid var(--hairline);
        border-radius: 999px;
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 11.5px;
        color: var(--muted);
        letter-spacing: 0.02em;
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border: 1px solid var(--hairline-strong);
        border-radius: 999px;
        font-size: 14.5px;
        font-weight: 500;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
      }
      .btn:hover { background: var(--bg-tint); color: var(--ink); border-color: var(--ink); }
      .btn.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .btn .arrow { transition: transform 200ms ease; }
      .btn:hover .arrow { transform: translateX(3px); }

      .site-footer { border-top: 1px solid var(--hairline); padding: 56px 0 40px; }
      .site-footer .grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 56px;
      }
      .site-footer h4 {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
        font-weight: 500;
      }
      .site-footer ul li { padding: 4px 0; }
      .site-footer ul li a { color: var(--ink-2); font-size: 14.5px; }
      .site-footer .meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--muted);
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
      }
      @media (max-width: 820px) { .site-footer .grid { grid-template-columns: 1fr 1fr; } }

      .reveal {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 600ms cubic-bezier(.2,.7,.2,1), transform 600ms cubic-bezier(.2,.7,.2,1);
      }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
      }

      .arrow { width: 14px; height: 14px; display: inline-block; vertical-align: -1px; }

      /* ===== PAGE-SPECIFIC ===== */

      .page-hero { padding: clamp(64px, 8vh, 110px) 0 56px; }

      .cs-feature {
        display: grid;
        grid-template-columns: 1fr;
        gap: 0;
        border-top: 1px solid var(--hairline);
      }
      .cs-feature-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border-bottom: 1px solid var(--hairline);
      }
      .cs-feature-row > div { padding: 56px; }
      .cs-feature-row .left { border-right: 1px solid var(--hairline); }
      .cs-feature-row .year {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 16px;
      }
      .cs-feature-row h2 {
        font-size: clamp(26px, 2.8vw, 36px);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.1;
        text-wrap: balance;
        margin-bottom: 16px;
      }
      .cs-feature-row .lede {
        color: var(--ink-2);
        font-size: 16px;
        max-width: 50ch;
        margin-bottom: 24px;
      }
      .cs-feature-row .tags { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 24px; }
      .cs-feature-row .metrics {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        padding: 20px;
        background: var(--bg-tint);
        border-radius: 4px;
        margin-bottom: 24px;
      }
      .cs-feature-row .metrics .m .k {
        font-family: "Geist Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: 6px;
      }
      .cs-feature-row .metrics .m .v {
        font-size: 22px;
        font-weight: 500;
        letter-spacing: -0.02em;
        color: var(--ink);
      }
      .cs-feature-row .lessons {
        border-left: 2px solid var(--accent);
        padding: 6px 0 6px 18px;
        font-size: 15px;
        color: var(--ink);
        line-height: 1.55;
        font-style: italic;
        max-width: 50ch;
      }
      .cs-feature-row .lessons::before {
        content: "Lesson, today";
        display: block;
        font-style: normal;
        color: var(--muted);
        font-family: "Geist Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: 6px;
      }
      @media (max-width: 820px) {
        .cs-feature-row { grid-template-columns: 1fr; }
        .cs-feature-row .left { border-right: none; border-bottom: 1px solid var(--hairline); }
        .cs-feature-row > div { padding: 36px 24px; }
      }
    </style>
  </head>

  <body>

    <SiteHeader />

    <main>

      <section class="page-hero">
        <div class="wrap reveal">
          <span class="eyebrow">Case studies</span>
          <h1 class="display" style="font-size: clamp(40px, 5.4vw, 76px); margin-top: 16px;">
            Production work, before the AI layer.
          </h1>
          <p class="lede" style="margin-top: 24px;">
            Identity migrations, multi-tenant Kubernetes, legacy modernization, probabilistic deployment models. The systems work that's the reason I know when AI helps and when it quietly breaks things.
          </p>
        </div>
      </section>

      <section class="tight">
        <div class="wrap">
          <div class="cs-feature">
            {caseStudies.map((cs) => {
              const meta = csMeta[cs.id];
              if (!meta) return null;
              return (
                <div class="cs-feature-row reveal">
                  <div class="left">
                    <div class="year">{meta.year} · {meta.domain}</div>
                    <h2>{cs.data.pageTitle}</h2>
                    <p class="lede">{cs.data.description}</p>
                    <div class="tags">
                      {meta.tags.map((t) => <span class="tag">{t}</span>)}
                    </div>
                  </div>
                  <div>
                    <div class="metrics">
                      {meta.metrics.map((m) => (
                        <div class="m">
                          <span class="k">{m.k}</span>
                          <span class="v">{m.v}</span>
                        </div>
                      ))}
                    </div>
                    <p class="lessons">{meta.lesson}</p>
                    <a class="btn" href={`/case-studies/${cs.id}`}>
                      Read full case study
                      <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
                    </a>
                  </div>
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <section class="tight">
        <div class="wrap">
          <div style="display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: end; padding: 56px 0; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline);">
            <div>
              <span class="eyebrow">Then → now</span>
              <h2 class="h2" style="margin-top: 14px;">The systems depth is why the current AI work doesn't drift.</h2>
            </div>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <a class="btn primary" href="/builds">
                See current builds
                <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
              </a>
              <a class="btn" href="/about">About</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="grid">
          <div>
            <a class="brand" href="/"><img src="/JitanGupta%20Logo.png" alt="Jitan Gupta" style="height:44px;width:auto;display:block;mix-blend-mode:multiply;" /></a>
            <p class="body" style="font-size:14.5px; max-width: 42ch; margin-top: 12px;">
              Engineer building AI infrastructure and developer tooling, in public. Mumbai, India.
            </p>
          </div>
          <div>
            <h4>Sitemap</h4>
            <ul>
              <li><a href="/builds">Builds</a></li>
              <li><a href="/frameworks">Frameworks</a></li>
              <li><a href="/case-studies">Case studies</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4>Elsewhere</h4>
            <ul>
              <li><a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
              <li><a href="https://www.youtube.com/@jitangupta" target="_blank" rel="noopener noreferrer">YouTube ↗</a></li>
              <li><a href="https://www.linkedin.com/in/jitangupta/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a></li>
            </ul>
          </div>
          <div>
            <h4>Speak with me</h4>
            <ul>
              <li><a href="/contact">Speaking & podcasts</a></li>
              <li><a href="/contact">Collaboration</a></li>
              <li><a href="/contact">Anything serious</a></li>
            </ul>
          </div>
        </div>
        <div class="meta">
          <span>© 2026 Jitan Gupta. All rights reserved.</span>
          <span class="mono">Built in public · Mumbai → web</span>
        </div>
      </div>
    </footer>

    <script>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight) { el.classList.add('in'); }
        else { io.observe(el); }
      });
      setTimeout(() => {
        document.querySelectorAll('.reveal:not(.in)').forEach((el) => el.classList.add('in'));
      }, 1500);
    </script>

  </body>
</html>
