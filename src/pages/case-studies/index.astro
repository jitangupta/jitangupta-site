---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';

const caseStudies = (await getCollection('caseStudies')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const seoTitle = "Case Studies | Kubernetes & Cloud Infrastructure | Jitan Gupta";
const seoDescription = "Explore detailed case studies of Kubernetes migrations, AI-powered DevOps tools, and multi-tenant SaaS infrastructure projects.";
---
<Layout	title={seoTitle} description={seoDescription}>
    <section class="bg-[#0d1117] pt-32 pb-16 border-b border-gray-800">
        <div class="container-custom text-center">
            <!-- Title -->
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">Case Studies</h1>

            <!-- Convincing Notes -->
            <p class="text-xl text-gray-400 max-w-3xl mx-auto leading-relaxed">Deep dives into real-world infrastructure challenges and how I solved them.</p>
        </div>
    </section>

    <section class="bg-[#0d1117] py-16">
        <div class="container-custom">
          <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
            {caseStudies.map((caseStudy) => (
                caseStudy.data.draft == true ? null :
                <a href={`/case-studies/${caseStudy.id}`} class="group block">
                    <div class="bg-[#161b22] rounded-xl border border-gray-800 overflow-hidden transition-all duration-300 hover:border-blue-500/50 hover:shadow-2xl hover:shadow-blue-900/20 hover:-translate-y-1">
                        <div class="relative aspect-video overflow-hidden bg-[#0d1117]">
                            <div class="absolute inset-0 bg-blue-500/10 mix-blend-overlay"></div>
                            <img src={caseStudy.data.heroImage} alt={caseStudy.data.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
                        </div>
                        <div class="p-6">
                            <div class="mb-3">
                                <span class="inline-block px-2 py-1 text-xs font-mono text-blue-400 bg-blue-900/20 border border-blue-900/50 rounded">
                                    CASE STUDY
                                </span>
                            </div>
                            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-blue-400 transition-colors">{caseStudy.data.pageTitle}</h3>
                            <p class="text-gray-400 text-sm mb-4 line-clamp-2">{caseStudy.data.summary || caseStudy.data.description}</p>
                            <span class="inline-flex items-center gap-2 text-sm text-blue-400 font-medium">
                                Read Case Study
                                <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
                            </span>
                        </div>
                    </div>
                </a>
            ))}
          </div>
        </div>
    </section>
</Layout>