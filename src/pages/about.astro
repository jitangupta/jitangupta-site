---
import BaseHead from "../components/BaseHead.astro";
import SiteHeader from "../components/SiteHeader.astro";

const title = "About — Jitan Gupta";
const description = "Mumbai-based engineer. Ten years of production systems, two-plus building at the AI layer.";
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <style>
      :root,
      html[data-theme="paper"] {
        --bg: oklch(0.985 0.008 80);
        --bg-tint: oklch(0.965 0.012 80);
        --ink: oklch(0.18 0.012 60);
        --ink-2: oklch(0.30 0.012 60);
        --muted: oklch(0.50 0.012 60);
        --hairline: oklch(0.88 0.010 80);
        --hairline-strong: oklch(0.78 0.012 80);
        --accent: oklch(0.62 0.20 32);
        --accent-ink: oklch(0.98 0.005 80);
        --selection: oklch(0.85 0.14 32 / 0.45);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Geist", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: "ss01","ss02","cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
      }

      ::selection { background: var(--selection); }
      body { min-height: 100vh; overflow-x: hidden; }

      a {
        color: inherit;
        text-decoration: none;
        text-underline-offset: 3px;
        transition: color 150ms ease, opacity 150ms ease;
      }
      a:hover { color: var(--accent); }

      p { margin: 0; }
      ul, ol { margin: 0; padding: 0; list-style: none; }
      img { max-width: 100%; display: block; }

      .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
      @media (max-width: 540px) { .wrap { padding: 0 20px; } }

      .hairline-t { border-top: 1px solid var(--hairline); }

      .mono {
        font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;
        font-feature-settings: "ss01","ss02";
      }

      .eyebrow {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .eyebrow::before {
        content: "";
        width: 18px;
        height: 1px;
        background: var(--hairline-strong);
      }

      h1, h2, h3, h4 { margin: 0; font-weight: 500; letter-spacing: -0.02em; }

      .h2 {
        font-size: clamp(32px, 4.4vw, 56px);
        line-height: 1.02;
        letter-spacing: -0.028em;
        text-wrap: balance;
        font-weight: 500;
      }

      .lede {
        font-size: clamp(18px, 1.4vw, 22px);
        line-height: 1.5;
        color: var(--ink-2);
        text-wrap: pretty;
        max-width: 62ch;
      }

      .body { font-size: 17px; line-height: 1.6; color: var(--ink-2); text-wrap: pretty; }
      .small { font-size: 14px; color: var(--muted); }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in oklch, var(--bg) 88%, transparent);
        backdrop-filter: saturate(140%) blur(12px);
        -webkit-backdrop-filter: saturate(140%) blur(12px);
        border-bottom: 1px solid color-mix(in oklch, var(--hairline) 60%, transparent);
      }
      .site-header .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
        letter-spacing: -0.01em;
      }
      .brand .dot {
        width: 9px; height: 9px;
        background: var(--accent);
        border-radius: 50%;
        display: inline-block;
      }
      .nav { display: flex; align-items: center; gap: 28px; font-size: 14.5px; }
      .nav a { color: var(--ink-2); }
      .nav a.active { color: var(--ink); }
      .nav a:hover { color: var(--ink); }
      @media (max-width: 720px) {
        .nav { gap: 18px; font-size: 13.5px; }
        .nav a.nav-hide-sm { display: none; }
      }

      section { padding: 96px 0; position: relative; }
      section.tight { padding: 64px 0; }
      @media (max-width: 720px) { section { padding: 64px 0; } }

      .section-head {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 48px;
        margin-bottom: 56px;
        align-items: end;
      }
      .section-head .lede { margin-top: 16px; }
      @media (max-width: 820px) {
        .section-head { grid-template-columns: 1fr; gap: 16px; margin-bottom: 40px; }
      }

      .tag {
        display: inline-block;
        padding: 4px 9px;
        border: 1px solid var(--hairline);
        border-radius: 999px;
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 11.5px;
        color: var(--muted);
        letter-spacing: 0.02em;
      }

      .status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 11.5px;
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .status::before {
        content: "";
        width: 7px; height: 7px;
        background: var(--accent);
        border-radius: 50%;
        box-shadow: 0 0 0 3px color-mix(in oklch, var(--accent) 18%, transparent);
      }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border: 1px solid var(--hairline-strong);
        border-radius: 999px;
        font-size: 14.5px;
        font-weight: 500;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
      }
      .btn:hover { background: var(--bg-tint); color: var(--ink); border-color: var(--ink); }
      .btn.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .btn .arrow { transition: transform 200ms ease; }
      .btn:hover .arrow { transform: translateX(3px); }

      .site-footer { border-top: 1px solid var(--hairline); padding: 56px 0 40px; }
      .site-footer .grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 56px;
      }
      .site-footer h4 {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
        font-weight: 500;
      }
      .site-footer ul li { padding: 4px 0; }
      .site-footer ul li a { color: var(--ink-2); font-size: 14.5px; }
      .site-footer .meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--muted);
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
      }
      @media (max-width: 820px) { .site-footer .grid { grid-template-columns: 1fr 1fr; } }

      .reveal {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 600ms cubic-bezier(.2,.7,.2,1), transform 600ms cubic-bezier(.2,.7,.2,1);
      }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
      }

      .arrow { width: 14px; height: 14px; display: inline-block; vertical-align: -1px; }

      /* ===== PAGE-SPECIFIC ===== */

      .about-hero { padding: clamp(64px, 9vh, 120px) 0 64px; }
      .about-hero .grid {
        display: grid;
        grid-template-columns: 1fr 1.6fr;
        gap: 80px;
        align-items: start;
      }
      @media (max-width: 820px) {
        .about-hero .grid { grid-template-columns: 1fr; gap: 40px; }
        .portrait { max-height: 300px; }
        .about-cta-row { grid-template-columns: 1fr !important; gap: 24px !important; }
      }
      @media (max-width: 540px) {
        .site-footer .grid { grid-template-columns: 1fr; }
      }

      .portrait {
        aspect-ratio: 4/5;
        border: 1px solid var(--hairline);
        border-radius: 4px;
        overflow: hidden;
        position: relative;
      }
      .portrait img {
        width: 100%; height: 100%;
        object-fit: cover;
        object-position: top center;
        display: block;
      }

      .about-hero h1 { margin-bottom: 24px; }

      .prose {
        max-width: 64ch;
        font-size: 18px;
        line-height: 1.65;
        color: var(--ink-2);
      }
      .prose p { margin-bottom: 20px; text-wrap: pretty; }
      .prose p strong { color: var(--ink); font-weight: 500; }
      .prose a { text-decoration: underline; text-decoration-color: var(--hairline-strong); text-underline-offset: 4px; }
      .prose a:hover { text-decoration-color: var(--accent); color: var(--accent); }

      .stack {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 24px;
        padding: 24px 0;
        border-top: 1px solid var(--hairline);
        align-items: start;
      }
      .stack .k {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        padding-top: 2px;
      }
      .stack ul { display: flex; flex-wrap: wrap; gap: 8px; }
      @media (max-width: 720px) { .stack { grid-template-columns: 1fr; gap: 8px; } }

      .timeline { border-top: 1px solid var(--hairline); margin-top: 40px; }
      .timeline-row {
        display: grid;
        grid-template-columns: 200px 1fr;
        gap: 32px;
        padding: 28px 0;
        border-bottom: 1px solid var(--hairline);
        align-items: start;
      }
      .timeline-row .year {
        font-family: "Geist Mono", monospace;
        font-size: 13px;
        color: var(--muted);
      }
      .timeline-row h3 {
        font-size: 18px;
        font-weight: 500;
        letter-spacing: -0.015em;
        margin-bottom: 6px;
      }
      .timeline-row p { color: var(--ink-2); font-size: 15.5px; line-height: 1.55; }
      @media (max-width: 720px) { .timeline-row { grid-template-columns: 1fr; gap: 6px; } }
    </style>
  </head>

  <body>

    <SiteHeader />

    <main>

      <section class="about-hero">
        <div class="wrap">
          <div class="grid">
            <div class="reveal">
              <div class="portrait">
                <img src="/jitan-bg.jpg" alt="Jitan Gupta" />
              </div>
              <div style="margin-top: 16px; display: flex; flex-direction: column; gap: 6px;">
                <span class="status">Based in Mumbai, India</span>
                <span class="small">UTC+5:30 · Available Mon–Fri</span>
              </div>
            </div>

            <div class="reveal">
              <span class="eyebrow">About</span>
              <h1 class="h2" style="margin-top:18px; margin-bottom: 32px;">
                Engineer. Currently building at the AI layer. Ten years of production systems sitting behind it.
              </h1>

              <div class="prose">
                <p>
                  I build <strong>AI infrastructure and developer tooling, in public</strong>. The work is MCP servers, agent workflows, Chrome extensions, pre-merge frameworks for AI-generated code. The shared trait: each one started as a problem in real engineering work, then became something other engineers can pick up.
                </p>
                <p>
                  For ten years before this, I shipped production software: Kubernetes migrations across 400+ tenants, identity systems on Azure, legacy modernization for university payment platforms, probabilistic models running real deployment decisions. That depth is the reason I can tell where AI helps and where it quietly breaks things.
                </p>
                <p>
                  I publish on YouTube in Hinglish, episode by episode. The most useful videos are the ones that include the part where it broke and what I did about it.
                </p>
                <p>
                  If you're building serious AI infrastructure, organizing a builders event, or want to talk about something specific, <a href="/contact">get in touch</a>.
                </p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="hairline-t">
        <div class="wrap">
          <div class="section-head reveal">
            <div>
              <span class="eyebrow">Working with</span>
              <h2 class="h2" style="margin-top: 18px;">The current tools, the current stack.</h2>
            </div>
            <p class="lede">
              What I'm actively building with right now, not a CV list of everything I've ever touched. If it's here, I shipped something with it in the last 90 days.
            </p>
          </div>

          <div class="reveal">
            <div class="stack">
              <span class="k">AI tooling</span>
              <ul>
                <span class="tag">Claude Code</span>
                <span class="tag">Claude Cowork</span>
                <span class="tag">MCP</span>
                <span class="tag">Agent SDKs</span>
                <span class="tag">Codex</span>
                <span class="tag">Hermes Agent</span>
              </ul>
            </div>
            <div class="stack">
              <span class="k">Languages</span>
              <ul>
                <span class="tag">TypeScript</span>
                <span class="tag">C#</span>
                <span class="tag">.NET Core</span>
                <span class="tag">SQL</span>
                <span class="tag">Bash</span>
              </ul>
            </div>
            <div class="stack">
              <span class="k">Infra</span>
              <ul>
                <span class="tag">Azure</span>
                <span class="tag">Kubernetes (AKS)</span>
                <span class="tag">Terraform</span>
                <span class="tag">Docker</span>
                <span class="tag">GitHub Actions</span>
              </ul>
            </div>
            <div class="stack">
              <span class="k">Domains</span>
              <ul>
                <span class="tag">Multi-tenant SaaS</span>
                <span class="tag">Identity</span>
                <span class="tag">Deployment automation</span>
                <span class="tag">Dev tooling</span>
                <span class="tag">Agent infra</span>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <section>
        <div class="wrap">
          <div class="section-head reveal">
            <div>
              <span class="eyebrow">Trajectory</span>
              <h2 class="h2" style="margin-top: 18px;">Ten years of production systems. Now building at the AI layer.</h2>
            </div>
            <p class="lede">
              Five companies, two co-founded startups, one consistent thread: owning the hard migration at the platform level. The long version is in the case studies.
            </p>
          </div>

          <div class="timeline">
            <div class="timeline-row reveal">
              <span class="year">2024 — Present</span>
              <div>
                <h3>Senior Engineer — LeahAI · AI layer</h3>
                <p>Migrating 14 microservices from Azure VMs to AKS across 400+ tenants, using AGIC + YARP for tenant-based version routing, GitOps with Helm and ArgoCD. Built a RAG-based deployment orchestration POC (Azure AI Foundry + Qdrant) that cuts release planning from 2 hours to 10 minutes. Migrated the identity platform serving 50K+ daily authentications with zero downtime. In parallel: cb-mcp-server, PromptMate, Cowork Boilerplate, the 5-Check framework, weekly videos.</p>
              </div>
            </div>
            <div class="timeline-row reveal">
              <span class="year">2021 — 2024</span>
              <div>
                <h3>Lead Engineer — Kaplan / Purdue Global</h3>
                <p>Inherited a stalled credit system migration at 10% completion. Led a 3-engineer team to full production release, consolidating 3 separate portals (student, admin, evaluator) into a unified microservices backend. Monolith-to-microservices architecture improved deployment frequency by 300%. Mentored two engineers through the transition and owned sprint planning for the backend team.</p>
              </div>
            </div>
            <div class="timeline-row reveal">
              <span class="year">2019 — 2021</span>
              <div>
                <h3>Senior Engineer — NEC Soft Solutions</h3>
                <p>Feature development across a Windows and web Document Management System. Led a Bootstrap 3→4 migration from POC through stakeholder approval to full delivery. Owned end-to-end build and release testing for Windows scanner applications.</p>
              </div>
            </div>
            <div class="timeline-row reveal">
              <span class="year">2016 — 2019</span>
              <div>
                <h3>Software Engineer — NeoSoft Technology</h3>
                <p>Built a Fixed Deposit purchase portal end to end with a 6-engineer team. Led internal SSO platform migration from .NET Framework to .NET Core, revamped the UI and trained 3 graduates who contributed to delivery. Financial services and legal domain work.</p>
              </div>
            </div>
            <div class="timeline-row reveal">
              <span class="year">2015 — 2016</span>
              <div>
                <h3>Co-founder & Developer — Artcarro</h3>
                <p>Co-founded an art services startup and built the entire technical platform from scratch: customer portal, admin portal, payment gateway integration. First experience owning a product end to end.</p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="tight">
        <div class="wrap">
          <div class="about-cta-row" style="display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: end; padding: 40px 0; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline);">
            <div>
              <span class="eyebrow">Next</span>
              <h2 class="h2" style="margin-top: 14px;">Want to see what I'm building right now?</h2>
            </div>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <a class="btn primary" href="/builds">
                Builds
                <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
              </a>
              <a class="btn" href="/contact">Contact</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="grid">
          <div>
            <a class="brand" href="/"><img src="/JitanGupta%20Logo.png" alt="Jitan Gupta" style="height:44px;width:auto;display:block;mix-blend-mode:multiply;" /></a>
            <p class="body" style="font-size:14.5px; max-width: 42ch; margin-top: 12px;">
              Engineer building AI infrastructure and developer tooling, in public. Mumbai, India.
            </p>
          </div>
          <div>
            <h4>Sitemap</h4>
            <ul>
              <li><a href="/builds">Builds</a></li>
              <li><a href="/frameworks">Frameworks</a></li>
              <li><a href="/case-studies">Case studies</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4>Elsewhere</h4>
            <ul>
              <li><a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
              <li><a href="https://www.youtube.com/@jitangupta" target="_blank" rel="noopener noreferrer">YouTube ↗</a></li>
              <li><a href="https://www.linkedin.com/in/jitangupta/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a></li>
            </ul>
          </div>
          <div>
            <h4>Speak with me</h4>
            <ul>
              <li><a href="/contact">Speaking & podcasts</a></li>
              <li><a href="/contact">Collaboration</a></li>
              <li><a href="/contact">Anything serious</a></li>
            </ul>
          </div>
        </div>
        <div class="meta">
          <span>© 2026 Jitan Gupta. All rights reserved.</span>
          <span class="mono">Built in public · Mumbai → web</span>
        </div>
      </div>
    </footer>

    <script>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight) { el.classList.add('in'); }
        else { io.observe(el); }
      });
      setTimeout(() => {
        document.querySelectorAll('.reveal:not(.in)').forEach((el) => el.classList.add('in'));
      }, 1500);
    </script>

  </body>
</html>
