---
import Layout from '../layouts/Layout.astro';
import { services } from '../data/services';

const title = "Services · Work With Jitan Gupta";
const description = "Practical AI adoption sessions for engineers and teams: discovery calls, 1:1 mentorship, AI workflow setup, full-day Team Training, and Build-Along sessions. Mumbai-based, on-site or remote.";

const individualServices = services.filter(s => s.tier === 'individual');
const teamServices = services.filter(s => s.tier === 'team');
---

<Layout title={title} description={description}>
  <section class="bg-[#F8FAFC] mx-2">
    <div class="bg-white max-w-screen-xl mx-auto px-5 py-5 md:px-15 md:py-10 rounded-b-2xl">

      <!-- Hero -->
      <div class="fade-up mt-5 md:mt-8 mb-6 md:mb-8">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4" style="line-height: 1.2;">
          Work With Me
        </h1>
        <p class="text-lg md:text-xl text-gray-600 max-w-2xl">
          From a 15-minute call to a full-day team session. Pick what fits your situation.
        </p>
      </div>

      <!-- Credibility paragraph -->
      <div class="fade-up mb-10 md:mb-14">
        <p class="text-sm text-gray-500 max-w-2xl leading-relaxed">
          I'm a Mumbai-based AI adoption practitioner with 10 years in tech: 9 years building .NET systems and cloud infrastructure (Kubernetes, AKS, Azure), plus a year in platform engineering. I build with AI tools daily in production work, not just demos. My YouTube channel documents real AI workflows, MCP integrations, and Claude Code projects as I build them. What I teach comes from what I ship.
        </p>
      </div>

      <!-- Individual Sessions -->
      <div class="fade-up mb-4">
        <h2 class="text-xl font-semibold text-gray-500 uppercase tracking-wider mb-6">Individual</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 fade-up-group mb-12">
        {individualServices.map((service) => (
          <div class={`relative flex flex-col rounded-2xl border p-6 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 ${
            service.isFree
              ? 'border-primary-300 bg-primary-50'
              : 'border-gray-200 bg-white shadow-sm hover:border-primary-400'
          }`}>
            {service.isFree && (
              <span class="absolute top-4 right-4 text-xs font-semibold bg-primary-600 text-white px-3 py-1 rounded-full">
                Free
              </span>
            )}

            <!-- Meta row -->
            <div class="flex flex-wrap items-center gap-2 mb-3">
              <span class="inline-flex items-center gap-1 text-sm text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                {service.duration}
              </span>
              {service.format && (
                <span class="text-xs font-medium bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">
                  {service.format}
                </span>
              )}
            </div>

            <h3 class="text-xl font-bold text-gray-900 mb-1">{service.title}</h3>
            <p class="text-2xl font-bold text-primary-600 mb-4">{service.price}</p>

            <p class="text-gray-700 leading-relaxed mb-5">{service.description}</p>

            {service.whoFor && (
              <div class="mb-4">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Who this is for</p>
                <ul class="space-y-1">
                  {service.whoFor.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-gray-600 leading-relaxed">
                      <span class="mt-1.5 w-1 h-1 rounded-full bg-primary-400 shrink-0"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {service.whatYouGet && (
              <div class="mb-4">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">What you walk away with</p>
                <ul class="space-y-1">
                  {service.whatYouGet.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-gray-600 leading-relaxed">
                      <span class="mt-1.5 w-1 h-1 rounded-full bg-primary-400 shrink-0"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {service.note && (
              <p class="text-xs text-gray-400 leading-relaxed mb-5 italic">{service.note}</p>
            )}

            <div class="mt-auto pt-2 flex flex-wrap gap-3">
              <a
                href={`/services/${service.id}`}
                class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition"
              >
                See details →
              </a>
              {service.isFree && (
                <a
                  href={service.ctaLink}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center justify-center px-5 py-3 text-sm font-medium text-primary-700 border border-primary-300 hover:bg-primary-50 rounded-lg transition"
                >
                  Book on Topmate
                </a>
              )}
            </div>
          </div>
        ))}
      </div>

      <!-- Divider -->
      <div class="fade-up flex items-center gap-4 mb-10">
        <div class="flex-1 h-px bg-gray-200"></div>
        <span class="text-sm text-gray-400 font-medium">Team Sessions</span>
        <div class="flex-1 h-px bg-gray-200"></div>
      </div>

      <!-- Team Sessions -->
      <div class="fade-up mb-4">
        <h2 class="text-xl font-semibold text-gray-500 uppercase tracking-wider mb-6">For Teams</h2>
      </div>

      <div class="grid gap-6 md:grid-cols-2 fade-up-group mb-12">
        {teamServices.map((service) => (
          <div class="relative flex flex-col rounded-2xl border border-gray-200 bg-white shadow-sm p-6 hover:border-primary-400 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">

            <!-- Meta row -->
            <div class="flex flex-wrap items-center gap-3 mb-3">
              <span class="inline-flex items-center gap-1 text-sm text-gray-500">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>
                </svg>
                {service.duration}
              </span>
              {service.teamSize && (
                <span class="inline-flex items-center gap-1 text-sm text-gray-500">
                  <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                  {service.teamSize}
                </span>
              )}
              {service.format && (
                <span class="text-xs font-medium bg-gray-100 text-gray-600 px-2.5 py-1 rounded-full">
                  {service.format}
                </span>
              )}
            </div>

            <h3 class="text-xl font-bold text-gray-900 mb-1">{service.title}</h3>
            <p class="text-2xl font-bold text-primary-600 mb-4">{service.price}</p>

            <p class="text-gray-700 leading-relaxed mb-5">{service.description}</p>

            {service.covers && service.coversHeading && (
              <div class="mb-4">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">{service.coversHeading}</p>
                <ul class="space-y-1">
                  {service.covers.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-gray-600 leading-relaxed">
                      <span class="mt-1.5 w-1 h-1 rounded-full bg-primary-400 shrink-0"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {service.whoFor && (
              <div class="mb-4">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">Who this is for</p>
                <ul class="space-y-1">
                  {service.whoFor.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-gray-600 leading-relaxed">
                      <span class="mt-1.5 w-1 h-1 rounded-full bg-primary-400 shrink-0"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {service.whatYouGet && (
              <div class="mb-4">
                <p class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-2">What your team walks away with</p>
                <ul class="space-y-1">
                  {service.whatYouGet.map((item) => (
                    <li class="flex items-start gap-2 text-sm text-gray-600 leading-relaxed">
                      <span class="mt-1.5 w-1 h-1 rounded-full bg-primary-400 shrink-0"></span>
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            )}

            {service.note && (
              <p class="text-xs text-gray-400 leading-relaxed mb-5 italic">{service.note}</p>
            )}

            <div class="mt-auto pt-2">
              <a
                href={`/services/${service.id}`}
                class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition"
              >
                See details →
              </a>
            </div>
          </div>
        ))}
      </div>

      <!-- Closing section -->
      <div class="fade-up border-t border-gray-100 pt-8 pb-4">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">Not sure which one fits?</h2>
        <p class="text-gray-600 text-sm leading-relaxed mb-4 max-w-2xl">
          Most people start with the free discovery call. In 15 minutes I can usually tell you exactly which session (if any) would actually help. If your situation doesn't fit any of these, I'll tell you that too.
        </p>
        <ul class="space-y-1.5 text-sm text-gray-600 mb-5">
          <li><span class="text-gray-400">If you're a team lead exploring AI for your team:</span> start with Team Training.</li>
          <li><span class="text-gray-400">If you have a specific tool you want to build:</span> start with Build-Along.</li>
          <li><span class="text-gray-400">If you're an individual figuring things out:</span> start with 1:1 Mentorship or the Discovery Call.</li>
        </ul>
        <a
          href="https://topmate.io/jitangupta"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center text-sm text-primary-600 hover:underline font-medium"
        >
          Book a free discovery call →
        </a>
      </div>

    </div>
  </section>
</Layout>
