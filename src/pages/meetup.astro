
---
import Layout from '../layouts/Layout.astro';

const title = "Claude at Work — Hands-on AI Meetup in Mumbai | Jitan Gupta";
const description = "A hands-on Claude AI meetup in Mumbai for developers and non-technical professionals. Build a real MVP live. Sponsors and venue partners welcome.";

const SPONSOR_MAILTO = "mailto:hi@jitangupta.com?subject=Claude%20at%20Work%20Mumbai%20%E2%80%94%20Sponsorship%20Interest&body=Hi%20Jitan%2C%0A%0AI%27m%20interested%20in%20sponsoring%20%2F%20supporting%20the%20Claude%20at%20Work%20meetup.%0A%0AOrganization%3A%20%0ARole%3A%20%0AHow%20I%27d%20like%20to%20help%3A%20%0A%0ALooking%20forward%20to%20discussing.";
const VENUE_MAILTO = "mailto:hi@jitangupta.com?subject=Venue%20Offer%20%E2%80%94%20Claude%20at%20Work%20Mumbai&body=Hi%20Jitan%2C%0A%0AI%20can%20offer%20a%20venue%20for%20the%20Claude%20at%20Work%20meetup.%0A%0AVenue%20name%3A%20%0ALocation%3A%20%0ACapacity%3A%20%0AAvailable%20dates%3A%20%0AWi-Fi%20%2F%20Projector%3A%20%0A%0ALet%20me%20know%20if%20you%20need%20more%20details.";
---

<Layout title={title} description={description}>

  <!-- Hero -->
  <section class="bg-[#F8FAFC] mx-2">
    <div class="bg-white max-w-screen-xl mx-auto px-6 py-10 rounded-b-2xl">
      <div class="grid lg:grid-cols-2 gap-10 items-center">
        <!-- Image -->
        <div class="order-1 lg:order-2">
          <img
            src="/images/claude-meetup.jpg"
            alt="Claude at Work — Mumbai Meetup"
            class="w-full h-auto rounded-2xl shadow-md object-cover"
          />
        </div>
        <!-- Text -->
        <div class="order-2 lg:order-1">
          <span class="inline-block bg-primary-100 text-primary-700 text-xs font-semibold px-4 py-1.5 rounded-full mb-5 tracking-wide uppercase">
            Mumbai — Accepting Sponsors & Venue Partners
          </span>
          <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-5 leading-tight">
            Claude at Work
          </h1>
          <p class="text-lg text-gray-600 mb-8">
            A hands-on session where professionals — technical and non-technical — use Claude to solve a real problem, live. Not a product demo. A build session.
          </p>
          <div class="flex flex-wrap gap-4">
            <a
              href={SPONSOR_MAILTO}
              class="inline-flex items-center gap-2 px-6 py-3 text-base font-medium text-white bg-accent-600 hover:bg-accent-700 rounded-lg transition"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
              Become a Sponsor →
            </a>
            <a
              href="#venue"
              class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-900 border border-gray-300 rounded-lg hover:bg-gray-100 transition"
            >
              Offer a Venue
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What Is This Meetup -->
  <section class="bg-[#F8FAFC] py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">What Is This Meetup?</h2>
      <p class="text-gray-600 mb-8 text-lg">Three things happen at this session — for everyone, not just developers.</p>
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Card 1 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-primary-100 text-primary-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Claude Code</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            For developers: use Claude as a pair-programming partner directly from the terminal. Live coding on real projects — not toy demos.
          </p>
        </div>
        <!-- Card 2 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-accent-100 text-accent-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Claude Cowork</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            For non-developers: automate documents, spreadsheets, presentations, and file management from your desktop. No coding. No setup.
          </p>
        </div>
        <!-- Card 3 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-primary-100 text-primary-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Build an MVP — Live</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Attendees will pick a real problem, form teams, and build a working MVP during the session using Claude as their AI co-pilot.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Venue Requirements -->
  <section id="venue" class="bg-white py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-widest mb-2">What we need</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">Venue Requirements</h2>
      <p class="text-gray-600 mb-8 text-lg">People will be working on laptops, forming teams, and demoing what they built. The space needs to support that.</p>
      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-4">
        <!-- Seats -->
        <div class="bg-[#F8FAFC] border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-primary-100 text-primary-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">20–50 seats</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Flexible seating — classroom, boardroom, or open floor. Teams of 3–5 need to cluster together.
          </p>
        </div>
        <!-- Wi-Fi -->
        <div class="bg-[#F8FAFC] border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-accent-100 text-accent-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><circle cx="12" cy="20" r="1" fill="currentColor"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Reliable Wi-Fi</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Everyone will be running Claude live. Bandwidth matters more than speed.
          </p>
        </div>
        <!-- Projector -->
        <div class="bg-[#F8FAFC] border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-primary-100 text-primary-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="15" x="2" y="3" rx="2"/><polyline points="8 21 12 17 16 21"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Projector / Screen</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            For live demos in Part 1 and team presentations in Part 2.
          </p>
        </div>
        <!-- Power -->
        <div class="bg-[#F8FAFC] border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-accent-100 text-accent-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22V12"/><path d="M5 12H2a10 10 0 0 0 20 0h-3"/><path d="M12 2v4"/><path d="M9 6h6"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-2">Power access</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Charging stations or extension boards. Laptops drain fast during AI-heavy sessions.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Meetup Format -->
  <section class="bg-[#F8FAFC] py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-8">How the Session Runs</h2>
      <div class="grid gap-6 md:grid-cols-2 mb-10">
        <!-- Part 1 -->
        <div class="border border-gray-200 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-primary-100 text-primary-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Part 1</span>
            <h3 class="text-xl font-bold text-gray-900">Learn</h3>
          </div>
          <ul class="space-y-3 text-gray-700 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Introduction to Claude's capabilities
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Live demos of Code and Cowork
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Real-world use cases at work
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Tips for getting the most out of AI
            </li>
          </ul>
        </div>
        <!-- Part 2 -->
        <div class="border border-gray-200 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-accent-100 text-accent-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Part 2</span>
            <h3 class="text-xl font-bold text-gray-900">Build</h3>
          </div>
          <ul class="space-y-3 text-gray-700 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Form small teams (mixed skill levels)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Pick a real problem to solve
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Build an MVP with Claude as co-pilot
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Demo what you built to the group
            </li>
          </ul>
        </div>
      </div>

      <!-- Stats Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-white rounded-2xl p-5 text-center border border-gray-100">
          <p class="text-3xl font-bold text-primary-600 mb-1">1–2h</p>
          <p class="text-sm text-gray-600">Session length</p>
        </div>
        <div class="bg-white rounded-2xl p-5 text-center border border-gray-100">
          <p class="text-3xl font-bold text-primary-600 mb-1">20–50</p>
          <p class="text-sm text-gray-600">Ideal attendees</p>
        </div>
        <div class="bg-white rounded-2xl p-5 text-center border border-gray-100">
          <p class="text-3xl font-bold text-primary-600 mb-1">50/50</p>
          <p class="text-sm text-gray-600">Tech / non-tech mix</p>
        </div>
        <div class="bg-white rounded-2xl p-5 text-center border border-gray-100">
          <p class="text-3xl font-bold text-accent-500 mb-1">1 MVP</p>
          <p class="text-sm text-gray-600">Built live</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Why Support This -->
  <section class="bg-white py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <p class="text-xs font-semibold text-primary-600 uppercase tracking-widest mb-2">For partners & sponsors</p>
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-8">Why Support This</h2>
      <div class="grid gap-6 md:grid-cols-3">
        <!-- AI Companies -->
        <div class="bg-[#F8FAFC] border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-primary-100 text-primary-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a10 10 0 1 0 10 10"/><path d="M12 8v4l3 3"/><path d="M18 2v4h4"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">For AI Companies</h3>
          <ul class="space-y-3 text-gray-600 text-sm leading-relaxed">
            <li>Get your tools in the hands of 20–50 professionals who will use them at work the next day. This isn't a keynote audience — these are practitioners who build.</li>
            <li class="pt-2 border-t border-gray-100">Attendees leave with real projects built on your platform. That's adoption, not awareness.</li>
          </ul>
        </div>
        <!-- Corporates -->
        <div class="bg-[#F8FAFC] border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-accent-100 text-accent-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="16" height="20" x="4" y="2" rx="2"/><path d="M9 22v-4h6v4"/><path d="M8 6h.01"/><path d="M16 6h.01"/><path d="M12 6h.01"/><path d="M12 10h.01"/><path d="M8 10h.01"/><path d="M16 10h.01"/><path d="M8 14h.01"/><path d="M16 14h.01"/><path d="M12 14h.01"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">For Corporates</h3>
          <ul class="space-y-3 text-gray-600 text-sm leading-relaxed">
            <li>Give your team hands-on AI skills in a structured, low-risk setting. Mixed skill levels welcome — developers and non-technical staff work side by side.</li>
            <li class="pt-2 border-t border-gray-100">Your employees build something real in 2 hours. Better than any training slide deck.</li>
          </ul>
        </div>
        <!-- Venue Partners -->
        <div class="bg-[#F8FAFC] border border-gray-200 rounded-2xl p-6 hover:border-accent-500 shadow-sm hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
          <div class="w-10 h-10 bg-primary-100 text-primary-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          </div>
          <h3 class="text-lg font-bold text-gray-900 mb-3">For Venue Partners</h3>
          <ul class="space-y-3 text-gray-600 text-sm leading-relaxed">
            <li>20–50 tech professionals in your space. The event gets documented and shared on YouTube and LinkedIn — your venue gets credited.</li>
            <li class="pt-2 border-t border-gray-100">You provide the space. I handle everything else — promotion, logistics, content, follow-up. Zero cost to you.</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- About the Organizer -->
  <section id="about" class="bg-[#F8FAFC] py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-8">About the Organizer</h2>
      <div class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row gap-8 items-start">
        <img
          src="/jitan-bg.png"
          alt="Jitan Gupta"
          class="w-36 h-auto shrink-0 rounded-xl self-center md:self-start"
        />
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-1">Jitan Gupta</h3>
          <p class="text-primary-600 font-medium mb-4">AI Adoption Practitioner — helping teams and individuals use AI responsibly, practically, and without the hype</p>
          <p class="text-gray-700 leading-relaxed mb-6">
            10+ years building enterprise software — multi-tenant Kubernetes migrations, cloud infrastructure, identity platforms serving 50K+ daily authentications. The last year spent embedding Claude into real daily workflows and teaching others to do the same. I work with developers and non-technical professionals, and everything I teach comes from hands-on practice — not slides.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="https://jitangupta.com/" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              Website
            </a>
            <a href="https://www.youtube.com/@jitangupta" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-white bg-accent-600 hover:bg-accent-700 px-4 py-2 rounded-lg transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
              YouTube
            </a>
            <a href="https://www.linkedin.com/in/jitangupta/" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Relevant Work & Projects -->
  <section class="bg-white py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-8">Relevant Work & Projects</h2>
      <div class="max-w-3xl space-y-8">

        <div class="flex gap-5">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-accent-500 shrink-0 mt-1.5"></div>
            <div class="w-px flex-1 bg-gray-200 mt-2"></div>
          </div>
          <div class="pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-1">Cloud & SaaS at Scale</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
