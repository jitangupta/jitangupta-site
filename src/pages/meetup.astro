
---
import Layout from '../layouts/Layout.astro';

const title = "Claude at Work — Meetup by Jitan Gupta";
const description = "A hands-on meetup exploring Claude AI for tech and non-tech professionals. Build an MVP together.";

const MAILTO = "mailto:hi@jitangupta.com?subject=Claude%20at%20Work%20Meetup%20—%20Venue%20Interest";
---

<Layout title={title} description={description}>

  <!-- Hero -->
  <section class="bg-[#F8FAFC] mx-2">
    <div class="bg-white max-w-screen-xl mx-auto px-6 py-14 rounded-b-2xl text-center">
      <span class="inline-block bg-primary-100 text-primary-700 text-xs font-semibold px-4 py-1.5 rounded-full mb-5 tracking-wide uppercase">
        Meetup Proposal
      </span>
      <h1 class="text-4xl md:text-6xl font-bold text-gray-900 mb-5 leading-tight">
        Claude at Work
      </h1>
      <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-8">
        A hands-on meetup for tech and non-tech professionals to explore Claude AI — and build an MVP together, live.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href={MAILTO}
          class="inline-flex items-center gap-2 px-6 py-3 text-base font-medium text-white bg-accent-600 hover:bg-accent-700 rounded-lg transition"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          Get in Touch
        </a>
        <a
          href="#about"
          class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-900 border border-gray-300 rounded-lg hover:bg-gray-100 transition"
        >
          Learn More
        </a>
      </div>
    </div>
  </section>

  <!-- What Is This Meetup -->
  <section class="bg-[#F8FAFC] py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">What Is This Meetup?</h2>
      <p class="text-gray-600 mb-8 text-lg">Three things happen at this session — for everyone, not just developers.</p>
      <div class="grid gap-6 md:grid-cols-3">
        <!-- Card 1 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:border-accent-500 transition-colors">
          <div class="w-10 h-10 bg-primary-100 text-primary-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Claude Code</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            For developers: use Claude as a pair-programming partner directly from the terminal. Ship features faster, debug smarter, automate workflows.
          </p>
        </div>
        <!-- Card 2 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:border-accent-500 transition-colors">
          <div class="w-10 h-10 bg-accent-100 text-accent-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Claude Cowork</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            For everyone else: automate file management, create documents, spreadsheets, and presentations — no coding needed.
          </p>
        </div>
        <!-- Card 3 -->
        <div class="bg-white border border-gray-200 rounded-2xl p-6 hover:border-accent-500 transition-colors">
          <div class="w-10 h-10 bg-primary-100 text-primary-700 rounded-xl flex items-center justify-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2 3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          </div>
          <h3 class="text-xl font-bold text-gray-900 mb-2">Build an MVP — Live</h3>
          <p class="text-gray-600 text-sm leading-relaxed">
            Attendees will pick a real problem, form teams, and build a working MVP during the session using Claude as their AI co-pilot.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Meetup Format -->
  <section class="bg-white py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-8">How the Session Runs</h2>
      <div class="grid gap-6 md:grid-cols-2 mb-10">
        <!-- Part 1 -->
        <div class="border border-gray-200 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-primary-100 text-primary-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Part 1</span>
            <h3 class="text-xl font-bold text-gray-900">Learn</h3>
          </div>
          <ul class="space-y-3 text-gray-700 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Introduction to Claude's capabilities
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Live demos of Code and Cowork
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Real-world use cases at work
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Tips for getting the most out of AI
            </li>
          </ul>
        </div>
        <!-- Part 2 -->
        <div class="border border-gray-200 rounded-2xl p-6">
          <div class="flex items-center gap-3 mb-4">
            <span class="bg-accent-100 text-accent-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Part 2</span>
            <h3 class="text-xl font-bold text-gray-900">Build</h3>
          </div>
          <ul class="space-y-3 text-gray-700 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Form small teams (mixed skill levels)
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Pick a real problem to solve
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Build an MVP with Claude as co-pilot
            </li>
            <li class="flex items-start gap-2">
              <span class="text-accent-500 font-bold mt-0.5">→</span>
              Demo what you built to the group
            </li>
          </ul>
        </div>
      </div>

      <!-- Stats Row -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="bg-[#F8FAFC] rounded-2xl p-5 text-center border border-gray-100">
          <p class="text-3xl font-bold text-primary-600 mb-1">1–2h</p>
          <p class="text-sm text-gray-600">Session length</p>
        </div>
        <div class="bg-[#F8FAFC] rounded-2xl p-5 text-center border border-gray-100">
          <p class="text-3xl font-bold text-primary-600 mb-1">20–50</p>
          <p class="text-sm text-gray-600">Ideal attendees</p>
        </div>
        <div class="bg-[#F8FAFC] rounded-2xl p-5 text-center border border-gray-100">
          <p class="text-3xl font-bold text-primary-600 mb-1">50/50</p>
          <p class="text-sm text-gray-600">Tech / non-tech mix</p>
        </div>
        <div class="bg-[#F8FAFC] rounded-2xl p-5 text-center border border-gray-100">
          <p class="text-3xl font-bold text-accent-500 mb-1">1 MVP</p>
          <p class="text-sm text-gray-600">Built live</p>
        </div>
      </div>
    </div>
  </section>

  <!-- About the Organizer -->
  <section id="about" class="bg-[#F8FAFC] py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-8">About the Organizer</h2>
      <div class="bg-white border border-gray-200 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row gap-8 items-start">
        <img
          src="/jitan-bg.png"
          alt="Jitan Gupta"
          class="w-36 h-auto shrink-0 rounded-xl self-center md:self-start"
        />
        <div>
          <h3 class="text-2xl font-bold text-gray-900 mb-1">Jitan Gupta</h3>
          <p class="text-primary-600 font-medium mb-4">AI Adoption Practitioner — helping teams and individuals use AI responsibly, practically, and without the hype</p>
          <p class="text-gray-700 leading-relaxed mb-6">
            I've spent the last year embedding Claude into real workflows — mine and others'. Not as a party trick, but as a daily tool that changes how you work. I teach both developers and non-technical professionals how to adopt AI in a way that's thoughtful, sustainable, and actually useful on the job. Everything I share comes from hands-on experimentation — not theory.
          </p>
          <div class="flex flex-wrap gap-3">
            <a href="https://jitangupta.com/" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/><path d="M2 12h20"/></svg>
              Website
            </a>
            <a href="https://www.youtube.com/@jitangupta" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-white bg-accent-600 hover:bg-accent-700 px-4 py-2 rounded-lg transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
              YouTube
            </a>
            <a href="https://www.linkedin.com/in/jitangupta/" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
              LinkedIn
            </a>
            <a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
              GitHub
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Relevant Work & Projects -->
  <section class="bg-white py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-8">Relevant Work & Projects</h2>
      <div class="max-w-3xl space-y-8">

        <div class="flex gap-5">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-accent-500 shrink-0 mt-1.5"></div>
            <div class="w-px flex-1 bg-gray-200 mt-2"></div>
          </div>
          <div class="pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-1">File Safety Guard — Claude Plugin</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Built and published a plugin for Claude Code and Cowork that prevents accidental file deletion and overwrites. Includes auto-backups, activity logging, and dry-run planning.
            </p>
          </div>
        </div>

        <div class="flex gap-5">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-accent-500 shrink-0 mt-1.5"></div>
            <div class="w-px flex-1 bg-gray-200 mt-2"></div>
          </div>
          <div class="pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-1">40+ Open Source Repositories</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Active GitHub contributor across JavaScript, TypeScript, Dart, and more. Projects span form validation libraries, calendar tools, architecture templates, and developer utilities.
            </p>
          </div>
        </div>

        <div class="flex gap-5">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-accent-500 shrink-0 mt-1.5"></div>
            <div class="w-px flex-1 bg-gray-200 mt-2"></div>
          </div>
          <div class="pb-8">
            <h3 class="text-lg font-bold text-gray-900 mb-1">YouTube Content Creator</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Sharing technical knowledge and tutorials covering development workflows, cloud engineering, and AI tools.
            </p>
          </div>
        </div>

        <div class="flex gap-5">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 rounded-full bg-accent-500 shrink-0 mt-1.5"></div>
          </div>
          <div>
            <h3 class="text-lg font-bold text-gray-900 mb-1">Cloud & SaaS at Scale</h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              Professional experience modernizing legacy systems, designing Azure cloud architectures, and building AI-powered tools for enterprise SaaS platforms.
            </p>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-[#F8FAFC] py-12 px-6">
    <div class="max-w-screen-xl mx-auto">
      <div class="bg-white border border-gray-200 rounded-2xl p-8 md:p-12 text-center">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Let's make this happen</h2>
        <p class="text-gray-600 text-lg max-w-xl mx-auto mb-8">
          Looking for a venue that can host 20–50 people with Wi-Fi and a projector. Flexible on dates and format.
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a
            href={MAILTO}
            class="inline-flex items-center gap-2 px-6 py-3 text-base font-medium text-white bg-accent-600 hover:bg-accent-700 rounded-lg transition"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            Offer a Venue
          </a>
          <a
            href="https://www.linkedin.com/in/jitangupta/"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 justify-center px-6 py-3 text-base font-medium text-gray-900 border border-gray-300 rounded-lg hover:bg-gray-100 transition"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
            Connect on LinkedIn
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>
