---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import CommonCTA from "../components/CommonCTA.astro";
import Chatwoot from "../components/chatwoot.astro";
import WebSiteSchema from "../components/schema/WebSiteSchema.astro";
import "../styles/global.css";
import { featuredVideos } from "../data/videos";
import { builds } from "../data/builds";

import { getCollection } from "astro:content";
const caseStudies = (await getCollection("caseStudies")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredBuilds = builds.slice(0, 3);
const homeTitle = "Jitan Gupta - Platform engineer figuring out Claude Code, MCP, and agents";
const homeDescription = "I'm a Mumbai-based platform engineer. I publish what I learn about Claude Code, MCP servers, and agent frameworks on YouTube, including the parts that broke.";
const aiSummaryPrompt = encodeURIComponent(
	"I want to understand what Jitan Gupta does at jitangupta.com. He is a Mumbai-based platform engineer who builds with AI tools in public, breaks down Claude Code, MCP servers, and agent frameworks for other engineers, and shares honest lessons on YouTube, including the parts that broke. Summarize what he builds, what he teaches, and why technical peers or event organizers might follow his work: https://jitangupta.com/",
);
const workingMethod = [
	{
		number: "01",
		title: "Test tools against real engineering work",
		description: "I use Claude Code, MCP servers, and agent workflows on concrete software problems before turning them into lessons.",
	},
	{
		number: "02",
		title: "Publish what worked and what broke",
		description: "The useful parts usually sit next to the failures, wrong turns, and missing context. I show both.",
	},
	{
		number: "03",
		title: "Turn patterns into tools and frameworks",
		description: "When something repeats, I shape it into a build, checklist, video, or framework other engineers can reuse.",
	},
];
const frameworkPreview = [
	"Task list",
	"Review commands",
	"Security check",
	"Manual testing",
	"PR + CI review",
];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={homeTitle} description={homeDescription} />
		<WebSiteSchema />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="bg-canvas mx-2">
			<div class="hero-grid bg-white border border-t-0 border-slate-200 max-w-screen-xl px-6 py-8 mx-auto lg:gap-10 lg:py-12 lg:grid-cols-12 rounded-b-2xl relative overflow-hidden">
				<!-- Subtle dot-grid watermark -->
				<div class="dot-grid" aria-hidden="true"></div>

				<!-- Photo: first in DOM. Top on mobile, left col on desktop (natural grid order). -->
				<div class="flex items-center justify-center lg:col-span-5 relative z-10 mb-4 lg:mb-0">
					<img
						src="/jitan-bg.png"
						class="w-52 sm:w-64 lg:w-full lg:max-w-[340px] h-auto object-contain"
						alt="Jitan Gupta"
					/>
				</div>

				<!-- Text: second in DOM. Below photo on mobile, right col on desktop. -->
				<div class="mr-auto place-self-center lg:col-span-7 relative z-10">
					<p class="section-label mb-3 hero-fade hero-fade-1">Mumbai, India</p>
					<h1 class="hero-fade hero-fade-2 max-w-2xl mb-4 text-3xl md:text-4xl xl:text-5xl font-bold">
						I'm Jitan, a platform engineer figuring out how AI tools actually work.
					</h1>
					<p class="hero-fade hero-fade-3 max-w-xl font-light text-gray-600 md:text-base mb-6 leading-relaxed">
						For ten years, I've shipped software in production. For the last two, I've been pulling apart Claude Code, MCP, and agent frameworks to understand what's underneath the demos. I share the working pieces on YouTube, including the parts that broke, which is usually more useful.
					</p>
					<div class="hero-fade hero-fade-3 flex flex-wrap gap-3 mb-7">
						<a
							href="https://www.youtube.com/@jitangupta"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
							Watch on YouTube
						</a>
						<a
							href="/builds"
							class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-800 border border-gray-300 rounded-lg hover:bg-gray-50 hover:border-gray-400 transition"
						>
							See what I've built
						</a>
					</div>
					<!-- Credential stats -->
					<div class="hero-fade hero-fade-3 grid grid-cols-3 gap-5 pt-6 border-t border-slate-200">
						<div>
							<p class="text-xl font-bold text-gray-900">10+</p>
							<p class="text-xs text-gray-500 uppercase tracking-wide font-medium mt-0.5">Years shipping production software</p>
						</div>
						<div>
							<p class="text-xl font-bold text-gray-900">PromptMate</p>
							<p class="text-xs text-gray-500 uppercase tracking-wide font-medium mt-0.5">Live on the Chrome Web Store</p>
						</div>
						<div>
							<p class="text-xl font-bold text-gray-900">5-Check</p>
							<p class="text-xs text-gray-500 uppercase tracking-wide font-medium mt-0.5">Framework for AI-generated code</p>
						</div>
					</div>
				</div>
				
			</div>

			<!-- Ask AI to summarize - full-width bottom row inside hero card -->
				<div class="col-span-12 relative z-10 border-gray-100 pt-4 pb-2 flex flex-col sm:flex-row items-center justify-center gap-4 sm:gap-6">
					<p class="text-xs text-gray-400 tracking-widest uppercase">Summarize what I do with AI</p>
					<div class="flex items-center gap-5">
	
						<a
							href={`https://claude.ai/new?q=${aiSummaryPrompt}`}
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Summarize Jitan's work using Claude"
							title="Open in Claude"
							class="text-gray-300 hover:text-gray-700 transition-colors"
						>
							<svg viewBox="0 0 24 24" fill="currentColor" width="22" height="22" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
								<g clip-path="url(#clip-claude-hero)">
									<path d="M4.71379 15.956L9.43179 13.308L9.51079 13.078L9.43079 12.95H9.20079L8.41079 12.902L5.71579 12.829L3.37879 12.732L1.11379 12.61L0.543789 12.489L0.00878906 11.785L0.0637891 11.432L0.543789 11.111L1.22879 11.171L2.74679 11.275L5.02379 11.432L6.67479 11.53L9.12179 11.785H9.51079L9.56479 11.627L9.43179 11.53L9.32879 11.432L6.97279 9.836L4.42279 8.148L3.08679 7.176L2.36479 6.685L1.99979 6.223L1.84179 5.215L2.49779 4.493L3.37779 4.553L3.60179 4.614L4.49479 5.3L6.40079 6.776L8.89079 8.609L9.25479 8.913L9.40079 8.809L9.41879 8.737L9.25479 8.463L7.90079 6.017L6.45579 3.527L5.81179 2.495L5.64179 1.876C5.57766 1.63815 5.54306 1.39331 5.53879 1.147L6.28679 0.133L6.69979 0L7.69479 0.134L8.11479 0.498L8.73379 1.913L9.73479 4.14L11.2898 7.17L11.7448 8.068L11.9878 8.9L12.0778 9.155H12.2368V9.01L12.3638 7.304L12.6008 5.209L12.8308 2.514L12.9108 1.754L13.2868 0.844L14.0338 0.352L14.6168 0.632L15.0968 1.317L15.0298 1.761L14.7438 3.612L14.1858 6.515L13.8208 8.457H14.0338L14.2768 8.215L15.2598 6.909L16.9118 4.845L17.6398 4.025L18.4898 3.121L19.0368 2.69H20.0688L20.8278 3.819L20.4878 4.985L19.4248 6.332L18.5448 7.474L17.2818 9.174L16.4918 10.534L16.5658 10.644L16.7538 10.624L19.6068 10.018L21.1488 9.738L22.9888 9.423L23.8208 9.811L23.9108 10.206L23.5838 11.013L21.6168 11.499L19.3098 11.961L15.8738 12.774L15.8308 12.804L15.8798 12.865L17.4278 13.011L18.0898 13.047H19.7098L22.7278 13.272L23.5178 13.794L23.9908 14.432L23.9108 14.917L22.6978 15.537L21.0578 15.148L17.2328 14.238L15.9228 13.909H15.7398V14.019L16.8328 15.087L18.8358 16.897L21.3438 19.227L21.4708 19.805L21.1498 20.26L20.8098 20.211L18.6058 18.554L17.7558 17.807L15.8308 16.187H15.7038V16.357L16.1468 17.006L18.4898 20.527L18.6118 21.607L18.4418 21.96L17.8348 22.173L17.1668 22.051L15.7948 20.127L14.3798 17.959L13.2388 16.016L13.0988 16.096L12.4248 23.35L12.1088 23.72L11.3808 24L10.7738 23.539L10.4518 22.792L10.7738 21.316L11.1618 19.392L11.4778 17.862L11.7628 15.962L11.9328 15.33L11.9208 15.288L11.7808 15.306L10.3488 17.273L8.16879 20.218L6.44479 22.063L6.03179 22.227L5.31579 21.857L5.38179 21.195L5.78279 20.606L8.16879 17.57L9.60779 15.688L10.5368 14.602L10.5308 14.444H10.4758L4.13779 18.56L3.00779 18.706L2.52279 18.25L2.58279 17.504L2.81379 17.261L4.72079 15.949L4.71379 15.956Z"/>
								</g>
								<defs><clipPath id="clip-claude-hero"><rect width="24" height="24" fill="white"/></clipPath></defs>
							</svg>
						</a>
	
						<a
							href={`https://chatgpt.com/?prompt=${aiSummaryPrompt}`}
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Summarize Jitan's work using ChatGPT"
							title="Open in ChatGPT"
							class="text-gray-300 hover:text-gray-700 transition-colors"
						>
							<svg viewBox="0 0 16 16" fill="currentColor" width="22" height="22" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
								<g clip-path="url(#clip-chatgpt-hero)">
