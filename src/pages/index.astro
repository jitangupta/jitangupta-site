---
import PaperLayout from "../layouts/PaperLayout.astro";
import WebSiteSchema from "../components/schema/WebSiteSchema.astro";
import { featuredVideos } from "../data/videos";
import { builds } from "../data/builds";
import { getCollection } from "astro:content";

const caseStudies = (await getCollection("caseStudies"))
  .filter((cs) => !cs.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const liveBuilds = builds.slice(0, 4);

const homeTitle = "Jitan Gupta — Engineer building AI infrastructure & developer tooling";
const homeDescription =
  "Ten years shipping production software across Kubernetes, multi-tenant SaaS, identity, and deployment automation. Now building at the AI layer: MCP servers, agent workflows, and developer tools that survive real engineering constraints.";

const aiSummaryPrompt = encodeURIComponent(
  "I want to understand what Jitan Gupta does at jitangupta.com. He is a Mumbai-based engineer building AI infrastructure and developer tooling in public — MCP servers, agent workflows, Chrome extensions, and pre-merge frameworks for AI-generated code. Ten years of production engineering behind it. Summarize what he builds, how he works, and why senior engineers, AI builders, and founders might follow his work: https://jitangupta.com/",
);

const statusLabel: Record<string, string> = {
  live: "Live · in use",
  "in-progress": "In progress",
  planned: "Planned",
};

const csYears: Record<string, string> = {
  "probabilistic-deployment-orchestration": "2024 — Present",
  "multi-tenant-aks-migration": "2024 — Present",
  "university-credit-system-migration": "2021 — 2024",
  "user-management-migration": "2024 — Present",
};

const csBriefs: Record<string, string> = {
  "probabilistic-deployment-orchestration":
    "A working RAG-based POC that turns 2 hours of tenant upgrade planning into 10 minutes. Modeled annual savings: ~$17K.",
  "multi-tenant-aks-migration":
    "Multi-tenant Kubernetes migration, version lock-in solved. Today I'd automate the tenant-by-tenant validation with AI. Back then we did it manually.",
  "university-credit-system-migration":
    "Cloud-native re-architecture of a payments system. 300% improvement in deployment frequency. The kind of domain complexity where AI-generated code breaks on day one if you don't understand the system.",
  "user-management-migration":
    "Identity systems have zero margin for error. AI accelerates the boring parts; a human owns the critical path.",
};

const homepageCaseStudies = caseStudies
  .filter((cs) => csYears[cs.id])
  .sort(
    (a, b) =>
      Object.keys(csYears).indexOf(a.id) - Object.keys(csYears).indexOf(b.id),
  );
---

<PaperLayout title={homeTitle} description={homeDescription}>
  <WebSiteSchema slot="head" />

  <style>
    /* ===== HERO ===== */
    .hero {
      padding: clamp(72px, 10vh, 140px) 0 clamp(72px, 12vh, 160px);
      position: relative;
    }
    .hero-split {
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 64px;
      align-items: center;
    }
    .hero-text { display: flex; flex-direction: column; gap: 32px; }
    .hero-portrait {
      aspect-ratio: 4/5;
      border-radius: 4px;
      overflow: hidden;
      border: 1px solid var(--hairline);
      align-self: start;
    }
    .hero-portrait img { width: 100%; height: 100%; object-fit: cover; object-position: top center; display: block; }
    @media (max-width: 900px) {
      .hero-split { grid-template-columns: 1fr; gap: 40px; }
      .hero-portrait { max-width: 200px; margin: 0 auto; }
    }
    .hero .meta-row { display: flex; justify-content: space-between; gap: 24px; flex-wrap: wrap; }
    .hero h1 { margin: 0; }
    .hero .lede { max-width: 64ch; }
    .hero .cta-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 8px; }
    .hero-pillars {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 32px;
      padding-top: 40px;
      border-top: 1px solid var(--hairline);
      margin-top: 32px;
    }
    .hero-pillars .pillar { display: flex; flex-direction: column; gap: 6px; }
    .hero-pillars .pillar .k {
      font-family: "Geist Mono", monospace;
      font-size: 11.5px;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--muted);
    }
    .hero-pillars .pillar .v { font-size: 16px; color: var(--ink); line-height: 1.4; }
    @media (max-width: 900px) { .hero-pillars { grid-template-columns: repeat(2, 1fr); gap: 24px; } }
    @media (max-width: 480px) { .hero-pillars { grid-template-columns: 1fr; gap: 20px; } }

    .hero-bg {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background-image: linear-gradient(to right, color-mix(in oklch, var(--ink) 5%, transparent) 1px, transparent 1px);
      background-size: 80px 100%;
      mask-image: linear-gradient(to bottom, black, transparent 70%);
      -webkit-mask-image: linear-gradient(to bottom, black, transparent 70%);
      opacity: 0.6;
    }

    /* ===== LIVE PROJECTS ===== */
    .now-list { border-top: 1px solid var(--hairline); }
    .now-row {
      display: grid;
      grid-template-columns: 56px 1.6fr 2fr 1fr 24px;
      gap: 24px;
      padding: 28px 0;
      align-items: start;
      border-bottom: 1px solid var(--hairline);
      transition: background 200ms ease;
    }
    .now-row:hover { background: var(--bg-tint); }
    .now-row .idx { font-family: "Geist Mono", monospace; font-size: 12px; color: var(--muted); padding-top: 4px; }
    .now-row .name { font-size: 20px; font-weight: 500; letter-spacing: -0.015em; color: var(--ink); }
    .now-row .name .stat { display: block; margin-top: 8px; }
    .now-row .desc { color: var(--ink-2); font-size: 15.5px; line-height: 1.55; }
    .now-row .tags { display: flex; flex-wrap: wrap; gap: 6px; align-items: flex-start; justify-content: flex-end; }
    .now-row .go { color: var(--muted); text-align: right; padding-top: 4px; }
    .now-row:hover .go { color: var(--accent); }
    @media (max-width: 820px) {
      .now-row {
        grid-template-columns: 36px 1fr 24px;
        grid-template-areas: "idx name go" ".   desc desc" ".   tags tags";
        gap: 12px;
      }
      .now-row .idx { grid-area: idx; }
      .now-row .name { grid-area: name; }
      .now-row .desc { grid-area: desc; }
      .now-row .tags { grid-area: tags; justify-content: flex-start; }
      .now-row .go { grid-area: go; }
    }

    /* ===== FRAMEWORKS PREVIEW ===== */
    .fw-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }
    .fw-card {
      border: 1px solid var(--hairline);
      border-radius: 4px;
      padding: 32px;
      display: flex;
      flex-direction: column;
      gap: 16px;
      background: var(--bg);
      transition: border-color 200ms ease, background 200ms ease;
      position: relative;
    }
    .fw-card:hover { border-color: var(--ink); }
    .fw-card .label { font-family: "Geist Mono", monospace; font-size: 11.5px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); }
    .fw-card h3 { font-size: clamp(22px, 2vw, 28px); line-height: 1.1; letter-spacing: -0.02em; }
    .fw-card .steps { display: flex; flex-direction: column; gap: 10px; margin-top: 8px; padding-top: 20px; border-top: 1px solid var(--hairline); }
    .fw-card .step { display: grid; grid-template-columns: 36px 1fr; gap: 14px; font-size: 14.5px; color: var(--ink-2); align-items: baseline; }
    .fw-card .step .n { font-family: "Geist Mono", monospace; font-size: 11.5px; color: var(--muted); }
    .fw-card .more { margin-top: auto; padding-top: 16px; display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: var(--ink); font-weight: 500; }
    @media (max-width: 820px) { .fw-grid { grid-template-columns: 1fr; } }

    /* ===== VIDEOS ===== */
    .vid-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
    .vid-card { display: flex; flex-direction: column; gap: 14px; background: transparent; border-top: 1px solid var(--hairline); padding-top: 22px; }
    .vid-card .thumb { aspect-ratio: 16 / 9; border: 1px solid var(--hairline); border-radius: 4px; position: relative; overflow: hidden; transition: border-color 200ms ease; }
    .vid-card .thumb img { width: 100%; height: 100%; object-fit: cover; transition: transform 300ms ease; }
    .vid-card:hover .thumb { border-color: var(--ink); }
    .vid-card:hover .thumb img { transform: scale(1.03); }
    .vid-card .thumb .play { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
    .vid-card .thumb .play span { width: 48px; height: 48px; border-radius: 50%; background: var(--ink); color: var(--bg); display: flex; align-items: center; justify-content: center; transition: background 200ms ease, transform 200ms ease; font-size: 18px; padding-left: 3px; }
    .vid-card:hover .thumb .play span { background: var(--accent); transform: scale(1.06); }
    .vid-card .runtime { position: absolute; bottom: 10px; right: 10px; font-family: "Geist Mono", monospace; font-size: 11px; background: color-mix(in oklch, var(--ink) 80%, transparent); color: var(--bg); padding: 3px 7px; border-radius: 3px; }
    .vid-card .meta { font-family: "Geist Mono", monospace; font-size: 11.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); display: flex; gap: 12px; }
    .vid-card h3 { font-size: 18px; line-height: 1.25; letter-spacing: -0.015em; font-weight: 500; }
    .vid-card p { font-size: 14.5px; color: var(--ink-2); line-height: 1.5; }
    .vid-card .more { margin-top: auto; padding-top: 6px; font-size: 13.5px; color: var(--ink); font-weight: 500; display: inline-flex; align-items: center; gap: 6px; }
    @media (max-width: 980px) { .vid-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 640px) { .vid-grid { grid-template-columns: 1fr; } }

    /* ===== CASE STUDIES ===== */
    .cs-list { border-top: 1px solid var(--hairline); }
    .cs-row { display: grid; grid-template-columns: 100px 1.5fr 2fr 100px; gap: 24px; padding: 28px 0; border-bottom: 1px solid var(--hairline); align-items: baseline; transition: background 200ms ease; }
    .cs-row:hover { background: var(--bg-tint); }
    .cs-row .year { font-family: "Geist Mono", monospace; font-size: 12px; color: var(--muted); }
    .cs-row h3 { font-size: 18px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.3; }
    .cs-row p { font-size: 14.5px; color: var(--ink-2); line-height: 1.5; }
    .cs-row .open { font-size: 13px; color: var(--muted); text-align: right; font-family: "Geist Mono", monospace; letter-spacing: 0.04em; text-transform: uppercase; }
    .cs-row:hover .open { color: var(--accent); }
    @media (max-width: 820px) { .cs-row { grid-template-columns: 1fr; gap: 8px; } .cs-row .open { text-align: left; } }

    /* ===== HOW I WORK ===== */
    .hw-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 24px; }
    @media (max-width: 820px) { .hw-grid { grid-template-columns: 1fr; } }

    /* ===== SPEAKING ===== */
    .speak { display: grid; grid-template-columns: 1.2fr 1fr; gap: 56px; align-items: end; padding: 80px 0; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline); }
    .speak h2 { margin-bottom: 16px; }
    .speak .right { display: flex; flex-direction: column; gap: 16px; align-items: flex-start; }
    .speak .right .topics { display: flex; flex-wrap: wrap; gap: 8px; }
    @media (max-width: 820px) { .speak { grid-template-columns: 1fr; gap: 24px; padding: 56px 0; } }

    /* ===== AI SUMMARY ===== */
    .ai-block { padding: 64px 0; border-bottom: 1px solid var(--hairline); }
    .ai-block h3 { font-size: 18px; margin-bottom: 8px; font-weight: 500; letter-spacing: -0.015em; }
    .ai-block p { color: var(--ink-2); margin-bottom: 24px; max-width: 60ch; font-size: 15px; }
    .ai-summary { display: flex; flex-wrap: wrap; gap: 10px; align-items: center; }
    .ai-summary .label { font-family: "Geist Mono", monospace; font-size: 12px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); margin-right: 8px; }
    .ai-summary a { display: inline-flex; align-items: center; gap: 6px; padding: 8px 12px; border: 1px solid var(--hairline); border-radius: 6px; font-size: 13.5px; color: var(--ink-2); background: var(--bg-tint); }
    .ai-summary a:hover { border-color: var(--ink); color: var(--ink); }
    .ai-summary a .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--accent); }
  </style>

  <!-- ====== HERO ====== -->
  <section class="hero">
    <div class="hero-bg" aria-hidden="true"></div>
    <div class="wrap">
      <div class="hero-split">
        <div class="hero-text reveal">
          <div class="meta-row">
            <span class="eyebrow">Mumbai · Building in public · 2026</span>
            <a class="eyebrow" href="/contact">
              <span style="display:inline-block;width:8px;height:8px;background:var(--accent);border-radius:50%;"></span>
              Open to Applied AI Engineer · AI Infrastructure · Forward Deployed Engineer roles
            </a>
          </div>

          <h1 class="display">
            I build AI infrastructure and agent workflows that survive real production constraints.
          </h1>

          <p class="lede">
            Ten years shipping production software across Kubernetes, multi-tenant SaaS, identity, and deployment automation. Now building at the AI layer: MCP servers, agent workflows, and developer tools that survive real engineering constraints.
          </p>

          <div class="cta-row">
            <a class="btn primary" href="/builds">
              See what I'm building
              <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </a>
            <a class="btn" href="/case-studies">Case studies</a>
            <a class="btn" href="https://www.youtube.com/@jitangupta" target="_blank" rel="noopener noreferrer">YouTube</a>
          </div>
        </div>
        <div class="hero-portrait reveal">
          <img src="/jitan-bg.jpg" alt="Jitan Gupta" />
        </div>
      </div>

      <div class="hero-pillars reveal">
        <div class="pillar">
          <span class="k">400+ tenants</span>
          <span class="v">Multi-tenant AKS migration shipped without downtime.</span>
        </div>
        <div class="pillar">
          <span class="k">14 microservices</span>
          <span class="v">Moved to Kubernetes. Version lock-in solved.</span>
        </div>
        <div class="pillar">
          <span class="k">50K+ daily authentications</span>
          <span class="v">Identity migration. Zero margin for error.</span>
        </div>
        <div class="pillar">
          <span class="k">2h → 10m</span>
          <span class="v">RAG-based release planning POC. Modeled ~$17K annual savings.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== NOW / LIVE PROJECTS ====== -->
  <section class="hairline-t">
    <div class="wrap">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow">Now</span>
          <h2 class="h2" style="margin-top:18px;">Live projects.<br>All shipping, all weekly.</h2>
        </div>
        <p class="lede">
          The current work, with status. Each one started as a real problem, got built in public on the channel, and is in use today.
        </p>
      </div>

      <div class="now-list">
        {liveBuilds.map((build, i) => (
          <a
            class="now-row reveal"
            href={build.githubUrl || build.liveUrl || "#"}
            target={build.githubUrl || build.liveUrl ? "_blank" : undefined}
            rel={build.githubUrl || build.liveUrl ? "noopener noreferrer" : undefined}
          >
            <span class="idx">{String(i + 1).padStart(2, "0")}</span>
            <div class="name">
              {build.title}
              <span class={`status stat${build.status !== "live" ? " muted" : ""}`}>
                {statusLabel[build.status]}
              </span>
            </div>
            <p class="desc">{build.description}</p>
            <div class="tags">
              {build.techStack.slice(0, 3).map((tech) => (
                <span class="tag">{tech}</span>
              ))}
            </div>
            <span class="go">→</span>
          </a>
        ))}
      </div>

      <div style="margin-top: 32px; display: flex; gap: 12px;">
        <a class="btn" href="/builds">
          All builds
          <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ====== HOW I WORK ====== -->
  <section>
    <div class="wrap">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow">Operating style</span>
          <h2 class="h2" style="margin-top:18px;">How I work.</h2>
        </div>
        <p class="lede">
          The behaviors that matter for applied AI work. Not a methodology — just how I actually operate.
        </p>
      </div>

      <div class="hw-grid">
        <div class="fw-card reveal">
          <span class="label">User-facing</span>
          <h3>From real constraints, not abstract demos</h3>
          <p class="body" style="font-size:15.5px;">
            I work from real user and business problems. General store operations, startup product ownership, enterprise stakeholder management, team training. The customer-facing instinct came before the engineering career.
          </p>
        </div>

        <div class="fw-card reveal">
          <span class="label">Engineering depth</span>
          <h3>The boring systems that make AI work matter</h3>
          <p class="body" style="font-size:15.5px;">
            AKS, multi-tenant SaaS, identity systems, legacy modernization. Ten years of the systems work that tells you where AI helps and where it quietly breaks things in production.
          </p>
        </div>

        <div class="fw-card reveal">
          <span class="label">AI layer</span>
          <h3>Infrastructure, not just API calls</h3>
          <p class="body" style="font-size:15.5px;">
            MCP servers, agent workflows, observable traces, evals, token controls. Building the layer that makes AI useful to a real engineering team — not demos that stop working after day one.
          </p>
        </div>

        <div class="fw-card reveal">
          <span class="label">Operating mode</span>
          <h3>Build → deploy → observe → teach</h3>
          <p class="body" style="font-size:15.5px;">
            I ship the thing, run it in production, then write down exactly what worked and what didn't. The YouTube channel and the articles are the output of that loop, not the other way around.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== CASE STUDIES ====== -->
  <section>
    <div class="wrap">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow">Foundation</span>
          <h2 class="h2" style="margin-top:18px;">Production work before the AI layer.</h2>
        </div>
        <p class="lede">
          The boring depth. Identity migrations, multi-tenant Kubernetes, legacy modernization — plus a working AI release-orchestration POC. That's the systems work behind knowing when AI helps and when it doesn't.
        </p>
      </div>

      <div class="cs-list">
        {homepageCaseStudies.map((cs) => (
          <a class="cs-row reveal" href={`/case-studies/${cs.id}`}>
            <span class="year">{csYears[cs.id]}</span>
            <h3>{cs.data.pageTitle}</h3>
            <p>{csBriefs[cs.id] || cs.data.description}</p>
            <span class="open">Case → </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ====== FRAMEWORKS ====== -->
  <section>
    <div class="wrap">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow">Frameworks</span>
          <h2 class="h2" style="margin-top:18px;">The repeatable parts of working with AI tools.</h2>
        </div>
        <p class="lede">
          When something works twice, I turn it into a checklist other engineers can run. The frameworks below are the ones I actually use, not aspirational.
        </p>
      </div>

      <div class="fw-grid">
        <a class="fw-card reveal" href="/frameworks#five-check">
          <span class="label">Current · stable</span>
          <h3>5-Check</h3>
          <p class="body" style="font-size:15.5px;">
            A pre-merge check for AI-generated code. Trust, verify, override before merge. Five gates between "agent finished" and "this lands on main".
          </p>
          <div class="steps">
            <div class="step"><span class="n">01</span> Task list — what was actually agreed</div>
            <div class="step"><span class="n">02</span> Review commands — what the agent ran</div>
            <div class="step"><span class="n">03</span> Security check — secrets, surface, blast radius</div>
            <div class="step"><span class="n">04</span> Manual testing — exercise the unhappy path</div>
            <div class="step"><span class="n">05</span> PR + CI review — diff and pipeline</div>
          </div>
          <span class="more">
            Read the framework
            <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
          </span>
        </a>

        <a class="fw-card reveal" href="/frameworks#dev-loop">
          <span class="label">Current · evolving</span>
          <h3>AI-Assisted Development Loop</h3>
          <p class="body" style="font-size:15.5px;">
            The outer loop the 5-Check sits inside. Task boundaries, review commands, security checks, manual testing, changeset review, human judgment: the whole arc, not just the merge gate.
          </p>
          <div class="steps">
            <div class="step"><span class="n">→</span> Frame the task small enough to verify</div>
            <div class="step"><span class="n">→</span> Pair with the agent, watch its commands</div>
            <div class="step"><span class="n">→</span> Run the 5-Check before any merge</div>
            <div class="step"><span class="n">→</span> Capture what broke for the next loop</div>
          </div>
          <span class="more">
            Read the framework
            <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- ====== VIDEOS ====== -->
  <section class="hairline-t">
    <div class="wrap">
      <div class="section-head reveal">
        <div>
          <span class="eyebrow">Recordings</span>
          <h2 class="h2" style="margin-top:18px;">Working with AI tools, on camera.</h2>
        </div>
        <p class="lede">
          Short, technical, Hinglish. The experiments themselves, not summaries. The most useful ones usually include the part where it broke.
        </p>
      </div>

      <div class="vid-grid">
        {featuredVideos.slice(0, 3).map((video) => (
          <a class="vid-card reveal" href={video.youtubeUrl} target="_blank" rel="noopener noreferrer">
            <div class="thumb">
              <img src={video.thumbnail} alt={video.title} loading="lazy" />
              <div class="play"><span>▶</span></div>
            </div>
            <div class="meta">
              <span>{video.category === "claude-code" ? "Claude Code" : video.category === "ai-tools" ? "AI Tools" : "Engineering"}</span>
              <span>Tutorial</span>
            </div>
            <h3>{video.title}</h3>
            <p>{video.description}</p>
            <span class="more">
              Watch
              <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </span>
          </a>
        ))}
      </div>

