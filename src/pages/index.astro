---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import CommonCTA from "../components/CommonCTA.astro";
import Chatwoot from "../components/chatwoot.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import "../styles/global.css";
import { featuredVideos } from "../data/videos";
import { builds } from "../data/builds";
import { events } from "../data/events";

import { getCollection } from "astro:content";
const caseStudies = (await getCollection("caseStudies")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredBuilds = builds.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="bg-[#F8FAFC] mx-2">
			<div class="grid bg-white max-w-screen-xl px-4 py-8 mx-auto lg:gap-8 xl:gap-0 lg:py-16 lg:grid-cols-12 rounded-b-2xl">
				<div class="flex justify-center sm:w-full sm:mt-4 lg:mt-0 lg:col-span-5 lg:flex">
					<img
						src="/jitan-bg.png"
						class="w-72 sm:w-72 md:w-80 lg:w-96 h-auto px-4 mb-7"
						alt="jitan-gupta"
					/>
				</div>
				<div class="mr-auto place-self-center lg:col-span-7">
					<h1 class="hero-fade hero-fade-1 max-w-2xl mb-4 text-4xl font-bold tracking-tight leading-tight xl:text-6xl">
						I Help Teams Adopt AI —<br />Responsibly, Practically,<br />and Without the Hype.
					</h1>
					<p class="hero-fade hero-fade-2 max-w-2xl font-light text-gray-700 md:text-xl lg:text-2xl mb-6">
						10+ years building enterprise systems. Now I teach professionals how to use AI tools
						in their actual work — not toy demos, not vibes, just what works.
					</p>
					<div class="hero-fade hero-fade-3 flex flex-wrap gap-3">
						<a
							href="https://www.youtube.com/@jitangupta"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 justify-center px-5 py-3 text-base font-medium text-center bg-primary-600 hover:bg-primary-700 text-white rounded-lg transition"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
							Watch on YouTube
						</a>
						<a
							href="/about"
							class="inline-flex items-center justify-center px-5 py-3 text-base font-medium text-center text-gray-900 border border-gray-300 rounded-lg hover:bg-gray-100 transition"
						>
							How I Can Help
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Latest from YouTube -->
		<section class="bg-[#F8FAFC] py-10 px-6">
			<div class="max-w-screen-xl mx-auto">
				<div class="fade-up">
					<h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">Latest from YouTube</h2>
					<p class="text-gray-600 mb-8">AI tools, engineering workflows, and lessons from building in production.</p>
				</div>
				<div class="grid gap-6 md:grid-cols-3 fade-up-group">
					{featuredVideos.map((video) => (
						<a
							href={video.youtubeUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden hover:border-primary-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 group"
						>
							<div class="h-48 bg-gray-100 overflow-hidden">
								<img
									src={video.thumbnail}
									alt={video.title}
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
								/>
							</div>
							<div class="p-5">
								<h3 class="font-semibold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors">{video.title}</h3>
								<p class="text-sm text-gray-600 mb-3">{video.description}</p>
								<span class="text-primary-500 font-medium text-sm">Watch →</span>
							</div>
						</a>
					))}
				</div>
				<div class="mt-8 text-center">
					<a
						href="https://www.youtube.com/@jitangupta"
						target="_blank"
						rel="noopener noreferrer"
						class="text-primary-600 font-medium hover:underline"
					>See all videos →</a>
				</div>
			</div>
		</section>

		<!-- What I'm Building -->
		<section class="bg-white py-10 px-6">
			<div class="max-w-screen-xl mx-auto">
				<h2 class="fade-up text-3xl md:text-4xl font-bold text-gray-800 mb-8">Open Source & Tools</h2>
				<div class="grid gap-6 md:grid-cols-2 fade-up-group">
					{featuredBuilds.map((build) => (
						<div class="border border-gray-200 shadow-sm rounded-2xl p-6 hover:border-primary-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200">
							<div class="flex items-start justify-between gap-3 mb-3">
								<h3 class="text-lg font-bold text-gray-900">{build.title}</h3>
								<span class={`shrink-0 text-xs font-semibold px-2 py-1 rounded-full ${
									build.status === 'live'
										? 'bg-primary-100 text-primary-700'
										: build.status === 'in-progress'
										? 'bg-primary-100 text-primary-700'
										: 'bg-gray-100 text-gray-600'
								}`}>
									{build.status === 'live' ? 'Live' : build.status === 'in-progress' ? 'In Progress' : 'Planned'}
								</span>
							</div>
							<p class="text-gray-600 text-sm mb-4">{build.description}</p>
							<div class="flex flex-wrap gap-2 mb-4">
								{build.techStack.map((tech) => (
									<span class="text-xs font-medium px-3 py-1 bg-[#F8FAFC] border border-gray-200 rounded-full text-gray-600">
										{tech}
									</span>
								))}
							</div>
							{build.githubUrl && (
								<a href={build.githubUrl} target="_blank" rel="noopener noreferrer"
									class="inline-flex items-center gap-1.5 text-xs font-medium text-gray-600 hover:text-gray-900 transition-colors">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
									View on GitHub
								</a>
							)}
						</div>
					))}
				</div>
				<div class="mt-8 text-center">
					<a href="/builds" class="text-primary-600 font-medium hover:underline">See all projects →</a>
				</div>
			</div>
		</section>

		<!-- Community & Events -->
		<section class="bg-[#F8FAFC] py-10 px-6">
			<div class="max-w-screen-xl mx-auto">
				<div class="fade-up">
					<h2 class="text-3xl md:text-4xl font-bold text-gray-800 mb-2">Community</h2>
					<p class="text-gray-600 mb-8">I teach in-person, not just on screen. Hands-on sessions where people build real things with AI.</p>
				</div>
				<div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3 fade-up-group">
					{events.map((event) => (
						<div class="bg-white border border-gray-200 shadow-sm rounded-2xl p-6 hover:border-primary-500 hover:shadow-md hover:-translate-y-0.5 transition-all duration-200 flex flex-col">
							<div class="flex items-center justify-between mb-3">
								<span class={`text-xs font-semibold px-3 py-1 rounded-full ${
									event.status === 'upcoming'
										? 'bg-primary-100 text-primary-700'
										: event.status === 'looking-for-venue'
										? 'bg-primary-100 text-primary-700'
										: 'bg-gray-100 text-gray-600'
								}`}>
									{event.statusLabel}
								</span>
							</div>
							<h3 class="text-lg font-bold text-gray-900 mb-2">{event.title}</h3>
							<p class="text-gray-600 text-sm mb-4 flex-1">{event.description}</p>
							<a href={event.link} class="inline-flex items-center text-primary-600 font-medium text-sm hover:underline">
								Learn more →
							</a>
						</div>
					))}
				</div>
				<p class="mt-6 text-sm text-gray-400 text-center">I teach AI adoption broadly. Claude is where I go deepest — so that's where the first meetup starts.</p>
			</div>
		</section>

		<!-- Case Studies -->
		<section class="bg-white py-10 px-6 text-center">
			<div class="max-w-screen-xl mx-auto rounded-2xl">
				<div class="fade-up">
					<h2 class="text-3xl md:text-5xl font-bold text-gray-700 mb-3">
						The Engineering Behind the Teaching
					</h2>
					<p class="text-lg text-gray-600 mb-10">
						Before I taught AI adoption, I spent 10 years building enterprise systems — multi-tenant migrations, identity platforms, deployment orchestration. That background is why I know when AI helps and when it doesn't.
					</p>
				</div>
				<div class="grid md:grid-cols-3 gap-6 fade-up-group">
					{
						caseStudies.map((caseStudy) =>
							caseStudy.data.draft == true ? null : (
								<a href={`/case-studies/${caseStudy.id}`}>
									<div class="bg-white rounded-2xl border-3 border-gray-300 shadow-sm overflow-hidden transition-all duration-200 hover:shadow-lg hover:-translate-y-1">
										<img
											src={caseStudy.data.heroImage}
											alt={caseStudy.data.title}
											class="w-full h-48 object-cover"
										/>
										<div class="p-6 text-left">
											<h3 class="text-xl font-semibold text-gray-700">
												{caseStudy.data.pageTitle}
											</h3>
											{caseStudy.data.aiBridge && (
												<p class="mt-2 text-sm text-gray-500 italic">{caseStudy.data.aiBridge}</p>
											)}
											<span class="inline-block mt-4 text-primary-500 font-semibold hover:underline">
												View Case Study →
											</span>
										</div>
									</div>
								</a>
							),
						)
					}
				</div>
			</div>
		</section>

		<!-- CommonCTA -->
		<CommonCTA />

		<Footer />
		<script
			is:inline
			src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"
		></script>
		<script is:inline>
			(function () {
				var obs = new IntersectionObserver(function (entries) {
					entries.forEach(function (e) {
						if (e.isIntersecting) {
							e.target.classList.add('visible');
							obs.unobserve(e.target);
						}
					});
				}, { threshold: 0.12 });
				function init() {
					document.querySelectorAll('.fade-up, .fade-up-group').forEach(function (el) {
						obs.observe(el);
					});
				}
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', init);
				} else {
					init();
				}
			})();
		</script>
		<Chatwoot />
		<!-- Yandex.Metrika counter -->
		{import.meta.env.MODE === "production" &&
		<script is:inline>
			(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
			m[i].l=1*new Date();
			for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
			k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
			(window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
			ym(100451952, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true });
		</script>
		<noscript><div><img src="https://mc.yandex.ru/watch/100451952" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
		}
		<!-- /Yandex.Metrika counter -->
	</body>
</html>
