---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import CommonCTA from "../components/CommonCTA.astro";
import Chatwoot from "../components/chatwoot.astro";
import WebSiteSchema from "../components/schema/WebSiteSchema.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import "../styles/global.css";
import { featuredVideos } from "../data/videos";
import { builds } from "../data/builds";
import { events } from "../data/events";

import { getCollection } from "astro:content";
const caseStudies = (await getCollection("caseStudies")).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredBuilds = builds.slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<WebSiteSchema />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="bg-[#F8FAFC] mx-2">
			<div class="hero-grid bg-white max-w-screen-xl px-6 py-10 mx-auto lg:gap-12 lg:py-20 lg:grid-cols-12 rounded-b-2xl relative overflow-hidden">
				<!-- Subtle dot-grid watermark -->
				<div class="dot-grid" aria-hidden="true"></div>

				<!-- Photo: first in DOM. Top on mobile, left col on desktop (natural grid order). -->
				<div class="flex items-end justify-center lg:col-span-5 relative z-10 mb-4 lg:mb-0">
					<img
						src="/jitan-bg.png"
						class="w-56 sm:w-72 lg:w-full lg:max-w-[460px] h-auto object-contain"
						alt="Jitan Gupta"
					/>
				</div>

				<!-- Text: second in DOM. Below photo on mobile, right col on desktop. -->
				<div class="mr-auto place-self-center lg:col-span-7 relative z-10">
					<p class="section-label mb-4 hero-fade hero-fade-1">AI Adoption Practitioner · Mumbai</p>
					<h1 class="hero-fade hero-fade-2 max-w-2xl mb-5 text-4xl font-bold xl:text-6xl">
						AI adoption that sticks.<br />Built around Claude Code, MCP, and agents.
					</h1>
					<p class="hero-fade hero-fade-3 max-w-xl font-light text-gray-600 md:text-xl lg:text-2xl mb-8 leading-relaxed">
						I'm a Mumbai-based AI adoption practitioner. I help engineering teams and non-technical professionals put AI into real daily work, with deep specialization in Claude Code, the Model Context Protocol, and agentic workflows.
					</p>
					<div class="hero-fade hero-fade-3 flex flex-wrap gap-3 mb-10">
						<a
							href="https://www.youtube.com/@jitangupta"
							target="_blank"
							rel="noopener noreferrer"
							class="inline-flex items-center gap-2 justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition"
						>
							<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
							Watch on YouTube
						</a>
						<a
							href="/builds"
							class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-gray-800 border border-gray-300 rounded-lg hover:bg-gray-50 hover:border-gray-400 transition"
						>
							See What I've Built
						</a>
					</div>
					<!-- Credential stats -->
					<div class="hero-fade hero-fade-3 flex flex-wrap gap-8 pt-8 border-t border-gray-100">
						<div>
							<p class="text-2xl font-bold text-gray-900">10+</p>
							<p class="text-xs text-gray-500 uppercase tracking-wide font-medium mt-0.5">Years engineering</p>
						</div>
						<div>
							<p class="text-2xl font-bold text-gray-900">100+</p>
							<p class="text-xs text-gray-500 uppercase tracking-wide font-medium mt-0.5">Enterprise tenants migrated</p>
						</div>
						<div>
							<p class="text-2xl font-bold text-gray-900">5</p>
							<p class="text-xs text-gray-500 uppercase tracking-wide font-medium mt-0.5">Products built from scratch</p>
						</div>
					</div>
				</div>
			</div>
		</section>

		<!-- Latest from YouTube -->
		<section class="bg-[#F8FAFC] py-16 px-6">
			<div class="max-w-screen-xl mx-auto">
				<div class="fade-up mb-10">
					<p class="section-label mb-3">Content</p>
					<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Latest from YouTube</h2>
					<p class="text-gray-500 max-w-lg">AI tools, engineering workflows, and lessons from building in production. Videos in Hinglish 🇮🇳</p>
				</div>
				<div class="grid gap-6 md:grid-cols-3 fade-up-group">
					{featuredVideos.map((video) => (
						<a
							href={video.youtubeUrl}
							target="_blank"
							rel="noopener noreferrer"
							class="bg-white rounded-xl border border-gray-200 overflow-hidden hover:border-primary-400 hover:shadow-xl hover:-translate-y-1.5 transition-all duration-250 group flex flex-col"
						>
							<div class="h-52 bg-gray-100 overflow-hidden flex-shrink-0">
								<img
									src={video.thumbnail}
									alt={video.title}
									class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-400"
								/>
							</div>
							<div class="p-5 flex flex-col flex-1">
								<h3 class="font-semibold text-gray-900 mb-2 text-base group-hover:text-primary-600 transition-colors leading-snug">{video.title}</h3>
								<p class="text-sm text-gray-500 mb-4 flex-1 leading-relaxed line-clamp-3">{video.description}</p>
								<span class="inline-flex items-center gap-1 text-primary-600 font-semibold text-sm group-hover:gap-2 transition-all">
									Watch
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
								</span>
							</div>
						</a>
					))}
				</div>
				<div class="mt-10 text-center">
					<a
						href="https://www.youtube.com/@jitangupta"
						target="_blank"
						rel="noopener noreferrer"
						class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors"
					>
						See all videos
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</div>
		</section>

		<!-- What I'm Building -->
		<section class="bg-white py-16 px-6">
			<div class="max-w-screen-xl mx-auto">
				<div class="fade-up mb-10">
					<p class="section-label mb-3">Open Source</p>
					<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">What I'm Building</h2>
					<p class="text-gray-500 max-w-lg">Tools I built to solve real problems. All open source, built in public.</p>
				</div>
				<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3 fade-up-group">
					{featuredBuilds.map((build) => (
						<div class="bg-primary-50 border border-primary-100 rounded-xl p-6 hover:border-primary-300 hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
							<div class="flex items-start justify-between gap-3 mb-3">
								<h3 class="text-base font-bold text-gray-900">{build.title}</h3>
								<span class={`shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full ${
									build.status === 'live'
										? 'bg-primary-600 text-white'
										: build.status === 'in-progress'
										? 'bg-primary-200 text-primary-800'
										: 'bg-gray-100 text-gray-600'
								}`}>
									{build.status === 'live' ? 'Live' : build.status === 'in-progress' ? 'In Progress' : 'Planned'}
								</span>
							</div>
							<p class="text-gray-600 text-sm mb-4 flex-1 leading-relaxed">{build.description}</p>
							<div class="flex flex-wrap gap-1.5 mb-5">
								{build.techStack.map((tech) => (
									<span class="text-xs font-medium px-2.5 py-1 bg-white border border-primary-200 rounded-full text-primary-700">
										{tech}
									</span>
								))}
							</div>
							{build.githubUrl && (
								<a href={build.githubUrl} target="_blank" rel="noopener noreferrer"
									class="inline-flex items-center gap-1.5 text-xs font-semibold text-primary-700 hover:text-primary-900 transition-colors mt-auto">
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
									View on GitHub
								</a>
							)}
						</div>
					))}
				</div>
				<div class="mt-10 text-center">
					<a href="/builds" class="inline-flex items-center gap-2 text-primary-600 font-semibold hover:text-primary-700 transition-colors">
						See all projects
						<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
					</a>
				</div>
			</div>
		</section>

		<!-- Community & Events -->
		<section class="bg-[#F8FAFC] py-16 px-6">
			<div class="max-w-screen-xl mx-auto">
				<div class="fade-up mb-10">
					<p class="section-label mb-3">In Person</p>
					<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">Community</h2>
					<p class="text-gray-500 max-w-lg">I teach in-person, not just on screen. Hands-on sessions where people build real things with AI.</p>
				</div>
				<div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3 fade-up-group">
					{events.map((event) => (
						<div class="bg-white border border-gray-200 rounded-xl p-6 hover:border-primary-400 hover:shadow-lg hover:-translate-y-1 transition-all duration-200 flex flex-col">
							<div class="mb-4">
								<span class={`text-xs font-semibold px-3 py-1 rounded-full ${
									event.status === 'upcoming'
										? 'bg-primary-600 text-white'
										: event.status === 'looking-for-venue'
										? 'bg-primary-100 text-primary-700'
										: 'bg-gray-100 text-gray-600'
								}`}>
									{event.statusLabel}
								</span>
							</div>
							<h3 class="text-base font-bold text-gray-900 mb-2">{event.title}</h3>
							<p class="text-gray-500 text-sm mb-5 flex-1 leading-relaxed">{event.description}</p>
							<a href={event.link} class="inline-flex items-center gap-1 text-primary-600 font-semibold text-sm hover:gap-2 transition-all">
								Learn more
								<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
							</a>
						</div>
					))}
				</div>
				<p class="mt-8 text-xs text-gray-400 text-center">I teach AI adoption broadly. Claude is where I go deepest, so that's where the first meetup starts.</p>
			</div>
		</section>

		<!-- Case Studies -->
		<section class="bg-white py-16 px-6">
			<div class="max-w-screen-xl mx-auto">
				<div class="fade-up mb-10 text-center">
					<p class="section-label mb-3 flex justify-center">Engineering Background</p>
					<h2 class="text-3xl md:text-5xl font-bold text-gray-900 mb-4">
						The Engineering Behind the Teaching
					</h2>
					<p class="text-lg text-gray-500 max-w-2xl mx-auto">
						Before I taught AI adoption, I spent 10 years building enterprise systems. That background is why I know when AI helps and when it doesn't.
					</p>
				</div>
				<div class="grid md:grid-cols-3 gap-6 fade-up-group">
					{
						caseStudies.map((caseStudy) =>
							caseStudy.data.draft == true ? null : (
								<a href={`/case-studies/${caseStudy.id}`} class="group">
									<div class="bg-white rounded-xl border border-gray-200 overflow-hidden transition-all duration-200 hover:border-primary-400 hover:shadow-xl hover:-translate-y-1.5 flex flex-col h-full">
										<div class="overflow-hidden">
											<img
												src={caseStudy.data.heroImage}
												alt={caseStudy.data.title}
												class="w-full h-48 object-cover group-hover:scale-105 transition-transform duration-400"
											/>
										</div>
										<div class="p-6 flex flex-col flex-1">
											<h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-700 transition-colors">
												{caseStudy.data.pageTitle}
											</h3>
											{caseStudy.data.aiBridge && (
												<p class="mt-1 text-sm text-gray-500 italic flex-1">{caseStudy.data.aiBridge}</p>
											)}
											<span class="inline-flex items-center gap-1 mt-5 text-primary-600 font-semibold text-sm group-hover:gap-2 transition-all">
												View case study
												<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
											</span>
										</div>
									</div>
								</a>
							),
						)
					}
				</div>
			</div>
		</section>

		<!-- CommonCTA -->
		<CommonCTA />

		<Footer />
		<script
			is:inline
			src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"
		></script>
		<script is:inline>
			(function () {
				var obs = new IntersectionObserver(function (entries) {
					entries.forEach(function (e) {
						if (e.isIntersecting) {
							e.target.classList.add('visible');
							obs.unobserve(e.target);
						}
					});
				}, { threshold: 0.12 });
				function init() {
					document.querySelectorAll('.fade-up, .fade-up-group').forEach(function (el) {
						obs.observe(el);
					});
				}
				if (document.readyState === 'loading') {
					document.addEventListener('DOMContentLoaded', init);
				} else {
					init();
				}
			})();
		</script>
		<Chatwoot />
		<!-- Yandex.Metrika counter -->
		{import.meta.env.MODE === "production" &&
		<script is:inline>
			(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
			m[i].l=1*new Date();
			for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
			k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
			(window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
			ym(100451952, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true });
		</script>
		<noscript><div><img src="https://mc.yandex.ru/watch/100451952" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
		}
		<!-- /Yandex.Metrika counter -->
	</body>
</html>
