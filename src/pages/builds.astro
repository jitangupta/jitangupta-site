---
import Layout from '../layouts/Layout.astro';
import { builds } from '../data/builds';

const title = "Builds — Things I've Built | Jitan Gupta";
const description = "Open source tools, apps, and projects I'm working on. Some finished, some in progress. Everything is on GitHub.";

const statusLabel: Record<string, string> = {
  live: 'Live',
  'in-progress': 'In Progress',
  planned: 'Planned',
};

const statusColor: Record<string, string> = {
  live: 'bg-primary-100 text-primary-700',
  'in-progress': 'bg-accent-100 text-accent-700',
  planned: 'bg-gray-100 text-gray-600',
};
---
<Layout title={title} description={description}>
  <section class="bg-[#F8FAFC] mx-2">
    <div class="bg-white max-w-screen-xl mx-auto px-6 py-12 rounded-b-2xl">

      <!-- Hero -->
      <div class="max-w-2xl mb-12">
        <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4">Things I've Built</h1>
        <p class="text-lg text-gray-700">
          I believe in building in public. These are tools, apps, and projects I'm working on — some finished, some in progress. Code is on GitHub.
        </p>
      </div>

      <!-- Project Cards -->
      <div class="grid gap-8 md:grid-cols-2">
        {builds.map((build) => (
          <div class="border border-gray-200 rounded-2xl p-6 flex flex-col hover:border-accent-500 transition-colors">

            {build.image && (
              <img src={build.image} alt={build.title} class="w-full h-48 object-cover rounded-xl mb-5" />
            )}

            <div class="flex items-start justify-between gap-3 mb-3">
              <h2 class="text-xl font-bold text-gray-900">{build.title}</h2>
              <span class={`shrink-0 text-xs font-semibold px-3 py-1 rounded-full ${statusColor[build.status]}`}>
                {statusLabel[build.status]}
              </span>
            </div>

            <p class="text-gray-700 mb-5 flex-1">{build.description}</p>

            <!-- Tech Stack -->
            <div class="flex flex-wrap gap-2 mb-5">
              {build.techStack.map((tech) => (
                <span class="text-xs font-medium px-3 py-1 bg-[#F8FAFC] border border-gray-200 rounded-full text-gray-600">
                  {tech}
                </span>
              ))}
            </div>

            <!-- Links -->
            <div class="flex gap-3 flex-wrap">
              {build.githubUrl && (
                <a href={build.githubUrl} target="_blank" rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-medium text-gray-700 border border-gray-300 px-4 py-2 rounded-lg hover:bg-gray-50 transition">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
                  GitHub
                </a>
              )}
              {build.liveUrl && (
                <a href={build.liveUrl} target="_blank" rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-medium text-white bg-primary-600 hover:bg-primary-700 px-4 py-2 rounded-lg transition">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  Live Site
                </a>
              )}
              {build.youtubeUrl && (
                <a href={build.youtubeUrl} target="_blank" rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 text-sm font-medium text-white bg-accent-600 hover:bg-accent-700 px-4 py-2 rounded-lg transition">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2.5 17a24.12 24.12 0 0 1 0-10 2 2 0 0 1 1.4-1.4 49.56 49.56 0 0 1 16.2 0A2 2 0 0 1 21.5 7a24.12 24.12 0 0 1 0 10 2 2 0 0 1-1.4 1.4 49.55 49.55 0 0 1-16.2 0A2 2 0 0 1 2.5 17"/><path d="m10 15 5-3-5-3z"/></svg>
                  Watch Build
                </a>
              )}
            </div>

          </div>
        ))}
      </div>

      <!-- Footer CTA -->
      <div class="mt-12 text-center">
        <p class="text-gray-600 mb-4">More projects coming. Follow along on GitHub.</p>
        <a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-white bg-primary-600 hover:bg-primary-700 px-6 py-3 rounded-lg transition font-medium">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          Follow on GitHub
        </a>
      </div>

    </div>
  </section>
</Layout>
