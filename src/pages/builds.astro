---
import BaseHead from "../components/BaseHead.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { builds } from "../data/builds";

const title = "Builds — Jitan Gupta";
const description = "Open source tools and projects, built in production, documented in public.";

const statusLabel: Record<string, string> = {
  live: "Live",
  "in-progress": "In progress",
  planned: "Planned",
};

const buildDates: Record<string, string> = {
  "cb-mcp-server": "2025 → ongoing",
  "PromptMate": "2024 → 2025",
  "Cowork Boilerplate": "2025",
  "File Safety Guard": "2025",
  "Content Board": "2024 → ongoing",
  "jitangupta.com": "2024 → ongoing",
};
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <style>
      :root,
      html[data-theme="paper"] {
        --bg: oklch(0.985 0.008 80);
        --bg-tint: oklch(0.965 0.012 80);
        --ink: oklch(0.18 0.012 60);
        --ink-2: oklch(0.30 0.012 60);
        --muted: oklch(0.50 0.012 60);
        --hairline: oklch(0.88 0.010 80);
        --hairline-strong: oklch(0.78 0.012 80);
        --accent: oklch(0.62 0.20 32);
        --accent-ink: oklch(0.98 0.005 80);
        --selection: oklch(0.85 0.14 32 / 0.45);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Geist", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: "ss01","ss02","cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
      }

      ::selection { background: var(--selection); }
      body { min-height: 100vh; overflow-x: hidden; }

      a {
        color: inherit;
        text-decoration: none;
        text-underline-offset: 3px;
        transition: color 150ms ease, opacity 150ms ease;
      }
      a:hover { color: var(--accent); }

      p { margin: 0; }
      ul, ol { margin: 0; padding: 0; list-style: none; }
      img { max-width: 100%; display: block; }

      .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
      @media (max-width: 540px) { .wrap { padding: 0 20px; } }

      .mono {
        font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;
        font-feature-settings: "ss01","ss02";
      }

      .eyebrow {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .eyebrow::before {
        content: "";
        width: 18px;
        height: 1px;
        background: var(--hairline-strong);
      }

      h1, h2, h3, h4 { margin: 0; font-weight: 500; letter-spacing: -0.02em; }

      .display {
        font-size: clamp(48px, 7.2vw, 104px);
        line-height: 0.98;
        letter-spacing: -0.035em;
        font-weight: 500;
        text-wrap: balance;
      }

      .h2 {
        font-size: clamp(32px, 4.4vw, 56px);
        line-height: 1.02;
        letter-spacing: -0.028em;
        text-wrap: balance;
        font-weight: 500;
      }

      .lede {
        font-size: clamp(18px, 1.4vw, 22px);
        line-height: 1.5;
        color: var(--ink-2);
        text-wrap: pretty;
        max-width: 62ch;
      }

      .body { font-size: 17px; line-height: 1.6; color: var(--ink-2); text-wrap: pretty; }
      .small { font-size: 14px; color: var(--muted); }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        background: color-mix(in oklch, var(--bg) 88%, transparent);
        backdrop-filter: saturate(140%) blur(12px);
        -webkit-backdrop-filter: saturate(140%) blur(12px);
        border-bottom: 1px solid color-mix(in oklch, var(--hairline) 60%, transparent);
      }
      .site-header .row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 64px;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
        letter-spacing: -0.01em;
      }
      .brand .dot {
        width: 9px; height: 9px;
        background: var(--accent);
        border-radius: 50%;
        display: inline-block;
      }
      .nav { display: flex; align-items: center; gap: 28px; font-size: 14.5px; }
      .nav a { color: var(--ink-2); }
      .nav a.active { color: var(--ink); }
      .nav a:hover { color: var(--ink); }
      @media (max-width: 720px) {
        .nav { gap: 18px; font-size: 13.5px; }
        .nav a.nav-hide-sm { display: none; }
      }

      section { padding: 96px 0; position: relative; }
      section.tight { padding: 64px 0; }
      @media (max-width: 720px) { section { padding: 64px 0; } }

      .tag {
        display: inline-block;
        padding: 4px 9px;
        border: 1px solid var(--hairline);
        border-radius: 999px;
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 11.5px;
        color: var(--muted);
        letter-spacing: 0.02em;
      }

      .status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 11.5px;
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .status::before {
        content: "";
        width: 7px; height: 7px;
        background: var(--accent);
        border-radius: 50%;
        box-shadow: 0 0 0 3px color-mix(in oklch, var(--accent) 18%, transparent);
      }
      .status.muted::before { background: var(--muted); box-shadow: none; }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border: 1px solid var(--hairline-strong);
        border-radius: 999px;
        font-size: 14.5px;
        font-weight: 500;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
      }
      .btn:hover { background: var(--bg-tint); color: var(--ink); border-color: var(--ink); }
      .btn.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .btn .arrow { transition: transform 200ms ease; }
      .btn:hover .arrow { transform: translateX(3px); }

      .site-footer { border-top: 1px solid var(--hairline); padding: 56px 0 40px; }
      .site-footer .grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 56px;
      }
      .site-footer h4 {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
        font-weight: 500;
      }
      .site-footer ul li { padding: 4px 0; }
      .site-footer ul li a { color: var(--ink-2); font-size: 14.5px; }
      .site-footer .meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--muted);
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
      }
      @media (max-width: 820px) { .site-footer .grid { grid-template-columns: 1fr 1fr; } }

      .reveal {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 600ms cubic-bezier(.2,.7,.2,1), transform 600ms cubic-bezier(.2,.7,.2,1);
      }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
      }

      .arrow { width: 14px; height: 14px; display: inline-block; vertical-align: -1px; }

      /* ===== PAGE-SPECIFIC ===== */

      .page-hero { padding: clamp(64px, 8vh, 110px) 0 56px; }
      .page-hero h1 { margin-bottom: 16px; }
      .page-hero .meta-row {
        display: flex; gap: 24px; flex-wrap: wrap;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .page-hero .meta-row b { color: var(--ink); font-weight: 500; }

      .build-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background: var(--hairline);
        border: 1px solid var(--hairline);
      }
      .build-card {
        background: var(--bg);
        padding: 36px;
        display: flex;
        flex-direction: column;
        gap: 16px;
        transition: background 200ms ease;
        position: relative;
      }
      .build-card:hover { background: var(--bg-tint); }
      .build-card .top {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
      }
      .build-card h3 {
        font-size: clamp(22px, 2.2vw, 28px);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.1;
      }
      .build-card .body { font-size: 15.5px; line-height: 1.6; max-width: 60ch; }
      .build-card .tag-row { display: flex; flex-wrap: wrap; gap: 6px; margin-top: auto; padding-top: 12px; }
      .build-card .footer-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid var(--hairline);
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .build-card .footer-row .open {
        color: var(--ink);
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .build-card:hover .footer-row .open { color: var(--accent); }
      @media (max-width: 820px) { .build-grid { grid-template-columns: 1fr; } }

      .filter-row {
        display: flex;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
        padding: 16px 0;
        border-bottom: 1px solid var(--hairline);
        margin-bottom: 32px;
      }
      .filter-row .label {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-right: 8px;
      }
      .filter-row .pill {
        padding: 6px 12px;
        border: 1px solid var(--hairline);
        border-radius: 999px;
        font-size: 13px;
        color: var(--ink-2);
        background: var(--bg);
        cursor: pointer;
        font-family: inherit;
      }
      .filter-row .pill.on { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .filter-row .pill:hover { border-color: var(--ink); }
    </style>
  </head>

  <body>

    <SiteHeader />

    <main>

      <section class="page-hero">
        <div class="wrap reveal">
          <span class="eyebrow">Builds</span>
          <h1 class="display" style="font-size: clamp(40px, 5.4vw, 76px);">
            Things I built because I needed them.
          </h1>
          <p class="lede" style="margin-top: 24px;">
            Open source, in production, documented end-to-end. Every project on this page started as a real problem inside my own work — then got shaped into something other engineers can pick up and run.
          </p>
          <div class="meta-row">
            <span><b>{builds.filter(b => b.status === "live").length}</b> Live</span>
            <span><b>{builds.filter(b => b.status === "in-progress").length}</b> In progress</span>
            <span><b>All</b> Open source</span>
            <span>Updated weekly</span>
          </div>
        </div>
      </section>

      <section class="tight">
        <div class="wrap">
          <div class="filter-row reveal">
            <span class="label">Filter</span>
            <button class="pill on">All</button>
            <button class="pill">MCP</button>
            <button class="pill">Agents</button>
            <button class="pill">Dev tooling</button>
            <button class="pill">Browser</button>
          </div>

          <div class="build-grid">
            {builds.map((build) => {
              const href = build.githubUrl || build.liveUrl || "https://github.com/jitangupta";
              const isExternal = href.startsWith("http");
              const linkLabel = build.githubUrl ? "View on GitHub →" :
                                build.liveUrl   ? "View live →" :
                                                  "Browse GitHub →";
              const dateStr = buildDates[build.title] || "2025";
              return (
                <a class="build-card reveal"
                   href={href}
                   target={isExternal ? "_blank" : undefined}
                   rel={isExternal ? "noopener noreferrer" : undefined}>
                  <div class="top">
                    <h3>{build.title}</h3>
                    <span class={`status${build.status !== "live" ? " muted" : ""}`}>
                      {statusLabel[build.status]}
                    </span>
                  </div>
                  <p class="body">{build.description}</p>
                  <div class="tag-row">
                    {build.techStack.slice(0, 4).map((tech) => (
                      <span class="tag">{tech}</span>
                    ))}
                  </div>
                  <div class="footer-row">
                    <span>{dateStr}</span>
                    <span class="open">{linkLabel}</span>
                  </div>
                </a>
              );
            })}

            <a class="build-card reveal" href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer">
              <div class="top">
                <h3>More on GitHub</h3>
                <span class="status muted">Misc</span>
              </div>
              <p class="body">
                Smaller experiments, demos, and one-off scripts live on my GitHub. Worth a look if you want to see what didn't graduate into a full project yet — or what the next one might come out of.
              </p>
              <div class="tag-row">
                <span class="tag">Experiments</span>
                <span class="tag">Scripts</span>
                <span class="tag">Demos</span>
              </div>
              <div class="footer-row">
                <span>Various</span>
                <span class="open">Browse GitHub →</span>
              </div>
            </a>
          </div>
        </div>
      </section>

      <section class="tight">
        <div class="wrap">
          <div style="display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: end; padding: 56px 0; border-top: 1px solid var(--hairline); border-bottom: 1px solid var(--hairline);">
            <div>
              <span class="eyebrow">Patterns</span>
              <h2 class="h2" style="margin-top: 14px;">When something repeats across builds, it becomes a framework.</h2>
            </div>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <a class="btn primary" href="/frameworks">
                See the frameworks
                <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="grid">
          <div>
            <a class="brand" href="/"><img src="/JitanGupta%20Logo.png" alt="Jitan Gupta" style="height:44px;width:auto;display:block;mix-blend-mode:multiply;" /></a>
            <p class="body" style="font-size:14.5px; max-width: 42ch; margin-top: 12px;">
              Engineer building AI infrastructure and developer tooling, in public. Mumbai, India.
            </p>
          </div>
          <div>
            <h4>Sitemap</h4>
            <ul>
              <li><a href="/builds">Builds</a></li>
              <li><a href="/frameworks">Frameworks</a></li>
              <li><a href="/case-studies">Case studies</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4>Elsewhere</h4>
            <ul>
              <li><a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
              <li><a href="https://www.youtube.com/@jitangupta" target="_blank" rel="noopener noreferrer">YouTube ↗</a></li>
              <li><a href="https://www.linkedin.com/in/jitangupta/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a></li>
            </ul>
          </div>
          <div>
            <h4>Speak with me</h4>
            <ul>
              <li><a href="/contact">Speaking & podcasts</a></li>
              <li><a href="/contact">Collaboration</a></li>
              <li><a href="/contact">Anything serious</a></li>
            </ul>
          </div>
        </div>
        <div class="meta">
          <span>© 2026 Jitan Gupta. All rights reserved.</span>
          <span class="mono">Built in public · Mumbai → web</span>
        </div>
      </div>
    </footer>

    <script>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight) { el.classList.add('in'); }
        else { io.observe(el); }
      });
      setTimeout(() => {
        document.querySelectorAll('.reveal:not(.in)').forEach((el) => el.classList.add('in'));
      }, 1500);

      document.querySelectorAll('.filter-row .pill').forEach((p) => {
        p.addEventListener('click', () => {
          document.querySelectorAll('.filter-row .pill').forEach((q) => q.classList.remove('on'));
          p.classList.add('on');
        });
      });
    </script>

  </body>
</html>
