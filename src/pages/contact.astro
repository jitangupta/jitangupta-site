---
import Layout from '../layouts/Layout.astro';
const title = "Contact Jitan Gupta · AI Adoption Practitioner in Mumbai";
const description = "Get in touch about Claude Code training, MCP work, agentic workflow setups, speaking, or open-source collaboration. Based in Mumbai, available globally.";
---
<Layout	title={title} description={description}>
    <section class="bg-[#F8FAFC] mx-2">
        <div class="bg-white max-w-screen-xl mx-auto px-5 py-5 md:px-15 md:py-10 rounded-b-2xl">
            <!-- Title -->
            <h1 class="text-3xl md:text-5xl lg:text-6xl mt-5 md:mt-8 mb-2 font-bold" style="line-height: 1.2;">👋 Let's Connect <br><span class="text-2xl md:text-4xl">Collaboration & Opportunities</span></h1>

            <!-- Main Content -->
            <p class="text-lg text-gray-700 mb-4">Whether you want to collaborate, have me speak at your event, or just say hello, I'd love to hear from you. I'm based in Mumbai and work with teams across India and globally.</p>

            <div class="my-6">
                <p class="text-lg font-semibold text-gray-900 mb-3">I'm open to:</p>
                <ul class="list-none space-y-2 text-gray-700 ml-4">
                    <li class="flex items-start">
                        <span class="text-primary-500 mr-3">✓</span>
                        <span>Speaking at events or podcasts</span>
                    </li>
                    <li class="flex items-start">
                        <span class="text-primary-500 mr-3">✓</span>
                        <span>Open source collaborations</span>
                    </li>
                    <li class="flex items-start">
                        <span class="text-primary-500 mr-3">✓</span>
                        <span>Teaching engineering teams</span>
                    </li>
                </ul>
            </div>

            <!-- Contact Form -->
            <form action="https://formspree.io/f/mvzbolpn" method="POST" class="my-8 max-w-2xl">
                <div class="space-y-4">
                    <div>
                        <label for="name" class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
                        <input type="text" id="name" name="name" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                    </div>

                    <div>
                        <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email *</label>
                        <input type="email" id="email" name="email" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent">
                    </div>

                    <div>
                        <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message *</label>
                        <textarea id="message" name="message" rows="5" required
                            class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-transparent"></textarea>
                    </div>

                    <button type="submit"
                        class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition">
                        Send Message
                    </button>
                </div>
            </form>

            <!-- Alternative Contact Methods -->
            <div class="my-8 pt-8 border-t border-gray-200">
                <p class="text-lg font-semibold text-gray-900 mb-3">Or connect via socials:</p>
                <ul class="list-none space-y-2">
                    <li class="text-gray-700">
                        💼 <a href="https://www.linkedin.com/in/jitangupta/" target="_blank" class="text-primary-600 hover:underline">LinkedIn</a>
                    </li>
                    <li class="text-gray-700">
                        🎥 <a href="https://www.youtube.com/@jitangupta" target="_blank" class="text-primary-600 hover:underline">YouTube</a>
                    </li>
                    <li class="text-gray-700">
                        💻 <a href="https://github.com/jitangupta" target="_blank" class="text-primary-600 hover:underline">GitHub</a>
                    </li>
                </ul>
            </div>

            <p class="text-gray-700">Looking forward to connecting! 🚀</p>
        </div>
    </section>
</Layout>
