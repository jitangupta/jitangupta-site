  <!-- Stack -->
  <section class="bg-white py-14 px-6">
    <div class="max-w-screen-xl mx-auto fade-up">
      <div class="mb-10 max-w-2xl">
        <p class="section-label mb-3">Stack</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">Why these specific tools</h2>
        <p class="mt-3 text-gray-500 text-sm">Every choice is documented in the series. The short version:</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 max-w-4xl fade-up-group">
        {[
          { layer: "Web + webhook", tech: "Next.js on Azure App Service", reason: "One deploy handles the webhook receiver and the dashboard UI. App Router keeps both concerns in the same codebase without the overhead of two services." },
          { layer: "Queue", tech: "Azure Service Bus", reason: "The webhook must return 200 OK in under a second. Claude takes 15–30 seconds. A queue decouples the two. Service Bus gives dead-letter queues and retries out of the box." },
          { layer: "Worker", tech: "Azure Functions", reason: "Queue-triggered. Scales to zero when idle, runs on demand. The AI review work is exactly the kind of job serverless is designed for." },
          { layer: "Database", tech: "Neon Postgres + Prisma", reason: "Serverless Postgres that branches like Git. Three tables: User, Installation, Review. Shared by both the web app and the worker." },
          { layer: "AI reviewer", tech: "Anthropic Claude", reason: "Reads the unified diff, returns structured JSON: risk score (1–10), summary paragraph, and an array of specific findings. Prompt design is documented in Episode 4." },
          { layer: "Auth", tech: "GitHub App + OAuth", reason: "Two separate auth flows: the App installation grants repo permissions for webhook events, OAuth lets users sign into the dashboard." },
        ].map((item) => (
          <div class="bg-[#F8FAFC] border border-gray-200 rounded-xl p-6 hover:border-primary-300 hover:shadow-md hover:bg-white transition-all duration-200">
            <p class="text-xs font-semibold uppercase tracking-wider text-primary-600 mb-2">{item.layer}</p>
            <h3 class="text-base font-bold text-gray-900 mb-2">{item.tech}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{item.reason}</p>
          </div>
        ))}
