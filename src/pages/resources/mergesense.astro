---
import Layout from '../../layouts/Layout.astro';

const title = "MergeSense · AI PR reviewer for teams moving fast with AI-generated code";
const description = "A GitHub App that reviews pull requests automatically. Reads the diff, scores merge risk, and posts a plain-language comment — before you hit merge. Built publicly as a video series.";

const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="18" r="3"/><circle cx="6" cy="6" r="3"/><path d="M6 21V9a9 9 0 0 0 9 9"/></svg>`,
    heading: "Automatic on every PR",
    body: "Install once on your org or repo. Every pull request triggers a review — no commands, no prompts from the developer. MergeSense just shows up.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
    heading: "Risk score + plain-language summary",
    body: "Not just linting. Claude reads the diff and returns a risk score, a one-paragraph summary, and specific concerns the reviewer should check.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M9 3v18"/><path d="m16 15-3-3 3-3"/></svg>`,
    heading: "Queue-backed, never blocks the webhook",
    body: "The webhook returns 200 OK in under a second. A Service Bus queue and Azure Function handle the slow AI work async. Your CI doesn't wait.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/></svg>`,
    heading: "Review history dashboard",
    body: "Sign in with GitHub OAuth and see every review MergeSense has posted across your org. Filter by repo, status, and risk level.",
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>`,
    heading: "Open source, built publicly",
    body: "Every architectural decision, every tradeoff, documented and recorded. The series shows how a real webhook-driven SaaS is designed and shipped.",
  },
];

const episodes = [
  { status: "Published", statusColor: "accent", title: "Episode 1 — Architecture", body: "What MergeSense does, why the queue matters, and how the three Azure services fit together. Full architecture walk-through with diagrams." },
  { status: "Published", statusColor: "accent", title: "Episode 2 — GitHub App setup", body: "Registering the GitHub App, configuring permissions and webhooks, local testing with a dev tunnel." },
  { status: "Upcoming", statusColor: "primary", title: "Episode 3 — Webhook to queue", body: "Verifying the webhook signature, writing the review record, and pushing the job to Service Bus." },
  { status: "Upcoming", statusColor: "primary", title: "Episode 4 — AI review worker", body: "The Azure Function that pulls the job, fetches the diff, calls Claude, and posts the comment back." },
  { status: "Upcoming", statusColor: "primary", title: "Episode 5 — Dashboard", body: "Next.js App Router, GitHub OAuth, and the Neon Postgres schema behind the review history view." },
  { status: "Upcoming", statusColor: "primary", title: "Episode 6 — Deploy + evaluate", body: "Azure App Service + Function App deployment via GitHub Actions, and an honest look at what Claude catches and misses." },
];

const statusStyles: Record<string, string> = {
  primary: "text-primary-700 bg-primary-50 border-primary-200",
  accent:  "text-accent-700 bg-accent-50 border-accent-200",
};
---

<Layout title={title} description={description}>

  <!-- Hero -->
  <section class="bg-[#F8FAFC] mx-2">
    <div class="bg-white max-w-screen-xl mx-auto px-8 py-14 rounded-b-2xl relative overflow-hidden">
      <div class="dot-grid" aria-hidden="true"></div>

      <!-- Decorative SVG: animated PR flow schematic -->
      <div class="absolute right-0 top-0 bottom-0 w-1/2 pointer-events-none hidden lg:flex items-center justify-end pr-12" aria-hidden="true">
        <svg width="420" height="340" viewBox="0 0 420 340" fill="none" xmlns="http://www.w3.org/2000/svg" class="mergesense-hero-svg">
          <style>
            /* PR card pulse */
            @keyframes ms-card-in { from { opacity:0; transform:translateY(12px); } to { opacity:1; transform:translateY(0); } }
            /* Arrow draw */
            @keyframes ms-dash { from { stroke-dashoffset: 120; } to { stroke-dashoffset: 0; } }
            /* Badge pop */
            @keyframes ms-pop { 0%,80% { opacity:0; transform:scale(0.6); } 100% { opacity:1; transform:scale(1); } }
            /* Processing dots */
            @keyframes ms-dot { 0%,100% { opacity:0.2; } 50% { opacity:1; } }
            /* Glow pulse */
            @keyframes ms-glow { 0%,100% { opacity:0.15; } 50% { opacity:0.35; } }

            .ms-pr-card   { animation: ms-card-in 0.5s ease both; }
            .ms-arrow-1   { stroke-dasharray: 120; stroke-dashoffset: 120; animation: ms-dash 0.6s 0.6s ease forwards; }
            .ms-arrow-2   { stroke-dasharray: 120; stroke-dashoffset: 120; animation: ms-dash 0.6s 2.4s ease forwards; }
            .ms-ai-box    { animation: ms-card-in 0.45s 1.1s ease both; opacity:0; }
            .ms-badge     { animation: ms-pop 0.4s 3.1s cubic-bezier(.34,1.56,.64,1) both; opacity:0; }
            .ms-dot-1     { animation: ms-dot 1s 1.2s ease infinite; }
            .ms-dot-2     { animation: ms-dot 1s 1.4s ease infinite; }
            .ms-dot-3     { animation: ms-dot 1s 1.6s ease infinite; }
            .ms-glow      { animation: ms-glow 2.5s 1.2s ease-in-out infinite; }
          </style>

          <!-- Glow behind AI box -->
          <ellipse class="ms-glow" cx="280" cy="170" rx="70" ry="50" fill="#477056"/>

          <!-- PR card (left) -->
          <g class="ms-pr-card">
            <rect x="20" y="90" width="170" height="160" rx="12" fill="white" stroke="#e5e7eb" stroke-width="1.5"/>
            <!-- PR header -->
            <rect x="20" y="90" width="170" height="36" rx="12" fill="#f9fafb"/>
            <rect x="20" y="114" width="170" height="12" rx="0" fill="#f9fafb"/>
            <circle cx="44" cy="108" r="8" fill="#477056" fill-opacity="0.15"/>
            <path d="M40 108h8M44 104v8" stroke="#477056" stroke-width="1.5" stroke-linecap="round"/>
            <rect x="58" y="104" width="70" height="6" rx="3" fill="#1f2937" fill-opacity="0.7"/>
            <rect x="148" y="103" width="32" height="8" rx="4" fill="#dbeafe"/>
            <text x="164" y="110" fill="#1d4ed8" font-size="6" font-weight="600" text-anchor="middle" font-family="system-ui">open</text>
            <!-- PR body lines -->
            <rect x="34" y="138" width="142" height="5" rx="2.5" fill="#9ca3af" fill-opacity="0.5"/>
            <rect x="34" y="149" width="110" height="5" rx="2.5" fill="#9ca3af" fill-opacity="0.4"/>
            <rect x="34" y="160" width="128" height="5" rx="2.5" fill="#9ca3af" fill-opacity="0.35"/>
            <!-- Diff snippet -->
            <rect x="34" y="176" width="142" height="30" rx="6" fill="#f0fdf4"/>
            <rect x="40" y="182" width="4" height="4" rx="1" fill="#16a34a"/>
            <rect x="48" y="183" width="80" height="3" rx="1.5" fill="#16a34a" fill-opacity="0.6"/>
            <rect x="40" y="190" width="4" height="4" rx="1" fill="#16a34a"/>
            <rect x="48" y="191" width="60" height="3" rx="1.5" fill="#16a34a" fill-opacity="0.5"/>
            <!-- Files changed label -->
            <rect x="34" y="216" width="55" height="18" rx="5" fill="#f3f4f6"/>
            <text x="61" y="228" fill="#6b7280" font-size="7.5" text-anchor="middle" font-family="system-ui">3 files</text>
            <rect x="96" y="216" width="65" height="18" rx="5" fill="#f3f4f6"/>
            <text x="128" y="228" fill="#6b7280" font-size="7.5" text-anchor="middle" font-family="system-ui">+84 / -12</text>
          </g>

          <!-- Arrow 1: PR card → AI box -->
          <path class="ms-arrow-1" d="M193 170 L230 170" stroke="#477056" stroke-width="2" stroke-linecap="round" marker-end="url(#ms-arr)"/>

          <!-- AI / MergeSense box -->
          <g class="ms-ai-box">
            <rect x="232" y="128" width="116" height="84" rx="12" fill="#253A33"/>
            <rect x="232" y="128" width="116" height="84" rx="12" stroke="#477056" stroke-width="1.5"/>
            <text x="290" y="152" fill="#a3c4ab" font-size="9" font-weight="700" text-anchor="middle" font-family="system-ui" letter-spacing="0.04em">MERGESENSE</text>
            <text x="290" y="166" fill="#6b9e7a" font-size="7.5" text-anchor="middle" font-family="system-ui">Reviewing diff…</text>
            <!-- Processing dots -->
            <circle class="ms-dot-1" cx="278" cy="182" r="4" fill="#477056"/>
            <circle class="ms-dot-2" cx="290" cy="182" r="4" fill="#477056"/>
            <circle class="ms-dot-3" cx="302" cy="182" r="4" fill="#477056"/>
          </g>

          <!-- Arrow 2: AI box → PR card (return) -->
          <path class="ms-arrow-2" d="M232 185 Q210 220 190 230" stroke="#477056" stroke-width="2" stroke-linecap="round" stroke-dasharray="4 3" marker-end="url(#ms-arr-ret)"/>

          <!-- Risk badge (appears after return arrow) -->
          <g class="ms-badge">
            <rect x="30" y="255" width="155" height="52" rx="10" fill="white" stroke="#477056" stroke-width="1.5"/>
            <rect x="30" y="255" width="155" height="52" rx="10" fill="#f0fdf4" fill-opacity="0.5"/>
            <rect x="40" y="264" width="50" height="16" rx="5" fill="#477056"/>
            <text x="65" y="275" fill="white" font-size="7.5" font-weight="700" text-anchor="middle" font-family="system-ui">LOW RISK</text>
            <text x="104" y="275" fill="#374151" font-size="7.5" font-family="system-ui">Score: 2 / 10</text>
            <rect x="40" y="286" width="130" height="4" rx="2" fill="#e5e7eb"/>
            <rect x="40" y="286" width="24" height="4" rx="2" fill="#477056"/>
            <text x="40" y="302" fill="#6b7280" font-size="7" font-family="system-ui">MergeSense reviewed · just now</text>
          </g>

          <!-- Arrowhead markers -->
          <defs>
            <marker id="ms-arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#477056"/>
            </marker>
            <marker id="ms-arr-ret" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="7" markerHeight="7" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#477056"/>
            </marker>
          </defs>
        </svg>
      </div>

      <div class="relative z-10 max-w-2xl">
        <p class="section-label mb-4 hero-fade hero-fade-1">GitHub App · Public Build Series · In Progress</p>
        <h1 class="hero-fade hero-fade-2 text-4xl md:text-5xl xl:text-6xl font-bold mb-5">
          AI wrote the PR.<br />Should you merge it?
        </h1>
        <p class="hero-fade hero-fade-3 text-lg md:text-xl text-gray-600 leading-relaxed mb-2">
          MergeSense is a GitHub App that reviews every pull request automatically. It reads the diff, scores merge risk, and posts a plain-language comment — in about 30 seconds, before your team has even opened the tab.
        </p>
        <p class="hero-fade hero-fade-3 text-sm text-gray-400 mb-8">Built publicly as a video series. Architecture, decisions, and tradeoffs — all documented.</p>
        <div class="hero-fade hero-fade-3 flex flex-wrap gap-3">
          <a
            href="/builds"
            class="inline-flex items-center gap-2 px-6 py-3 text-base font-medium text-white bg-primary-600 hover:bg-primary-700 rounded-lg transition"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
            See all builds
          </a>
          <a
            href="https://www.youtube.com/@jitangupta"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-6 py-3 text-base font-medium text-accent-700 border border-accent-300 bg-accent-50 rounded-lg hover:bg-accent-100 transition"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-2.75 12.64 12.64 0 0 0-8.64 0A4.83 4.83 0 0 1 3.41 6.69 44.59 44.59 0 0 0 3 12a44.59 44.59 0 0 0 .41 5.31 4.83 4.83 0 0 1 3.77 2.75 12.64 12.64 0 0 0 8.64 0 4.83 4.83 0 0 1 3.77-2.75A44.59 44.59 0 0 0 21 12a44.59 44.59 0 0 0-.41-5.31ZM9.75 15.02V8.98L15.5 12Z"/></svg>
            Follow the series
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Animated PR flow diagram -->
  <section class="bg-white py-14 px-6">
    <div class="max-w-screen-xl mx-auto fade-up">
      <div class="mb-8 max-w-2xl">
        <p class="section-label mb-3">Live PR flow</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900">What happens when you open a PR</h2>
        <p class="mt-3 text-gray-500 text-sm">From webhook to AI comment — the full sequence, animated.</p>
      </div>

      <div class="relative rounded-2xl overflow-hidden border border-gray-200 shadow-lg bg-white p-6 md:p-10 max-w-4xl">
        <svg id="flow-svg" viewBox="0 0 900 500" xmlns="http://www.w3.org/2000/svg" class="w-full h-auto">
          <style>
            /* Flow diagram animation */
            @keyframes flow-fade-in { from { opacity:0; } to { opacity:1; } }
            @keyframes flow-slide-in { from { opacity:0; transform:translateY(8px); } to { opacity:1; transform:translateY(0); } }
            @keyframes flow-draw { from { stroke-dashoffset: var(--len, 200); } to { stroke-dashoffset: 0; } }
            @keyframes flow-badge-pop { 0%,100%{} 0%{ opacity:0; transform:scale(0.5); } 100%{ opacity:1; transform:scale(1); } }
            @keyframes flow-process-spin {
              0% { stroke-dashoffset: 88; stroke-dasharray: 22 66; }
              50% { stroke-dashoffset: 0;  stroke-dasharray: 55 33; }
              100% { stroke-dashoffset: 88; stroke-dasharray: 22 66; }
            }
            @keyframes flow-pulse { 0%,100%{opacity:0.4;} 50%{opacity:1;} }

            .flow-actor { animation: flow-slide-in 0.4s ease both; }
            .flow-actor-1 { animation-delay: 0.1s; }
            .flow-actor-2 { animation-delay: 0.2s; }
            .flow-actor-3 { animation-delay: 0.3s; }
            .flow-actor-4 { animation-delay: 0.4s; }
            .flow-actor-5 { animation-delay: 0.5s; }
            .flow-actor-6 { animation-delay: 0.6s; }

            /* Each message arrow: drawn in sequence */
            .flow-line-1 { --len:130; stroke-dasharray:130; stroke-dashoffset:130; animation: flow-draw 0.5s 1.0s ease forwards; }
            .flow-line-2 { --len:130; stroke-dasharray:130; stroke-dashoffset:130; animation: flow-draw 0.5s 1.9s ease forwards; }
            .flow-line-3 { --len:510; stroke-dasharray:510; stroke-dashoffset:510; animation: flow-draw 0.6s 2.8s ease forwards; }
            .flow-line-4 { --len:130; stroke-dasharray:130; stroke-dashoffset:130; animation: flow-draw 0.5s 3.6s ease forwards; }
            .flow-line-5 { --len:130; stroke-dasharray:130; stroke-dashoffset:130; animation: flow-draw 0.5s 4.4s ease forwards; }
            .flow-line-6 { --len:260; stroke-dasharray:260; stroke-dashoffset:260; animation: flow-draw 0.6s 5.2s ease forwards; }
            .flow-line-7 { --len:390; stroke-dasharray:390; stroke-dashoffset:390; animation: flow-draw 0.6s 6.1s ease forwards; }
            .flow-line-8 { --len:390; stroke-dasharray:390; stroke-dashoffset:390; animation: flow-draw 0.6s 7.0s ease forwards; }

            .flow-label { animation: flow-fade-in 0.4s ease both; }
            .flow-lbl-1 { animation-delay: 1.3s; opacity:0; }
            .flow-lbl-2 { animation-delay: 2.2s; opacity:0; }
            .flow-lbl-3 { animation-delay: 3.2s; opacity:0; }
            .flow-lbl-4 { animation-delay: 3.9s; opacity:0; }
            .flow-lbl-5 { animation-delay: 4.7s; opacity:0; }
            .flow-lbl-6 { animation-delay: 5.5s; opacity:0; }
            .flow-lbl-7 { animation-delay: 6.4s; opacity:0; }
            .flow-lbl-8 { animation-delay: 7.3s; opacity:0; }

            .flow-step-badge { animation: flow-badge-pop 0.35s cubic-bezier(.34,1.56,.64,1) both; }
            .flow-step-1 { animation-delay: 1.0s; opacity:0; }
            .flow-step-2 { animation-delay: 1.9s; opacity:0; }
            .flow-step-3 { animation-delay: 2.8s; opacity:0; }
            .flow-step-4 { animation-delay: 3.6s; opacity:0; }
            .flow-step-5 { animation-delay: 4.4s; opacity:0; }
            .flow-step-6 { animation-delay: 5.2s; opacity:0; }
            .flow-step-7 { animation-delay: 6.1s; opacity:0; }
            .flow-step-8 { animation-delay: 7.0s; opacity:0; }

            .flow-processing { animation: flow-process-spin 1.8s 3.8s linear infinite; }
            .flow-result-badge { animation: flow-badge-pop 0.4s 7.4s cubic-bezier(.34,1.56,.64,1) both; opacity:0; }
            .flow-async-note { animation: flow-fade-in 0.4s 4.0s ease both; opacity:0; }
          </style>

          <defs>
            <marker id="fl-arr" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#475569"/>
            </marker>
            <marker id="fl-arr-ret" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#94a3b8"/>
            </marker>
            <marker id="fl-arr-green" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="#477056"/>
            </marker>
          </defs>

          <!-- ── Actor headers ── -->
          <!-- x positions: 60, 185, 310, 435, 560, 685 -->
          <g class="flow-actor flow-actor-1">
            <rect x="10" y="12" width="100" height="48" rx="8" fill="#FFF9C4" stroke="#F57F17" stroke-width="1.5"/>
            <text x="60" y="33" font-size="11" font-weight="700" fill="#1f2937" text-anchor="middle" font-family="system-ui">You</text>
            <text x="60" y="51" font-size="9" fill="#6b7280" text-anchor="middle" font-family="system-ui">PR author</text>
          </g>
          <g class="flow-actor flow-actor-2">
            <rect x="135" y="12" width="100" height="48" rx="8" fill="#f5f5f5" stroke="#24292f" stroke-width="1.5"/>
            <text x="185" y="33" font-size="11" font-weight="700" fill="#1f2937" text-anchor="middle" font-family="system-ui">GitHub</text>
            <text x="185" y="51" font-size="9" fill="#6b7280" text-anchor="middle" font-family="system-ui">platform</text>
          </g>
          <g class="flow-actor flow-actor-3">
            <rect x="260" y="12" width="100" height="48" rx="8" fill="#E3F2FD" stroke="#1976D2" stroke-width="1.5"/>
            <text x="310" y="33" font-size="11" font-weight="700" fill="#1f2937" text-anchor="middle" font-family="system-ui">App Service</text>
            <text x="310" y="51" font-size="9" fill="#6b7280" text-anchor="middle" font-family="system-ui">webhook</text>
          </g>
          <g class="flow-actor flow-actor-4">
            <rect x="385" y="12" width="100" height="48" rx="8" fill="#E3F2FD" stroke="#1976D2" stroke-width="1.5"/>
            <text x="435" y="33" font-size="11" font-weight="700" fill="#1f2937" text-anchor="middle" font-family="system-ui">Service Bus</text>
            <text x="435" y="51" font-size="9" fill="#6b7280" text-anchor="middle" font-family="system-ui">queue</text>
          </g>
          <g class="flow-actor flow-actor-5">
            <rect x="510" y="12" width="100" height="48" rx="8" fill="#E3F2FD" stroke="#1976D2" stroke-width="1.5"/>
            <text x="560" y="33" font-size="11" font-weight="700" fill="#1f2937" text-anchor="middle" font-family="system-ui">Function</text>
            <text x="560" y="51" font-size="9" fill="#6b7280" text-anchor="middle" font-family="system-ui">worker</text>
          </g>
          <g class="flow-actor flow-actor-6">
            <rect x="635" y="12" width="120" height="48" rx="8" fill="#E8F5E9" stroke="#477056" stroke-width="1.5"/>
            <text x="695" y="33" font-size="11" font-weight="700" fill="#1f2937" text-anchor="middle" font-family="system-ui">Claude AI</text>
            <text x="695" y="51" font-size="9" fill="#6b7280" text-anchor="middle" font-family="system-ui">reviewer</text>
          </g>

          <!-- Postgres actor -->
          <g class="flow-actor" style="animation-delay:0.7s">
            <rect x="770" y="12" width="110" height="48" rx="8" fill="#FFF3E0" stroke="#E65100" stroke-width="1.5"/>
            <text x="825" y="33" font-size="11" font-weight="700" fill="#1f2937" text-anchor="middle" font-family="system-ui">Postgres</text>
            <text x="825" y="51" font-size="9" fill="#6b7280" text-anchor="middle" font-family="system-ui">Neon DB</text>
          </g>

          <!-- ── Lifelines ── -->
          <line x1="60"  y1="60" x2="60"  y2="478" stroke="#e2e8f0" stroke-width="1.2" stroke-dasharray="4 4"/>
          <line x1="185" y1="60" x2="185" y2="478" stroke="#e2e8f0" stroke-width="1.2" stroke-dasharray="4 4"/>
