---
import BaseHead from '../../components/BaseHead.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const title = "PromptMate Guide — Save, organize, and use prompts in one click";
const description = "Step-by-step guide for PromptMate: how to save prompts, use tone and format, browse history, and build your personal AI prompt library inside ChatGPT, Claude, DeepSeek, and Kimi.";

const steps = [
  {
    number: "01",
    heading: "Install the extension",
    body: "Add PromptMate from the Chrome Web Store. Works on Chrome, Brave, Edge, and all Chromium-based browsers.",
  },
  {
    number: "02",
    heading: "Connect Google Drive",
    body: "When you open the sidebar for the first time, PromptMate asks to connect your Google Drive. Your library syncs to your own private folder — nothing stored on any external server.",
  },
  {
    number: "03",
    heading: "Open any supported AI",
    body: "Navigate to ChatGPT, Claude, DeepSeek, or Kimi. Look for the PromptMate button in the bottom-right corner and click it to open your sidebar.",
  },
  {
    number: "04",
    heading: "Save your first prompt",
    body: 'Click "New Prompt", write your instruction, choose a tone and output format, then save it to your library.',
  },
  {
    number: "05",
    heading: "Use it in any chat",
    body: 'Find your prompt in the sidebar, click "Use" — it inserts into the chat with your tone and format applied.',
  },
];

const guideSections = [
  {
    heading: "Quick start",
    body: "Install PromptMate, open a supported AI tool, save your first prompt, and use it without leaving the chat page.",
    href: "#quick-start",
  },
  {
    heading: "Video walkthroughs",
    body: "Watch the core workflow, editing flow, history restore, and cross-platform use across ChatGPT, Claude, DeepSeek, and Kimi.",
    href: "#walkthroughs",
  },
  {
    heading: "Prompt construction",
    body: "See how your saved instruction, selected tone, and selected format become the final prompt inserted into your AI chat.",
    href: "#prompt-construction",
  },
  {
    heading: "Best practices",
    body: "Six practical rules for writing prompts that are specific, reusable, easy to test, and worth keeping in your library.",
    href: "/promptmate/best-practices",
  },
  {
    heading: "Starter prompts",
    body: "Copy-ready prompts for engineers across code review, writing, debugging, and more. Add them to your library in one click.",
    href: "/promptmate/starter-prompts",
  },
  {
    heading: "History and restore",
    body: "If you edited a prompt and want an older version back, learn how version history and restore work.",
    href: "#edit-history",
  },
];

const walkthroughs = [
  {
    label: "Core workflow",
    heading: "Add a prompt, choose tone and format",
    body: "Every prompt in PromptMate carries two signals beyond the text: a tone (formal, casual, technical) and an output format (bullets, steps, prose, code). When you click Use, both are appended automatically — no manual adjustment every session.",
    video: "/promptmate/add-prompt-and-use-tone-format-final.mp4",
    urlChip: "chatgpt.com",
  },
  {
    label: "Edit & history",
    heading: "Edit prompts, restore any version",
    body: "Prompts aren't static. Open any saved prompt and edit it mid-session — your changes save back to the library. Every edit creates a version, so you can browse the history and restore any prior version without losing work.",
    video: "/promptmate/edit-use-history-restore-final.mp4",
    urlChip: "claude.ai",
  },
  {
    label: "Cross-platform",
    heading: "Works on ChatGPT, Claude, DeepSeek, and Kimi",
    body: "Same sidebar, same library, all four interfaces. Install once and your entire prompt collection is available wherever you work — ChatGPT, Claude, DeepSeek, Kimi. No duplicate setup, no syncing.",
    video: "/promptmate/works-across-final.mp4",
    urlChip: "chatgpt.com / claude.ai / deepseek.com / kimi.ai",
  },
];

const constructionParts = [
  {
    label: "Saved prompt",
    title: "The reusable instruction",
    body: "This is the core task you save in PromptMate: what the AI should do, the context it needs, and any constraints that should travel with the prompt.",
    example: "Review this pull request for correctness, edge cases, and maintainability. Call out risky assumptions before suggesting changes.",
  },
  {
    label: "Tone",
    title: "How the answer should sound",
    body: "Tone nudges the response style without changing the task. Technical, concise, friendly, or formal tones keep repeated work consistent.",
    example: "Use a technical but direct tone. Be precise, avoid fluff, and explain tradeoffs like a senior engineer reviewing the work.",
  },
  {
    label: "Format",
    title: "How the answer should be shaped",
    body: "Format tells the AI how to structure the output so you can scan it quickly: bullets, steps, checklist, table, prose, or code.",
    example: "Return the answer as a checklist with sections for blockers, important fixes, small improvements, and tests to add.",
  },
];

const tips = [
  {
    heading: "Start with prompts you already reuse",
    body: "Think about instructions you type every week — code review format, email drafts, explaining concepts. Those are your first 5 saves.",
  },
  {
    heading: "Use tone + format for consistent output",
    body: "Setting tone and format on save means every session starts with the same AI behavior — no drift, no retraining the model each time.",
  },
  {
    heading: "Edit during a session, not before",
    body: "Don't over-engineer prompts upfront. Save a rough version, use it, notice what's missing, then edit inline. The version history keeps your original.",
  },
  {
    heading: "History catches what you forgot",
    body: "Every prompt you use is logged. If a session produced great output but you closed the tab, scroll the history — the prompt that worked is still there.",
  },
];
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <style>
      :root,
      html[data-theme="paper"] {
        --bg: oklch(0.985 0.008 80);
        --bg-tint: oklch(0.965 0.012 80);
        --ink: oklch(0.18 0.012 60);
        --ink-2: oklch(0.30 0.012 60);
        --muted: oklch(0.50 0.012 60);
        --hairline: oklch(0.88 0.010 80);
        --hairline-strong: oklch(0.78 0.012 80);
        --accent: oklch(0.62 0.20 32);
        --accent-ink: oklch(0.98 0.005 80);
        --selection: oklch(0.85 0.14 32 / 0.45);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Geist", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: "ss01","ss02","cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
      }

      ::selection { background: var(--selection); }
      body { min-height: 100vh; overflow-x: hidden; }

      a {
        color: inherit;
        text-decoration: none;
        text-underline-offset: 3px;
        transition: color 150ms ease, opacity 150ms ease;
      }
      a:hover { color: var(--accent); }

      p { margin: 0; }
      ul, ol { margin: 0; padding: 0; list-style: none; }
      img { max-width: 100%; display: block; }

      .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
      @media (max-width: 540px) { .wrap { padding: 0 20px; } }

      .hairline-t { border-top: 1px solid var(--hairline); }

      .mono {
        font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;
        font-feature-settings: "ss01","ss02";
      }

      .eyebrow {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .eyebrow::before {
        content: "";
        width: 18px;
        height: 1px;
        background: var(--hairline-strong);
      }

      h1, h2, h3, h4 { margin: 0; font-weight: 500; letter-spacing: -0.02em; }

      .display {
        font-size: clamp(40px, 5.4vw, 76px);
        line-height: 0.98;
        letter-spacing: -0.035em;
        font-weight: 500;
        text-wrap: balance;
      }

      .h2 {
        font-size: clamp(28px, 3.6vw, 48px);
        line-height: 1.04;
        letter-spacing: -0.028em;
        text-wrap: balance;
        font-weight: 500;
      }

      .lede {
        font-size: clamp(17px, 1.3vw, 20px);
        line-height: 1.5;
        color: var(--ink-2);
        text-wrap: pretty;
        max-width: 62ch;
      }

      .body { font-size: 17px; line-height: 1.6; color: var(--ink-2); text-wrap: pretty; }
      .small { font-size: 14px; color: var(--muted); }

      section { padding: 88px 0; position: relative; }
      section.tight { padding: 64px 0; }
      @media (max-width: 720px) { section { padding: 64px 0; } }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border: 1px solid var(--hairline-strong);
        border-radius: 999px;
        font-size: 14.5px;
        font-weight: 500;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
      }
      .btn:hover { background: var(--bg-tint); color: var(--ink); border-color: var(--ink); }
      .btn.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .btn .arrow { transition: transform 200ms ease; }
      .btn:hover .arrow { transform: translateX(3px); }

      .site-footer { border-top: 1px solid var(--hairline); padding: 56px 0 40px; }
      .site-footer .grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 56px;
      }
      .site-footer h4 {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
        font-weight: 500;
      }
      .site-footer ul li { padding: 4px 0; }
      .site-footer ul li a { color: var(--ink-2); font-size: 14.5px; }
      .site-footer .meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--muted);
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
      }
      @media (max-width: 820px) { .site-footer .grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 540px) { .site-footer .grid { grid-template-columns: 1fr; } }

      .reveal {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 600ms cubic-bezier(.2,.7,.2,1), transform 600ms cubic-bezier(.2,.7,.2,1);
      }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
      }

      .arrow { width: 14px; height: 14px; display: inline-block; vertical-align: -1px; }

      /* PromptMate sub-nav */
      .pm-subnav {
        border-bottom: 1px solid var(--hairline);
        background: var(--bg);
      }
      .pm-subnav-inner {
        display: flex;
        align-items: center;
        height: 44px;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .pm-subnav-inner::-webkit-scrollbar { display: none; }
      .pm-subnav-brand {
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        white-space: nowrap;
        padding-right: 20px;
        margin-right: 20px;
        border-right: 1px solid var(--hairline);
        flex-shrink: 0;
      }
      .pm-subnav-links {
        display: flex;
        align-items: center;
        gap: 2px;
      }
      .pm-subnav-links a {
        padding: 5px 11px;
        font-size: 13px;
        color: var(--ink-2);
        border-radius: 6px;
        transition: background 120ms ease, color 120ms ease;
        white-space: nowrap;
      }
      .pm-subnav-links a:hover { background: var(--bg-tint); color: var(--ink); }
      .pm-subnav-links a.active { color: var(--ink); font-weight: 500; }

      /* ===== PAGE-SPECIFIC ===== */

      .page-hero { padding: clamp(64px, 9vh, 120px) 0 64px; }

      /* Quick start steps */
      .steps-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 0;
        border-top: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .step-item {
        padding: 28px 24px 28px 0;
        border-bottom: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        gap: 10px;
        position: relative;
      }
      .step-item + .step-item { padding-left: 24px; border-left: 1px solid var(--hairline); }
      .step-item .n {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .step-item h3 { font-size: 18px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.3; }
      .step-item p { font-size: 14.5px; color: var(--ink-2); line-height: 1.55; }
      @media (max-width: 820px) {
        .steps-grid { grid-template-columns: 1fr 1fr; }
        .step-item:nth-child(odd) { padding-left: 0; border-left: none; }
        .step-item:nth-child(even) { padding-left: 24px; border-left: 1px solid var(--hairline); }
      }
      @media (max-width: 540px) {
        .steps-grid { grid-template-columns: 1fr; }
        .step-item { padding-left: 0 !important; border-left: none !important; }
      }

      /* Page guide */
      .guide-block {
        display: grid;
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.35fr);
        gap: 56px;
        align-items: start;
      }
      .guide-copy {
        position: sticky;
        top: 96px;
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .guide-copy .btns { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 8px; }
      .trust-points {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 2px;
      }
      .trust-points span {
        display: inline-flex;
        align-items: center;
        padding: 7px 10px;
        border: 1px solid var(--hairline);
        border-radius: 999px;
        background: var(--bg-tint);
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        color: var(--ink-2);
      }
      .guide-list {
        display: grid;
        grid-template-columns: 1fr;
        border-top: 1px solid var(--hairline);
      }
      .guide-item {
        display: grid;
        grid-template-columns: 160px 1fr;
        gap: 28px;
        padding: 24px 0;
        border-bottom: 1px solid var(--hairline);
      }
      .guide-item h3 {
        font-size: 17px;
        font-weight: 500;
        letter-spacing: -0.015em;
        line-height: 1.3;
      }
      .guide-item p { font-size: 14.5px; color: var(--ink-2); line-height: 1.6; }
      .guide-item a {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        margin-top: 12px;
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        color: var(--accent);
      }
      @media (max-width: 860px) {
        .guide-block { grid-template-columns: 1fr; gap: 32px; }
        .guide-copy { position: static; }
      }
      @media (max-width: 560px) {
        .guide-item { grid-template-columns: 1fr; gap: 8px; }
      }

      /* Walkthroughs */
      .walkthrough { padding: 72px 0; border-top: 1px solid var(--hairline); }
      .walkthrough .inner {
        display: grid;
        grid-template-columns: 1fr 2fr;
        gap: 64px;
        align-items: start;
      }
      .walkthrough .text { display: flex; flex-direction: column; gap: 16px; padding-top: 8px; }
      .walkthrough h2 { font-size: clamp(24px, 2.8vw, 38px); font-weight: 500; letter-spacing: -0.025em; line-height: 1.1; }
      .walkthrough p { font-size: 15px; color: var(--ink-2); line-height: 1.65; max-width: 52ch; }
      @media (max-width: 820px) {
        .walkthrough .inner { grid-template-columns: 1fr; gap: 32px; }
      }

      /* Browser chrome video player */
      .video-frame {
        border: 1px solid var(--hairline-strong);
        border-radius: 6px;
        overflow: hidden;
        background: var(--ink);
      }
      .video-chrome {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 14px;
        background: color-mix(in oklch, var(--ink) 95%, var(--bg));
        border-bottom: 1px solid color-mix(in oklch, var(--bg) 12%, transparent);
      }
      .video-chrome .dot { width: 10px; height: 10px; border-radius: 50%; }
      .video-chrome .dot.r { background: oklch(0.60 0.18 24 / 0.7); }
      .video-chrome .dot.y { background: oklch(0.75 0.16 90 / 0.7); }
      .video-chrome .dot.g { background: oklch(0.68 0.18 150 / 0.7); }
      .video-chrome .url {
        margin-left: 10px;
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        color: color-mix(in oklch, var(--bg) 45%, transparent);
        letter-spacing: 0.01em;
      }
      .video-frame video { display: block; width: 100%; }

      /* Prompt construction */
      .construction-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        border-top: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .construction-part {
        padding: 28px 24px 28px 0;
        border-bottom: 1px solid var(--hairline);
      }
      .construction-part + .construction-part { padding-left: 24px; border-left: 1px solid var(--hairline); }
      .construction-part .label {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: 12px;
      }
      .construction-part h3 { font-size: 18px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.3; margin-bottom: 10px; }
      .construction-part p { font-size: 14.5px; color: var(--ink-2); line-height: 1.55; }
      .prompt-sample {
        margin-top: 18px;
        padding: 14px 16px;
        background: var(--bg-tint);
        border: 1px solid var(--hairline);
        border-radius: 6px;
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12.5px;
        line-height: 1.65;
        color: var(--ink-2);
      }
      .assembled-prompt {
        margin-top: 40px;
        border: 1px solid var(--hairline-strong);
        border-radius: 6px;
        overflow: hidden;
        background: var(--bg);
      }
      .assembled-prompt .top {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        padding: 14px 16px;
        border-bottom: 1px solid var(--hairline);
        background: var(--bg-tint);
      }
      .assembled-prompt .top span {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        color: var(--muted);
      }
      .assembled-prompt pre {
        margin: 0;
        padding: 20px;
        white-space: pre-wrap;
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 13px;
        line-height: 1.7;
        color: var(--ink);
      }
      @media (max-width: 860px) {
        .construction-grid { grid-template-columns: 1fr; }
        .construction-part,
        .construction-part + .construction-part {
          padding: 24px 0;
          border-left: none;
        }
      }

      /* Tips grid */
      .tips-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border-top: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .tip-item {
        padding: 32px 32px 32px 0;
        border-bottom: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .tip-item:nth-child(even) {
        padding-left: 32px;
        border-left: 1px solid var(--hairline);
        padding-right: 0;
      }
      .tip-item h3 { font-size: 18px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.3; }
      .tip-item p { font-size: 14.5px; color: var(--ink-2); line-height: 1.55; }
      @media (max-width: 640px) {
        .tips-grid { grid-template-columns: 1fr; }
        .tip-item { padding: 28px 0 !important; border-left: none !important; }
      }

      /* CTA block */
      .cta-block {
        padding: 64px 0;
        border-top: 1px solid var(--hairline);
        border-bottom: 1px solid var(--hairline);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 40px;
        align-items: end;
      }
      .cta-block h2 { margin-bottom: 12px; }
      .cta-block .btns { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
      @media (max-width: 720px) { .cta-block { grid-template-columns: 1fr; gap: 24px; } }
    </style>
  </head>

  <body>

    <SiteHeader />

    <nav class="pm-subnav">
      <div class="wrap">
        <div class="pm-subnav-inner">
          <span class="pm-subnav-brand">PromptMate</span>
          <div class="pm-subnav-links">
            <a href="/promptmate">Overview</a>
            <a href="/promptmate/getting-started" class="active">Getting started</a>
            <a href="/promptmate/best-practices">Best practices</a>
            <a href="/promptmate/starter-prompts">Starter prompts</a>
          </div>
        </div>
      </div>
    </nav>

    <main>

      <!-- HERO -->
      <section class="page-hero">
        <div class="wrap reveal">
          <span class="eyebrow">PromptMate · Getting started</span>
          <h1 class="display" style="margin-top: 16px;">
            Get the most out<br />of PromptMate.
          </h1>
          <p class="lede" style="margin-top: 24px;">
            You're a few clicks away from a prompt library that actually works — saved once, used everywhere, in ChatGPT, Claude, DeepSeek, and Kimi.
          </p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px;">
            <a
              class="btn primary"
              href="https://chromewebstore.google.com/detail/promptmate/oknglgpcglngpaobpjndcaaljdchmgai"
              target="_blank"
              rel="noopener noreferrer"
            >
              Install Free
              <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </a>
            <a class="btn" href="/promptmate">
