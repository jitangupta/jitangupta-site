---
import BaseHead from '../../components/BaseHead.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const title = "PromptMate · Personal prompt library for ChatGPT, Claude, DeepSeek, and Kimi";
const description = "A Chrome extension that adds a personal prompt library sidebar to ChatGPT, Claude, DeepSeek, and Kimi. Save, organize, and insert prompts in one click. Built in Mumbai, open source, no backend.";

const features = [
  {
    heading: "Sidebar inside ChatGPT, Claude, DeepSeek, and Kimi",
    body: "No tab switching. Your prompts live where you work — a sidebar that opens on ChatGPT, Claude, DeepSeek, and Kimi with one click.",
  },
  {
    heading: "Save with tone and format",
    body: "Each prompt stores a tone (formal, casual, technical) and output format (bullets, steps, prose, code). Inserted together, in one click.",
  },
  {
    heading: "Open source, no backend",
    body: "Syncs to your own private Google Drive folder. No data on my infrastructure. You own your library.",
  },
  {
    heading: "Edit on demand",
    body: "Prompts aren't locked. Open any saved prompt, tweak it mid-session, save back. The edit is yours.",
  },
  {
    heading: "Local usage analytics",
    body: "Tracks how often you create, apply, copy, and delete prompts. Stored locally so you can see what's actually useful.",
  },
  {
    heading: "Prompt history",
    body: "Every prompt you use is logged. Go back to any previous prompt from your session history — nothing gets lost between chats.",
  },
];

const roadmap = [
  {
    live: false,
    status: "Planned",
    title: "Group Prompts",
    body: "Organize your library into named groups — by project, by use case, or by workflow. Find what you need without scrolling through everything.",
  },
  {
    live: false,
    status: "Planned",
    title: "Share Prompts",
    body: "Publish a prompt to anyone-with-link. The receiver gets their own copy. Private by default, shareable on demand.",
  },
  {
    live: false,
    status: "Planned",
    title: "Codex & Claude Code desktop",
    body: "Bring your prompt library into Codex and the Claude Code desktop app — the same one-click insert experience, now for coding workflows too.",
  },
  {
    live: true,
    status: "Live · v0.6.0",
    title: "Prompt version history",
    body: "Every edit to a saved prompt creates a version. Browse the history, see what changed, and restore any prior version without losing work.",
  },
];

const screenshots = [
  {
    url: "chatgpt.com",
    src: "/images/promptmate/banner-chatgpt.jpg",
    alt: "PromptMate button on ChatGPT",
    caption: "One-click open on ChatGPT",
    sub: "The PromptMate button appears in the bottom-right corner.",
  },
  {
    url: "chatgpt.com",
    src: "/images/promptmate/banner-chatgpt-open.jpg",
    alt: "PromptMate sidebar open on ChatGPT",
    caption: "Sidebar with tone & format",
    sub: "Search, pick tone, pick format, click Use. Done.",
  },
  {
    url: "claude.ai",
    src: "/images/promptmate/banner-claude.jpg",
    alt: "PromptMate button on Claude",
    caption: "Same experience on Claude",
    sub: "Same sidebar, same library, both interfaces.",
  },
  {
    url: "claude.ai",
    src: "/images/promptmate/banner-claude-open.jpg",
    alt: "PromptMate sidebar open on Claude",
    caption: "Insert with full context",
    sub: "Tone and format instructions are appended automatically.",
  },
];
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <style>
      :root,
      html[data-theme="paper"] {
        --bg: oklch(0.985 0.008 80);
        --bg-tint: oklch(0.965 0.012 80);
        --ink: oklch(0.18 0.012 60);
        --ink-2: oklch(0.30 0.012 60);
        --muted: oklch(0.50 0.012 60);
        --hairline: oklch(0.88 0.010 80);
        --hairline-strong: oklch(0.78 0.012 80);
        --accent: oklch(0.62 0.20 32);
        --accent-ink: oklch(0.98 0.005 80);
        --selection: oklch(0.85 0.14 32 / 0.45);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Geist", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: "ss01","ss02","cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
      }

      ::selection { background: var(--selection); }
      body { min-height: 100vh; overflow-x: hidden; }

      a {
        color: inherit;
        text-decoration: none;
        text-underline-offset: 3px;
        transition: color 150ms ease, opacity 150ms ease;
      }
      a:hover { color: var(--accent); }

      p { margin: 0; }
      ul, ol { margin: 0; padding: 0; list-style: none; }
      img { max-width: 100%; display: block; }

      .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
      @media (max-width: 540px) { .wrap { padding: 0 20px; } }

      .hairline-t { border-top: 1px solid var(--hairline); }

      .mono {
        font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;
        font-feature-settings: "ss01","ss02";
      }

      .eyebrow {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .eyebrow::before {
        content: "";
        width: 18px;
        height: 1px;
        background: var(--hairline-strong);
      }

      h1, h2, h3, h4 { margin: 0; font-weight: 500; letter-spacing: -0.02em; }

      .display {
        font-size: clamp(40px, 5.4vw, 76px);
        line-height: 0.98;
        letter-spacing: -0.035em;
        font-weight: 500;
        text-wrap: balance;
      }

      .h2 {
        font-size: clamp(28px, 3.6vw, 48px);
        line-height: 1.04;
        letter-spacing: -0.028em;
        text-wrap: balance;
        font-weight: 500;
      }

      .lede {
        font-size: clamp(17px, 1.3vw, 20px);
        line-height: 1.5;
        color: var(--ink-2);
        text-wrap: pretty;
        max-width: 62ch;
      }

      .body { font-size: 17px; line-height: 1.6; color: var(--ink-2); text-wrap: pretty; }
      .small { font-size: 14px; color: var(--muted); }

      section { padding: 88px 0; position: relative; }
      section.tight { padding: 64px 0; }
      @media (max-width: 720px) { section { padding: 64px 0; } }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border: 1px solid var(--hairline-strong);
        border-radius: 999px;
        font-size: 14.5px;
        font-weight: 500;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
      }
      .btn:hover { background: var(--bg-tint); color: var(--ink); border-color: var(--ink); }
      .btn.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .btn .arrow { transition: transform 200ms ease; }
      .btn:hover .arrow { transform: translateX(3px); }

      .status {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 11.5px;
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .status::before {
        content: "";
        width: 7px; height: 7px;
        background: var(--accent);
        border-radius: 50%;
        box-shadow: 0 0 0 3px color-mix(in oklch, var(--accent) 18%, transparent);
      }
      .status.muted::before { background: var(--muted); box-shadow: none; }

      .site-footer { border-top: 1px solid var(--hairline); padding: 56px 0 40px; }
      .site-footer .grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 56px;
      }
      .site-footer h4 {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
        font-weight: 500;
      }
      .site-footer ul li { padding: 4px 0; }
      .site-footer ul li a { color: var(--ink-2); font-size: 14.5px; }
      .site-footer .meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--muted);
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
      }
      @media (max-width: 820px) { .site-footer .grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 540px) { .site-footer .grid { grid-template-columns: 1fr; } }

      .reveal {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 600ms cubic-bezier(.2,.7,.2,1), transform 600ms cubic-bezier(.2,.7,.2,1);
      }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
      }

      .arrow { width: 14px; height: 14px; display: inline-block; vertical-align: -1px; }

      /* PromptMate sub-nav */
      .pm-subnav {
        border-bottom: 1px solid var(--hairline);
        background: var(--bg);
      }
      .pm-subnav-inner {
        display: flex;
        align-items: center;
        height: 44px;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .pm-subnav-inner::-webkit-scrollbar { display: none; }
      .pm-subnav-brand {
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        white-space: nowrap;
        padding-right: 20px;
        margin-right: 20px;
        border-right: 1px solid var(--hairline);
        flex-shrink: 0;
      }
      .pm-subnav-links {
        display: flex;
        align-items: center;
        gap: 2px;
      }
      .pm-subnav-links a {
        padding: 5px 11px;
        font-size: 13px;
        color: var(--ink-2);
        border-radius: 6px;
        transition: background 120ms ease, color 120ms ease;
        white-space: nowrap;
      }
      .pm-subnav-links a:hover { background: var(--bg-tint); color: var(--ink); }
      .pm-subnav-links a.active { color: var(--ink); font-weight: 500; }

      /* ===== PAGE-SPECIFIC ===== */

      .page-hero { padding: clamp(64px, 9vh, 120px) 0 64px; }

      .meta-row {
        display: flex;
        gap: 24px;
        flex-wrap: wrap;
        margin-top: 28px;
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        color: var(--muted);
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }
      .meta-row b { color: var(--ink); font-weight: 500; }

      /* Video / browser chrome */
      .video-frame {
        border: 1px solid var(--hairline-strong);
        border-radius: 6px;
        overflow: hidden;
        background: var(--ink);
      }
      .video-chrome {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 14px;
        background: color-mix(in oklch, var(--ink) 95%, var(--bg));
        border-bottom: 1px solid color-mix(in oklch, var(--bg) 12%, transparent);
      }
      .video-chrome .dot { width: 10px; height: 10px; border-radius: 50%; }
      .video-chrome .dot.r { background: oklch(0.60 0.18 24 / 0.7); }
      .video-chrome .dot.y { background: oklch(0.75 0.16 90 / 0.7); }
      .video-chrome .dot.g { background: oklch(0.68 0.18 150 / 0.7); }
      .video-chrome .url {
        margin-left: 10px;
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        color: color-mix(in oklch, var(--bg) 45%, transparent);
        letter-spacing: 0.01em;
      }
      .video-frame video { display: block; width: 100%; }

      /* Screenshots */
      .screenshot-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background: var(--hairline);
        border: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .screenshot-item {
        background: var(--bg);
        overflow: hidden;
        display: flex;
        flex-direction: column;
      }
      .screenshot-chrome {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 10px 14px;
        background: var(--bg-tint);
        border-bottom: 1px solid var(--hairline);
      }
      .screenshot-chrome .dot { width: 8px; height: 8px; border-radius: 50%; }
      .screenshot-chrome .dot.r { background: oklch(0.65 0.16 24 / 0.6); }
      .screenshot-chrome .dot.y { background: oklch(0.78 0.14 90 / 0.6); }
      .screenshot-chrome .dot.g { background: oklch(0.70 0.16 150 / 0.6); }
      .screenshot-chrome .url {
        margin-left: 8px;
        font-family: "Geist Mono", monospace;
        font-size: 11px;
        color: var(--muted);
        letter-spacing: 0.01em;
      }
      .screenshot-item img { display: block; width: 100%; }
      .screenshot-caption {
        padding: 16px 20px;
        border-top: 1px solid var(--hairline);
      }
      .screenshot-caption h4 { font-size: 15px; font-weight: 500; letter-spacing: -0.01em; }
      .screenshot-caption p { font-size: 13px; color: var(--muted); margin-top: 4px; line-height: 1.5; }
      @media (max-width: 720px) { .screenshot-grid { grid-template-columns: 1fr; } }

      /* Origin/story block */
      .origin-block {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(0, 1.5fr);
        gap: 64px;
        align-items: start;
        padding: 64px 0;
        border-top: 1px solid var(--hairline);
        border-bottom: 1px solid var(--hairline);
      }
      .origin-sticky {
        position: sticky;
        top: 96px;
        display: flex;
        flex-direction: column;
        gap: 16px;
      }
      .origin-prose {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }
      .origin-prose p { font-size: 16px; line-height: 1.7; color: var(--ink-2); }
      .origin-prose em { color: var(--ink); font-style: italic; }
      .origin-attribution {
        display: flex;
        align-items: center;
        gap: 12px;
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
        margin-top: 8px;
      }
      .origin-attribution img {
        width: 36px; height: 36px;
        border-radius: 50%;
        object-fit: cover;
      }
      .origin-attribution .name { font-size: 14px; font-weight: 500; }
      .origin-attribution .sub { font-size: 12px; color: var(--muted); margin-top: 2px; }
      .origin-attribution .sub a { color: var(--accent); }
      @media (max-width: 860px) {
        .origin-block { grid-template-columns: 1fr; gap: 32px; }
        .origin-sticky { position: static; }
      }

      /* Features grid */
      .feature-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        background: var(--hairline);
        border: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .feature-item {
        background: var(--bg);
        padding: 28px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: background 150ms ease;
      }
      .feature-item:hover { background: var(--bg-tint); }
      .feature-item h3 { font-size: 16px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.3; }
      .feature-item p { font-size: 14.5px; color: var(--ink-2); line-height: 1.55; }
      @media (max-width: 820px) { .feature-grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 540px) { .feature-grid { grid-template-columns: 1fr; } }

      /* Roadmap grid */
      .roadmap-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background: var(--hairline);
        border: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .roadmap-item {
        background: var(--bg);
        padding: 32px;
        display: flex;
        flex-direction: column;
        gap: 10px;
        transition: background 150ms ease;
      }
      .roadmap-item:hover { background: var(--bg-tint); }
      .roadmap-item h3 { font-size: 18px; font-weight: 500; letter-spacing: -0.018em; line-height: 1.3; }
      .roadmap-item p { font-size: 14.5px; color: var(--ink-2); line-height: 1.6; }
      @media (max-width: 640px) { .roadmap-grid { grid-template-columns: 1fr; } }

      /* CTA block */
      .cta-block {
        padding: 64px 0;
        border-top: 1px solid var(--hairline);
        border-bottom: 1px solid var(--hairline);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 40px;
        align-items: end;
      }
      .cta-block .btns { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
      @media (max-width: 720px) { .cta-block { grid-template-columns: 1fr; gap: 24px; } }
    </style>
  </head>

  <body>

    <SiteHeader />

    <nav class="pm-subnav">
      <div class="wrap">
        <div class="pm-subnav-inner">
          <span class="pm-subnav-brand">PromptMate</span>
          <div class="pm-subnav-links">
            <a href="/promptmate" class="active">Overview</a>
            <a href="/promptmate/getting-started">Getting started</a>
            <a href="/promptmate/best-practices">Best practices</a>
            <a href="/promptmate/starter-prompts">Starter prompts</a>
            <a href="/promptmate/whats-new">What's new</a>
          </div>
        </div>
      </div>
    </nav>

    <main>

      <!-- HERO -->
      <section class="page-hero">
        <div class="wrap reveal">
          <img src="/prompt-mate-logo.png" alt="PromptMate" style="height: 56px; width: auto; display: block; margin-bottom: 20px;" />
          <span class="eyebrow">Chrome Extension · Free &amp; Open Source</span>
          <h1 class="display" style="margin-top: 16px;">
            Your saved prompts,<br />one click away.
          </h1>
          <p class="lede" style="margin-top: 24px;">
            A personal prompt library that lives inside ChatGPT, Claude, DeepSeek, and Kimi. Built for engineers and AI power users who are tired of retyping the same instructions every session.
          </p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px;">
            <a
              class="btn primary"
              href="https://chromewebstore.google.com/detail/promptmate/oknglgpcglngpaobpjndcaaljdchmgai"
              target="_blank"
              rel="noopener noreferrer"
            >
              Install Free
              <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </a>
            <a
              class="btn"
              href="https://github.com/jitangupta/PromptMate"
              target="_blank"
              rel="noopener noreferrer"
            >
              View on GitHub
              <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </a>
            <a class="btn" href="/promptmate/getting-started">
              Getting started guide
            </a>
          </div>
          <div class="meta-row">
            <span><b>v0.6.0</b> Current</span>
            <span><b>4</b> Platforms</span>
            <span><b>Free</b> No account</span>
            <span>Works on Chrome, Brave, Edge, and all Chromium-based browsers</span>
          </div>
        </div>
      </section>

      <!-- LAUNCH VIDEO -->
      <section class="tight hairline-t">
        <div class="wrap">
          <div class="reveal" style="margin-bottom: 32px;">
            <span class="eyebrow">Launch walkthrough</span>
            <h2 class="h2" style="margin-top: 16px;">See it in action.</h2>
            <p class="lede" style="margin-top: 12px;">Install, setup, and a real session showing how PromptMate fits into a daily AI workflow.</p>
          </div>
          <div class="video-frame reveal" style="max-width: 880px;">
            <div class="video-chrome">
              <span class="dot r"></span>
              <span class="dot y"></span>
              <span class="dot g"></span>
              <span class="url">chrome://extensions</span>
            </div>
            <video
              src="/images/promptmate/launch.mp4"
              controls
              preload="metadata"
              poster="/images/promptmate/banner-claude.jpg"
            >
              Your browser does not support the video tag.
            </video>
          </div>
        </div>
      </section>

      <!-- SCREENSHOTS -->
      <section class="tight hairline-t">
        <div class="wrap">
          <div class="reveal">
            <span class="eyebrow">In the wild</span>
            <h2 class="h2" style="margin-top: 16px;">Works where you work.</h2>
            <p class="lede" style="margin-top: 12px;">Opens as a sidebar on ChatGPT, Claude, DeepSeek, and Kimi. No context switching, no separate tab.</p>
          </div>
          <div class="screenshot-grid">
            {screenshots.map((s) => (
              <div class="screenshot-item reveal">
                <div class="screenshot-chrome">
                  <span class="dot r"></span>
                  <span class="dot y"></span>
                  <span class="dot g"></span>
                  <span class="url">{s.url}</span>
                </div>
                <img src={s.src} alt={s.alt} loading="lazy" />
                <div class="screenshot-caption">
                  <h4>{s.caption}</h4>
                  <p>{s.sub}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- ORIGIN -->
      <section class="tight">
        <div class="wrap">
          <div class="origin-block reveal">
            <div class="origin-sticky">
              <span class="eyebrow">Why I built it</span>
              <h2 class="h2">The friction was real.</h2>
            </div>
            <div class="origin-prose">
              <p>
                I use Claude and ChatGPT for almost everything now: code reviews, draft emails, explaining concepts to teammates, writing scripts for YouTube. And I kept typing the same instructions over and over.
              </p>
              <p>
                Not the prompts themselves — I had those saved in Notion, in a text file, scattered in browser tabs. The problem was the ritual: open a new chat, remember which prompt, find the file, copy, paste, adjust the tone manually. Every. Single. Session.
              </p>
              <p>
