    <script>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => {
          if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
        });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.reveal').forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight) { el.classList.add('in'); }
        else { io.observe(el); }
      });

      setTimeout(() => {
        document.querySelectorAll('.reveal:not(.in)').forEach((el) => el.classList.add('in'));
      }, 1500);

      // Copy prompt buttons
      document.querySelectorAll('.prompt-copy-btn').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const text = btn.getAttribute('data-prompt');
          if (!text) return;
          try {
            await navigator.clipboard.writeText(text);
            btn.classList.add('copied');
            btn.textContent = '✓ Copied';
            setTimeout(() => {
              btn.classList.remove('copied');
              btn.innerHTML = `<svg width="13" height="13" viewBox="0 0 13 13" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="1.5" y="3.5" width="8" height="8" rx="1.5"/><path d="M3.5 3.5V2.5a1 1 0 0 1 1-1h5a1 1 0 0 1 1 1v5a1 1 0 0 1-1 1H8.5"/></svg> Copy prompt`;
            }, 2000);
          } catch {
            // fallback: select text in the pre
            const pre = btn.closest('.prompt-body')?.querySelector('.prompt-text');
            if (pre) {
              const range = document.createRange();
              range.selectNodeContents(pre);
              const sel = window.getSelection();
              sel?.removeAllRanges();
              sel?.addRange(range);
            }
          }
        });
      });
    </script>

