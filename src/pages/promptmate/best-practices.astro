---
import BaseHead from '../../components/BaseHead.astro';
import SiteHeader from '../../components/SiteHeader.astro';

const title = "PromptMate Best Practices — Write prompts worth saving";
const description = "Six rules for writing PromptMate prompts with variables, context, groups, tone, and format. Build a reusable prompt library you actually use every session.";

const practices = [
  {
    number: "01",
    heading: "Be specific about the task, not the persona",
    body: 'Write "Review this code for SQL injection vulnerabilities" rather than "Act as a security expert". Task-specific prompts produce consistent, usable output. Persona prompts produce unpredictable responses.',
    ask: "What exactly do you want done? Start there.",
    example: {
      bad: "Act as a senior engineer and review this.",
      good: "Review this pull request for correctness, edge cases, and maintainability. Call out risky assumptions before suggesting changes.",
    },
  },
  {
    number: "02",
    heading: "Use variables for the parts that change",
    body: 'Build reusable prompts with {{variables}} like {{diff}}, {{topic}}, or {{audience}} for the parts that change each session. Static framing stays saved; PromptMate asks for the variable values when you click Use.',
    ask: "What changes session to session? Make that a variable.",
    example: {
      bad: "Explain Kubernetes to me.",
      good: "Explain {{topic}} clearly. Start with a one-sentence definition, then give me the intuition, then a practical example. Assume I know software engineering basics.",
    },
  },
  {
    number: "03",
    heading: "One task per prompt",
    body: "Prompts that ask for three things produce output that does two of them well and one poorly. Save separate prompts for separate tasks. Compose them manually in a session when you need both.",
    ask: "Can you split this into two focused prompts?",
    example: {
      bad: "Review my code, write tests for it, and then document it.",
      good: "Save three separate prompts: one for review, one for tests, one for documentation.",
    },
  },
  {
    number: "04",
    heading: "Match tone and format to the reader, not the task",
    body: "A code review written as prose is slow to scan. A technical spec in bullet points loses nuance. The output format should match how the output will actually be read — not just what feels right to write.",
    ask: "Who reads this output? How will they consume it?",
    example: {
      bad: "Explain the bug fix. (No format set)",
      good: "Format: Steps numbered 1–N. Each step: what changed, why, and what to verify. Written for a junior engineer reading in a PR comment.",
    },
  },
  {
    number: "05",
    heading: "Test before saving, not after",
    body: "Use a prompt two or three times in real sessions before saving it. If you need to edit it every time, it's not ready. Save the version that works without adjustment — that's the one worth keeping.",
    ask: "Did this produce the right output without editing? If not, fix first.",
    example: {
      bad: 'Saving a prompt the first time you write it "just in case".',
      good: "Run it twice with different inputs. Edit until no adjustments are needed. Then save.",
    },
  },
  {
    number: "06",
    heading: "Include the context the model can't infer",
    body: "Language, framework, audience, constraints, what to avoid. The model doesn't know you're on a Kubernetes cluster or writing for a non-technical PM. Put that in the prompt — it won't drift session to session.",
    ask: "What would a smart colleague need to know to do this task well?",
    example: {
      bad: "Write documentation for this function.",
      good: "Write JSDoc documentation for this TypeScript function. Audience: engineers onboarding to this codebase. Cover: what it does, parameters, return value, one usage example, and edge cases to watch for.",
    },
  },
];

const tips = [
  {
    heading: "Start with prompts you already reuse",
    body: "Think about instructions you type every week — code review format, email drafts, explaining concepts to teammates. Those are your first 5 saves. Don't start from scratch — start from what's already working.",
  },
  {
    heading: "Use variables instead of editing pasted text",
    body: "If the same part changes every time, make it a variable. The same prompt with {{diff}} or {{audience}} becomes reusable without manual cleanup in the chat box.",
  },
  {
    heading: "Move repeated framing out of the prompt",
    body: "Your role belongs in user context. Project rules belong in group instructions. Keep the prompt body focused on the task, or your library becomes hard to maintain.",
  },
  {
    heading: "Edit during a session, not before",
    body: "Don't over-engineer prompts upfront. Save a rough version, use it in real work, notice what's missing, then edit inline. Version history keeps your original.",
  },
];

const layerDecisions = [
  {
    label: "User context",
    use: "Use for stable facts about you: role, stack, audience preferences, and how you like answers.",
    avoid: "Do not put one project, one task, or one pasted input here.",
  },
  {
    label: "Group instruction",
    use: "Use for rules shared by a workflow: code review standards, writing voice, product constraints, or team conventions.",
    avoid: "Do not repeat the same group instruction inside every prompt.",
  },
  {
    label: "Prompt body",
    use: "Use for the reusable task: what to do, what to inspect, and what a good answer should include.",
    avoid: "Do not make one prompt do three unrelated jobs.",
  },
  {
    label: "Variables",
    use: "Use for changing values: {{diff}}, {{topic}}, {{error_message}}, {{target_reader}}, or {{feature_goal}}.",
    avoid: "Do not save a prompt that forces you to edit text after inserting it.",
  },
];
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <BaseHead title={title} description={description} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <style>
      :root,
      html[data-theme="paper"] {
        --bg: oklch(0.985 0.008 80);
        --bg-tint: oklch(0.965 0.012 80);
        --ink: oklch(0.18 0.012 60);
        --ink-2: oklch(0.30 0.012 60);
        --muted: oklch(0.50 0.012 60);
        --hairline: oklch(0.88 0.010 80);
        --hairline-strong: oklch(0.78 0.012 80);
        --accent: oklch(0.62 0.20 32);
        --accent-ink: oklch(0.98 0.005 80);
        --selection: oklch(0.85 0.14 32 / 0.45);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Geist", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: "ss01","ss02","cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
      }

      ::selection { background: var(--selection); }
      body { min-height: 100vh; overflow-x: hidden; }

      a {
        color: inherit;
        text-decoration: none;
        text-underline-offset: 3px;
        transition: color 150ms ease, opacity 150ms ease;
      }
      a:hover { color: var(--accent); }

      p { margin: 0; }
      ul, ol { margin: 0; padding: 0; list-style: none; }
      img { max-width: 100%; display: block; }

      .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
      @media (max-width: 540px) { .wrap { padding: 0 20px; } }

      .hairline-t { border-top: 1px solid var(--hairline); }

      .mono {
        font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;
        font-feature-settings: "ss01","ss02";
      }

      .eyebrow {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .eyebrow::before {
        content: "";
        width: 18px;
        height: 1px;
        background: var(--hairline-strong);
      }

      h1, h2, h3, h4 { margin: 0; font-weight: 500; letter-spacing: -0.02em; }

      .display {
        font-size: clamp(40px, 5.4vw, 76px);
        line-height: 0.98;
        letter-spacing: -0.035em;
        font-weight: 500;
        text-wrap: balance;
      }

      .h2 {
        font-size: clamp(28px, 3.6vw, 48px);
        line-height: 1.04;
        letter-spacing: -0.028em;
        text-wrap: balance;
        font-weight: 500;
      }

      .lede {
        font-size: clamp(17px, 1.3vw, 20px);
        line-height: 1.5;
        color: var(--ink-2);
        text-wrap: pretty;
        max-width: 62ch;
      }

      .body { font-size: 17px; line-height: 1.6; color: var(--ink-2); text-wrap: pretty; }

      section { padding: 88px 0; position: relative; }
      section.tight { padding: 64px 0; }
      @media (max-width: 720px) { section { padding: 64px 0; } }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border: 1px solid var(--hairline-strong);
        border-radius: 999px;
        font-size: 14.5px;
        font-weight: 500;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
      }
      .btn:hover { background: var(--bg-tint); color: var(--ink); border-color: var(--ink); }
      .btn.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .btn .arrow { transition: transform 200ms ease; }
      .btn:hover .arrow { transform: translateX(3px); }

      .site-footer { border-top: 1px solid var(--hairline); padding: 56px 0 40px; }
      .site-footer .grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 56px;
      }
      .site-footer h4 {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
        font-weight: 500;
      }
      .site-footer ul li { padding: 4px 0; }
      .site-footer ul li a { color: var(--ink-2); font-size: 14.5px; }
      .site-footer .meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--muted);
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
      }
      @media (max-width: 820px) { .site-footer .grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 540px) { .site-footer .grid { grid-template-columns: 1fr; } }

      .reveal {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 600ms cubic-bezier(.2,.7,.2,1), transform 600ms cubic-bezier(.2,.7,.2,1);
      }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
      }

      .arrow { width: 14px; height: 14px; display: inline-block; vertical-align: -1px; }

      /* PromptMate sub-nav */
      .pm-subnav {
        border-bottom: 1px solid var(--hairline);
        background: var(--bg);
      }
      .pm-subnav-inner {
        display: flex;
        align-items: center;
        height: 44px;
        overflow-x: auto;
        scrollbar-width: none;
      }
      .pm-subnav-inner::-webkit-scrollbar { display: none; }
      .pm-subnav-brand {
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        white-space: nowrap;
        padding-right: 20px;
        margin-right: 20px;
        border-right: 1px solid var(--hairline);
        flex-shrink: 0;
      }
      .pm-subnav-links {
        display: flex;
        align-items: center;
        gap: 2px;
      }
      .pm-subnav-links a {
        padding: 5px 11px;
        font-size: 13px;
        color: var(--ink-2);
        border-radius: 6px;
        transition: background 120ms ease, color 120ms ease;
        white-space: nowrap;
      }
      .pm-subnav-links a:hover { background: var(--bg-tint); color: var(--ink); }
      .pm-subnav-links a.active { color: var(--ink); font-weight: 500; }

      /* ===== PAGE-SPECIFIC ===== */

      .page-hero { padding: clamp(64px, 9vh, 120px) 0 64px; }

      /* Practices */
      .practice-list {
        display: flex;
        flex-direction: column;
        border-top: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .practice {
        display: grid;
        grid-template-columns: 80px 1fr;
        gap: 32px;
        padding: 40px 0;
        border-bottom: 1px solid var(--hairline);
        align-items: start;
      }
      .practice .num {
        font-family: "Geist Mono", monospace;
        font-size: 13px;
        color: var(--muted);
        letter-spacing: 0.04em;
        padding-top: 4px;
      }
      .practice h3 { font-size: 20px; font-weight: 500; letter-spacing: -0.018em; margin-bottom: 10px; }
      .practice p { color: var(--ink-2); line-height: 1.6; font-size: 15.5px; max-width: 64ch; }
      .practice .ask {
        margin-top: 14px;
        padding: 12px 16px;
        background: var(--bg-tint);
        border-left: 2px solid var(--accent);
        font-family: "Geist Mono", monospace;
        font-size: 13px;
        line-height: 1.6;
        color: var(--ink);
      }
      .practice .ask::before {
        content: "Ask yourself";
        display: block;
        color: var(--muted);
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: 5px;
      }
      .example-pair {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1px;
        background: var(--hairline);
        border: 1px solid var(--hairline);
        border-radius: 6px;
        overflow: hidden;
        margin-top: 18px;
      }
      .example-half {
        background: var(--bg);
        padding: 14px 16px;
      }
      .example-half .label {
        font-family: "Geist Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        display: block;
        margin-bottom: 8px;
      }
      .example-half.bad .label { color: oklch(0.55 0.14 24); }
      .example-half.good .label { color: oklch(0.50 0.14 150); }
      .example-half p {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12.5px;
        line-height: 1.65;
        color: var(--ink-2);
      }
      @media (max-width: 640px) {
        .example-pair { grid-template-columns: 1fr; }
        .practice { grid-template-columns: 1fr; gap: 8px; }
      }

      /* Layer decisions */
      .decision-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1px;
        background: var(--hairline);
        border: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .decision-card {
        background: var(--bg);
        padding: 28px;
        display: flex;
        flex-direction: column;
        gap: 14px;
      }
      .decision-card h3 {
        font-size: 18px;
        font-weight: 500;
        letter-spacing: -0.015em;
        line-height: 1.3;
      }
      .decision-card p {
        font-size: 14.5px;
        color: var(--ink-2);
        line-height: 1.6;
      }
      .decision-card .avoid {
        padding-top: 14px;
        border-top: 1px solid var(--hairline);
        color: var(--muted);
      }
      @media (max-width: 700px) { .decision-grid { grid-template-columns: 1fr; } }

      /* Tips */
      .tips-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 0;
        border-top: 1px solid var(--hairline);
        margin-top: 48px;
      }
      .tip-item {
        padding: 32px 32px 32px 0;
        border-bottom: 1px solid var(--hairline);
        display: flex;
        flex-direction: column;
        gap: 10px;
      }
      .tip-item:nth-child(even) {
        padding-left: 32px;
        border-left: 1px solid var(--hairline);
        padding-right: 0;
      }
      .tip-item h3 { font-size: 18px; font-weight: 500; letter-spacing: -0.015em; line-height: 1.3; }
      .tip-item p { font-size: 14.5px; color: var(--ink-2); line-height: 1.55; }
      @media (max-width: 640px) {
        .tips-grid { grid-template-columns: 1fr; }
        .tip-item { padding: 28px 0 !important; border-left: none !important; }
      }

      /* CTA block */
      .cta-block {
        padding: 64px 0;
        border-top: 1px solid var(--hairline);
        border-bottom: 1px solid var(--hairline);
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 40px;
        align-items: end;
      }
      .cta-block .btns { display: flex; gap: 12px; flex-wrap: wrap; align-items: center; }
      @media (max-width: 720px) { .cta-block { grid-template-columns: 1fr; gap: 24px; } }
    </style>
  </head>

  <body>

    <SiteHeader />

    <nav class="pm-subnav">
      <div class="wrap">
        <div class="pm-subnav-inner">
          <span class="pm-subnav-brand">PromptMate</span>
          <div class="pm-subnav-links">
            <a href="/promptmate">Overview</a>
            <a href="/promptmate/getting-started">Getting started</a>
            <a href="/promptmate/best-practices" class="active">Best practices</a>
            <a href="/promptmate/starter-prompts">Starter prompts</a>
            <a href="/promptmate/whats-new">What's new</a>
          </div>
        </div>
      </div>
    </nav>

    <main>

      <!-- HERO -->
      <section class="page-hero">
        <div class="wrap reveal">
          <span class="eyebrow">PromptMate · Best practices</span>
          <h1 class="display" style="margin-top: 16px;">
            Write prompts<br />worth saving.
          </h1>
          <p class="lede" style="margin-top: 24px;">
            The difference between a library you use daily and one you abandon after a week comes down to how the prompts are written. Six rules that make the difference.
          </p>
          <div style="display: flex; gap: 12px; flex-wrap: wrap; margin-top: 32px;">
            <a class="btn" href="/promptmate/starter-prompts">
              Browse starter prompts
              <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
            </a>
            <a class="btn" href="/promptmate/getting-started">
              <svg style="width:14px;height:14px;" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M11 7H3M6.5 3.5L3 7l3.5 3.5"/></svg>
              Back to getting started
            </a>
          </div>
        </div>
      </section>

      <!-- PRACTICES -->
      <section class="tight hairline-t">
        <div class="wrap">
          <div class="reveal">
            <span class="eyebrow">Six rules</span>
            <h2 class="h2" style="margin-top: 16px;">What separates prompts that stick from ones that rot.</h2>
            <p class="lede" style="margin-top: 12px;">
              These aren't theoretical. They come from the patterns that actually make prompts reusable across sessions — the difference between a library you open every day and one you forget about.
            </p>
          </div>
          <div class="practice-list">
            {practices.map((p) => (
              <div class="practice reveal">
                <span class="num">{p.number}</span>
                <div>
                  <h3>{p.heading}</h3>
                  <p>{p.body}</p>
                  <div class="ask">{p.ask}</div>
                  <div class="example-pair">
                    <div class="example-half bad">
                      <span class="label">Less effective</span>
                      <p>{p.example.bad}</p>
                    </div>
                    <div class="example-half good">
                      <span class="label">Better</span>
                      <p>{p.example.good}</p>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- LAYER DECISIONS -->
      <section class="tight hairline-t">
        <div class="wrap">
          <div class="reveal">
            <span class="eyebrow">Library design</span>
            <h2 class="h2" style="margin-top: 16px;">Put each instruction in the right place.</h2>
            <p class="lede" style="margin-top: 12px;">
              A prompt library gets easier to use when repeated context moves up a level and the saved prompt stays focused on the task.
            </p>
          </div>
          <div class="decision-grid">
            {layerDecisions.map((item) => (
              <div class="decision-card reveal">
                <h3>{item.label}</h3>
                <p>{item.use}</p>
                <p class="avoid">{item.avoid}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- TIPS -->
      <section class="tight hairline-t">
        <div class="wrap">
          <div class="reveal">
            <span class="eyebrow">Habits</span>
            <h2 class="h2" style="margin-top: 16px;">Build a library that sticks.</h2>
            <p class="lede" style="margin-top: 12px;">Small patterns that make PromptMate worth keeping open every session.</p>
          </div>
          <div class="tips-grid">
            {tips.map((tip) => (
              <div class="tip-item reveal">
                <h3>{tip.heading}</h3>
                <p>{tip.body}</p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <section class="tight">
        <div class="wrap">
          <div class="cta-block reveal">
            <div>
              <span class="eyebrow">Ready to build?</span>
              <h2 class="h2" style="margin-top: 14px;">See the rules in practice.</h2>
              <p class="body" style="margin-top: 12px; max-width: 52ch;">
                The starter prompts page has copy-ready examples that follow all six rules. Add them to your library and adapt them to your workflow.
              </p>
            </div>
            <div class="btns">
              <a class="btn primary" href="/promptmate/starter-prompts">
                Starter prompts
                <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
              </a>
              <a
                class="btn"
                href="https://chromewebstore.google.com/detail/promptmate/oknglgpcglngpaobpjndcaaljdchmgai"
                target="_blank"
                rel="noopener noreferrer"
              >
                Install PromptMate
              </a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="grid">
          <div>
            <a href="/" style="display:inline-block; margin-bottom: 14px;">
              <img src="/JitanGupta%20Logo.png" alt="Jitan Gupta" style="height:44px;width:auto;display:block;mix-blend-mode:multiply;" />
            </a>
            <p class="body" style="font-size:14.5px; max-width: 42ch; margin-top: 12px;">
              Engineer building AI infrastructure and developer tooling, in public. Mumbai, India.
            </p>
          </div>
          <div>
            <h4>PromptMate</h4>
            <ul>
              <li><a href="/promptmate">Overview</a></li>
              <li><a href="/promptmate/getting-started">Getting started</a></li>
              <li><a href="/promptmate/best-practices">Best practices</a></li>
              <li><a href="/promptmate/starter-prompts">Starter prompts</a></li>
              <li><a href="/promptmate/whats-new">What's new</a></li>
            </ul>
          </div>
          <div>
            <h4>Elsewhere</h4>
            <ul>
              <li><a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
