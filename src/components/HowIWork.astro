          <circle cx="250" cy="295" r="2" fill="#00d4ff" opacity="0.5"></circle>
          <circle cx="285" cy="295" r="2" fill="#00d4ff" opacity="0.7"></circle>
        </g>

        <!-- PHASE 2: THE WORK -->
        <g id="phase-2" class="animate-fade" transform="translate(410, 295)">
          <g>
            <polygon
              points="0,-75 65,-37 65,37 0,75 -65,37 -65,-37"
              fill="url(#cyanGlow2)"
              stroke="#00d4ff"
              stroke-width="1.5"
              filter="url(#softGlow2)"></polygon>
            <g stroke="#00d4ff" stroke-width="0.8" opacity="0.5">
              <line x1="-35" y1="-25" x2="35" y2="-25"></line>
              <line x1="-35" y1="0" x2="35" y2="0"></line>
              <line x1="-35" y1="25" x2="35" y2="25"></line>
              <line x1="-17" y1="-45" x2="-17" y2="45"></line>
              <line x1="17" y1="-45" x2="17" y2="45"></line>
            </g>
            <circle cx="-17" cy="-25" r="4" fill="#00d4ff" opacity="0.7"
            ></circle>
            <circle cx="17" cy="-25" r="4" fill="#00d4ff" opacity="0.7"
            ></circle>
            <circle cx="-17" cy="0" r="5" fill="#00d4ff" opacity="0.9"></circle>
            <circle cx="17" cy="0" r="5" fill="#00d4ff" opacity="0.9"></circle>
            <circle cx="-17" cy="25" r="4" fill="#00d4ff" opacity="0.7"
            ></circle>
            <circle cx="17" cy="25" r="4" fill="#00d4ff" opacity="0.7"></circle>
          </g>
          <g>
            <text
              x="0"
              y="120"
              text-anchor="middle"
              fill="#00d4ff"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="11"
              font-weight="600"
              letter-spacing="1">ARCHITECTURE &amp; MIGRATION</text
            >
            <text
              x="0"
              y="140"
              text-anchor="middle"
              fill="#0891b2"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Platform design</text
            >
            <text
              x="0"
              y="154"
              text-anchor="middle"
              fill="#0891b2"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Migration planning</text
            >
            <text
              x="0"
              y="168"
              text-anchor="middle"
              fill="#0891b2"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Tooling setup</text
            >
          </g>
        </g>

        <!-- ARROW 2 -->
        <g id="arrow-2" class="arrow animate-fade">
          <line
            x1="510"
            y1="295"
            x2="600"
            y2="295"
            stroke="#8b5cf6"
            stroke-width="2"
            stroke-dasharray="6,3"
            marker-end="url(#arrowPurple2)"
            opacity="0.7"></line>
          <circle cx="535" cy="295" r="2" fill="#8b5cf6" opacity="0.5"></circle>
          <circle cx="570" cy="295" r="2" fill="#8b5cf6" opacity="0.7"></circle>
        </g>

        <!-- PHASE 3: THE OUTCOME -->
        <g id="phase-3" class="animate-fade" transform="translate(700, 295)">
          <g>
            <rect
