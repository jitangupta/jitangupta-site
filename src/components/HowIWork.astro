        </g>
      </svg>
    </div>
  </div>
</section>

<style>
  /* Process Hero Animations */
  #process-hero .animate-fade {
    opacity: 0;
    transition: opacity 0.6s ease-out;
  }

  #process-hero .arrow line {
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 0.5s ease-out;
  }

  #process-hero #feedback-path {
    stroke-dasharray: 1200;
    stroke-dashoffset: 1200;
    transition: stroke-dashoffset 1s ease-out;
  }

  #process-hero.animate .animate-fade {
    opacity: 1;
  }

  #process-hero.animate .arrow line {
    stroke-dashoffset: 0;
  }

  #process-hero.animate #feedback-path {
    stroke-dashoffset: 0;
  }

  #process-hero.animate #phase-1 {
    transition-delay: 0s;
  }
  #process-hero.animate #arrow-1 {
    transition-delay: 0.4s;
  }
  #process-hero.animate #arrow-1 line {
    transition-delay: 0.4s;
  }
  #process-hero.animate #phase-2 {
    transition-delay: 0.6s;
  }
  #process-hero.animate #arrow-2 {
    transition-delay: 0.85s;
  }
  #process-hero.animate #arrow-2 line {
    transition-delay: 0.85s;
  }
  #process-hero.animate #phase-3 {
    transition-delay: 1.05s;
  }
  #process-hero.animate #arrow-3 {
    transition-delay: 1.3s;
  }
  #process-hero.animate #arrow-3 line {
    transition-delay: 1.3s;
  }
  #process-hero.animate #phase-4 {
    transition-delay: 1.5s;
  }
  #process-hero.animate #feedback-loop {
    transition-delay: 1.8s;
  }
  #process-hero.animate #feedback-path {
    transition-delay: 1.8s;
  }

  @media (prefers-reduced-motion: reduce) {
    #process-hero .animate-fade {
      transition: none !important;
      opacity: 1 !important;
    }

    #process-hero .arrow line,
    #process-hero #feedback-path {
      transition: none !important;
      stroke-dashoffset: 0 !important;
    }
  }
</style>

<script>
  // Intersection observer for the Process SVG animation
  const processObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const svg = entry.target.querySelector("svg");
          if (svg) {
            setTimeout(() => svg.classList.add("animate"), 150);
          }
        }
      });
    },
    { threshold: 0.25 },
  );

  const processContainer = document.getElementById("container-process");
  if (processContainer) {
    processObserver.observe(processContainer);
  }
</script>
