---

---

<section id="how-i-work" class="py-24 bg-card-dark">
  <div class="container-custom">
    <div class="text-center mb-16">
      <span
        class="inline-block px-3 py-1 mb-4 border border-accent-cyan/30 rounded-full bg-accent-cyan/10 backdrop-blur-sm text-xs font-mono text-accent-cyan tracking-widest uppercase"
        >My Process</span
      >
      <h2 class="text-3xl md:text-4xl font-bold mb-4">How We Work Together</h2>
      <p class="text-muted max-w-2xl mx-auto">
        From chaos to continuous improvement
      </p>
    </div>

    <div
      class="svg-container max-w-6xl mx-auto"
      id="container-process"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 80 1200 520"
        id="process-hero"
        class="w-full h-auto"
      >
        <defs>
          <linearGradient id="bgGrad2" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#0a0a0f"></stop>
            <stop offset="50%" stop-color="#0d0d14"></stop>
            <stop offset="100%" stop-color="#0a0a0f"></stop>
          </linearGradient>

          <linearGradient id="cyanGlow2" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#00d4ff" stop-opacity="0.3"></stop>
            <stop offset="100%" stop-color="#00d4ff" stop-opacity="0.08"></stop>
          </linearGradient>

          <linearGradient id="purpleGlow2" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.3"></stop>
            <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.08"></stop>
          </linearGradient>

          <linearGradient id="greenGlow2" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#10b981" stop-opacity="0.3"></stop>
            <stop offset="100%" stop-color="#10b981" stop-opacity="0.08"></stop>
          </linearGradient>

          <filter id="softGlow2" x="-50%" y="-50%" width="200%" height="200%">
            <feGaussianBlur stdDeviation="6" result="blur"></feGaussianBlur>
            <feMerge>
              <feMergeNode in="blur"></feMergeNode>
              <feMergeNode in="SourceGraphic"></feMergeNode>
            </feMerge>
          </filter>

          <pattern
            id="grid2"
            width="40"
            height="40"
            patternUnits="userSpaceOnUse"
          >
            <path
              d="M 40 0 L 0 0 0 40"
              fill="none"
              stroke="#1a1a2e"
              stroke-width="0.5"></path>
          </pattern>

          <marker
            id="arrowCyan2"
            markerWidth="8"
            markerHeight="8"
            refX="7"
            refY="3"
            orient="auto"
          >
            <path d="M0,0 L0,6 L8,3 z" fill="#00d4ff"></path>
          </marker>

          <marker
            id="arrowPurple2"
            markerWidth="8"
            markerHeight="8"
            refX="7"
            refY="3"
            orient="auto"
          >
            <path d="M0,0 L0,6 L8,3 z" fill="#8b5cf6"></path>
          </marker>

          <marker
            id="arrowGreen2"
            markerWidth="8"
            markerHeight="8"
            refX="7"
            refY="3"
            orient="auto"
          >
            <path d="M0,0 L0,6 L8,3 z" fill="#10b981"></path>
          </marker>
        </defs>

        <!-- Background removed for transparency -->


        <!-- PHASE 1: THE CHALLENGE -->
        <g id="phase-1" class="animate-fade" transform="translate(130, 295)">
          <g>
            <rect
              x="-50"
              y="-70"
              width="36"
              height="26"
              fill="none"
              stroke="#4b5563"
              stroke-width="1"
              transform="rotate(-12)"
              opacity="0.5"></rect>
            <rect
              x="15"
              y="-75"
              width="32"
              height="22"
              fill="none"
              stroke="#4b5563"
              stroke-width="1"
              transform="rotate(8)"
              opacity="0.4"></rect>
            <rect
              x="-35"
              y="25"
              width="40"
              height="24"
              fill="none"
              stroke="#4b5563"
              stroke-width="1"
              transform="rotate(-6)"
              opacity="0.5"></rect>
            <rect
              x="20"
              y="40"
              width="34"
              height="20"
              fill="none"
              stroke="#4b5563"
              stroke-width="1"
              transform="rotate(4)"
              opacity="0.4"></rect>
            <rect
              x="-15"
              y="-25"
              width="44"
              height="30"
              fill="none"
              stroke="#4b5563"
              stroke-width="1"
              transform="rotate(2)"
              opacity="0.55"></rect>
            <text
              x="-40"
              y="-45"
              fill="#4b5563"
              font-family="system-ui, sans-serif"
              font-size="14"
              opacity="0.5">?</text
            >
            <text
              x="35"
              y="-50"
              fill="#4b5563"
              font-family="system-ui, sans-serif"
              font-size="12"
              opacity="0.4">?</text
            >
            <text
              x="45"
              y="35"
              fill="#4b5563"
              font-family="system-ui, sans-serif"
              font-size="11"
              opacity="0.45">?</text
            >
            <circle cx="-25" cy="55" r="2.5" fill="#4b5563" opacity="0.4"
            ></circle>
            <circle cx="50" cy="-35" r="2" fill="#4b5563" opacity="0.45"
            ></circle>
          </g>
          <g>
            <text
              x="0"
              y="120"
              text-anchor="middle"
              fill="#6b7280"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="11"
              font-weight="600"
              letter-spacing="1">YOUR CURRENT STATE</text
            >
            <text
              x="0"
              y="140"
              text-anchor="middle"
              fill="#4b5563"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Scattered systems</text
            >
            <text
              x="0"
              y="154"
              text-anchor="middle"
              fill="#4b5563"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Tribal knowledge</text
            >
            <text
              x="0"
              y="168"
              text-anchor="middle"
              fill="#4b5563"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Deployment fear</text
            >
          </g>
        </g>

        <!-- ARROW 1 -->
        <g id="arrow-1" class="arrow animate-fade">
          <line
            x1="225"
            y1="295"
            x2="315"
            y2="295"
            stroke="#00d4ff"
