              y="-75"
              width="130"
              height="150"
              rx="6"
              fill="url(#purpleGlow2)"
              stroke="#8b5cf6"
              stroke-width="1.5"
              filter="url(#softGlow2)"></rect>
            <g>
              <rect
                x="-50"
                y="-60"
                width="32"
                height="22"
                rx="3"
                fill="#141420"
                stroke="#8b5cf6"
                stroke-width="0.8"></rect>
              <rect
                x="-10"
                y="-60"
                width="32"
                height="22"
                rx="3"
                fill="#141420"
                stroke="#8b5cf6"
                stroke-width="0.8"></rect>
              <rect
                x="-50"
                y="-28"
                width="32"
                height="22"
                rx="3"
                fill="#141420"
                stroke="#8b5cf6"
                stroke-width="0.8"></rect>
              <rect
                x="-10"
                y="-28"
                width="32"
                height="22"
                rx="3"
                fill="#141420"
                stroke="#8b5cf6"
                stroke-width="0.8"></rect>
              <rect
                x="-50"
                y="4"
                width="32"
                height="22"
                rx="3"
                fill="#141420"
                stroke="#8b5cf6"
                stroke-width="0.8"></rect>
              <rect
                x="-10"
                y="4"
                width="32"
                height="22"
                rx="3"
                fill="#141420"
                stroke="#8b5cf6"
                stroke-width="0.8"></rect>
            </g>
            <circle cx="-40" cy="-49" r="2.5" fill="#10b981"></circle>
            <circle cx="0" cy="-49" r="2.5" fill="#10b981"></circle>
            <circle cx="-40" cy="-17" r="2.5" fill="#10b981"></circle>
            <circle cx="0" cy="-17" r="2.5" fill="#10b981"></circle>
            <circle cx="-40" cy="15" r="2.5" fill="#10b981"></circle>
            <circle cx="0" cy="15" r="2.5" fill="#10b981"></circle>
            <g transform="translate(35, -42)">
              <rect
                width="18"
                height="24"
                rx="2"
                fill="none"
                stroke="#8b5cf6"
                stroke-width="1.2"></rect>
              <line
                x1="4"
                y1="7"
                x2="14"
                y2="7"
                stroke="#8b5cf6"
                stroke-width="0.8"></line>
              <line
                x1="4"
                y1="12"
                x2="14"
                y2="12"
                stroke="#8b5cf6"
                stroke-width="0.8"></line>
              <line
                x1="4"
                y1="17"
                x2="10"
                y2="17"
                stroke="#8b5cf6"
                stroke-width="0.8"></line>
            </g>
            <g transform="translate(35, 8)">
              <circle
                cx="4"
                cy="4"
                r="3.5"
                fill="none"
                stroke="#8b5cf6"
                stroke-width="1.2"></circle>
              <circle
                cx="14"
                cy="4"
                r="3.5"
                fill="none"
                stroke="#8b5cf6"
                stroke-width="1.2"></circle>
              <path
                d="M0 18 Q4 11 9 18"
                fill="none"
                stroke="#8b5cf6"
                stroke-width="1.2"></path>
              <path
                d="M9 18 Q14 11 18 18"
                fill="none"
                stroke="#8b5cf6"
                stroke-width="1.2"></path>
            </g>
          </g>
          <g>
            <text
              x="0"
              y="120"
              text-anchor="middle"
              fill="#8b5cf6"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="11"
              font-weight="600"
              letter-spacing="1">PRODUCTION + HANDOFF</text
            >
            <text
              x="0"
              y="140"
              text-anchor="middle"
              fill="#7c3aed"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Running in prod</text
            >
            <text
              x="0"
              y="154"
              text-anchor="middle"
              fill="#7c3aed"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Docs complete</text
            >
            <text
              x="0"
              y="168"
              text-anchor="middle"
              fill="#7c3aed"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Team trained</text
            >
          </g>
        </g>

        <!-- ARROW 3 -->
        <g id="arrow-3" class="arrow animate-fade">
          <line
            x1="800"
            y1="295"
            x2="890"
            y2="295"
            stroke="#10b981"
            stroke-width="2"
            stroke-dasharray="6,3"
            marker-end="url(#arrowGreen2)"
            opacity="0.7"></line>
          <circle cx="825" cy="295" r="2" fill="#10b981" opacity="0.5"></circle>
          <circle cx="860" cy="295" r="2" fill="#10b981" opacity="0.7"></circle>
        </g>

        <!-- PHASE 4: THE LOOP -->
        <g id="phase-4" class="animate-fade" transform="translate(990, 295)">
          <g>
            <circle
              cx="0"
              cy="0"
              r="65"
              fill="url(#greenGlow2)"
              stroke="#10b981"
              stroke-width="1.5"
              filter="url(#softGlow2)"></circle>

            <!-- Circular arrows -->
            <path
              d="M 35 -30 A 40 40 0 0 1 35 30"
              fill="none"
              stroke="#10b981"
              stroke-width="1.5"
              stroke-dasharray="4,2"></path>
            <path
              d="M0,0 L-6,-3 L-6,3 Z"
              fill="#10b981"
              transform="translate(35, 30) rotate(138)"></path>

            <path
              d="M -35 30 A 40 40 0 0 1 -35 -30"
              fill="none"
              stroke="#10b981"
              stroke-width="1.5"
              stroke-dasharray="4,2"></path>
            <path
              d="M0,0 L-6,-3 L-6,3 Z"
              fill="#10b981"
              transform="translate(-35, -30) rotate(-42)"></path>

            <!-- Metrics chart in center -->
            <g transform="translate(-22, -18)">
              <rect
                x="0"
                y="18"
                width="7"
                height="18"
                fill="#10b981"
                opacity="0.5"></rect>
              <rect
                x="12"
