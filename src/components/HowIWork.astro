              y="154"
              text-anchor="middle"
              fill="#059669"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Issues caught early</text
            >
            <text
              x="0"
              y="168"
              text-anchor="middle"
              fill="#059669"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="9">Continuous tuning</text
            >
          </g>
        </g>

        <!-- FEEDBACK LOOP -->
        <g id="feedback-loop" class="animate-fade">
          <path
            id="feedback-path"
            d="M 950 380 Q 550 520 130 380"
            fill="none"
            stroke="#10b981"
            stroke-width="1.2"
            stroke-dasharray="5,3"
            opacity="0.35"></path>
          <path
            d="M0,0 L-8,-4 L-8,4 Z"
