---
---

<section id="services" class="py-24 bg-primary-dark">
  <div class="container-custom">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Problems I Solve</h2>
      <p class="text-muted max-w-2xl mx-auto">Real challenges SaaS platforms face when scaling multi-tenant infrastructure.</p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Service 1 -->
      <div class="group p-8 rounded-2xl bg-card border border-subtle hover:border-accent-cyan/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-cyan/10 hover:-translate-y-1 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-cyan/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 mb-6 rounded-xl bg-accent-cyan/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <img src="/images/icon-k8s.png" alt="Kubernetes" class="w-8 h-8 object-contain" />
        </div>
        <h3 class="text-xl font-bold text-white mb-4 group-hover:text-accent-cyan transition-colors">Tenant Version Chaos</h3>
        <ul class="space-y-3 text-muted">
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Your enterprise customers need independent versions</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Compliance requires tenant isolation</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Standard K8s doesn't support this out of the box</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span class="font-semibold text-white">→ I design multi-tenant architectures that scale</span>
          </li>
        </ul>
      </div>

      <!-- Service 2 -->
      <div class="group p-8 rounded-2xl bg-card border border-subtle hover:border-accent-cyan/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-cyan/10 hover:-translate-y-1 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-cyan/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 mb-6 rounded-xl bg-accent-cyan/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <img src="/images/icon-ai.png" alt="AI Ops" class="w-8 h-8 object-contain" />
        </div>
        <h3 class="text-xl font-bold text-white mb-4 group-hover:text-accent-cyan transition-colors">Deployment Nightmares</h3>
        <ul class="space-y-3 text-muted">
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Manual deployments taking hours</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Incidents during releases</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>No visibility into what changed</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span class="font-semibold text-white">→ I build AI-powered deployment orchestration</span>
          </li>
        </ul>
      </div>

      <!-- Service 3 -->
      <div class="group p-8 rounded-2xl bg-card border border-subtle hover:border-accent-cyan/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-cyan/10 hover:-translate-y-1 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-cyan/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 mb-6 rounded-xl bg-accent-cyan/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <img src="/images/icon-docs.png" alt="Documentation" class="w-8 h-8 object-contain" />
        </div>
        <h3 class="text-xl font-bold text-white mb-4 group-hover:text-accent-cyan transition-colors">Knowledge Trapped in Heads</h3>
        <ul class="space-y-3 text-muted">
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Only one person knows how it works</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>No runbooks, no documentation</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Fear of that person leaving</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span class="font-semibold text-white">→ I document everything and train your team</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
