---
---

<section id="services" class="py-24 bg-primary-dark">
  <div class="container-custom">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">What I Build</h2>
      <p class="text-muted max-w-2xl mx-auto">Specialized expertise in cloud infrastructure, AI-native systems, and scalable .NET platforms.</p>
    </div>
    
    <div class="grid md:grid-cols-3 gap-8">
      <!-- Service 1 -->
      <div class="group p-8 rounded-2xl bg-card border border-subtle hover:border-accent-cyan/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-cyan/10 hover:-translate-y-1 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-cyan/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 mb-6 rounded-xl bg-accent-cyan/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <img src="/images/icon-k8s.png" alt="Kubernetes" class="w-8 h-8 object-contain" />
        </div>
        <h3 class="text-xl font-bold text-white mb-4 group-hover:text-accent-cyan transition-colors">Multi-Tenant Kubernetes</h3>
        <ul class="space-y-3 text-muted">
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>AKS cluster design and migration</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Tenant isolation with namespace strategies</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>YARP reverse proxy routing</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>GitOps with ArgoCD and Helm</span>
          </li>
        </ul>
      </div>

      <!-- Service 2 -->
      <div class="group p-8 rounded-2xl bg-card border border-subtle hover:border-accent-cyan/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-cyan/10 hover:-translate-y-1 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-cyan/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 mb-6 rounded-xl bg-accent-cyan/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <img src="/images/icon-ai.png" alt="AI Ops" class="w-8 h-8 object-contain" />
        </div>
        <h3 class="text-xl font-bold text-white mb-4 group-hover:text-accent-cyan transition-colors">AI-Native Infrastructure</h3>
        <ul class="space-y-3 text-muted">
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>RAG pipelines for intelligent systems</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>LLMOps and prompt engineering</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Azure AI Foundry integrations</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Vector databases (Qdrant, Azure AI Search)</span>
          </li>
        </ul>
      </div>

      <!-- Service 3 -->
      <div class="group p-8 rounded-2xl bg-card border border-subtle hover:border-accent-cyan/50 transition-all duration-300 hover:shadow-lg hover:shadow-accent-cyan/10 hover:-translate-y-1 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-cyan/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
        <div class="w-14 h-14 mb-6 rounded-xl bg-accent-cyan/10 flex items-center justify-center group-hover:scale-110 transition-transform duration-300">
          <img src="/images/icon-docs.png" alt="Documentation" class="w-8 h-8 object-contain" />
        </div>
        <h3 class="text-xl font-bold text-white mb-4 group-hover:text-accent-cyan transition-colors">.NET & Backend Systems</h3>
        <ul class="space-y-3 text-muted">
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Microservices architecture with .NET Core</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>ASP.NET Identity and authentication</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>RESTful and gRPC APIs</span>
          </li>
          <li class="flex items-start gap-3">
            <span class="text-accent-cyan mt-1">▹</span>
            <span>Event-driven systems with message queues</span>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>
