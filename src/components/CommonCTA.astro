---
const paths = [
  {
    label: "Videos",
    href: "https://www.youtube.com/@jitangupta",
    external: true,
    title: "Start with the experiments",
    description: "Claude Code, MCP servers, and agent workflows tested in real engineering contexts.",
  },
  {
    label: "Builds",
    href: "/builds",
    title: "Inspect the tools",
    description: "Open source projects that came from solving actual workflow problems.",
  },
  {
    label: "Frameworks",
    href: "/frameworks",
    title: "Reuse the checks",
    description: "Practical checklists and mental models shaped from repeated AI tool work.",
  },
];
---

<section class="bg-canvas px-6 py-16">
  <div class="mx-auto max-w-screen-xl border-t border-slate-200 pt-12">
    <div class="grid gap-10 lg:grid-cols-[0.9fr_1.4fr] lg:items-start">
      <div>
        <p class="section-label mb-3">Follow the work</p>
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
          The useful parts live across videos, builds, and frameworks.
        </h2>
        <p class="text-gray-600 leading-relaxed max-w-xl">
          Start wherever you think best: watch the experiments, inspect the artifacts, or reuse the checks in your own workflow.
        </p>
      </div>

      <div class="grid gap-3 md:grid-cols-3">
        {paths.map((path) => (
          <a
            href={path.href}
            target={path.external ? "_blank" : undefined}
            rel={path.external ? "noopener noreferrer" : undefined}
            class="group rounded-lg border border-slate-200 bg-white p-5 transition duration-200 hover:-translate-y-1 hover:border-primary-300 hover:shadow-lg"
          >
            <p class="text-xs font-semibold uppercase tracking-widest text-primary-600 mb-4">{path.label}</p>
            <h3 class="text-lg font-semibold text-gray-900 mb-2 group-hover:text-primary-700 transition-colors">
              {path.title}
            </h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-5">{path.description}</p>
            <span class="inline-flex items-center gap-1 text-sm font-semibold text-primary-600 group-hover:gap-2 transition-all">
              Open
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
