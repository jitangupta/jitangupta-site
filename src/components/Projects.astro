---
---

<section id="projects" class="py-24 bg-primary-dark">
  <div class="container-custom">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold mb-4">Recent Work</h2>
      <p class="text-muted max-w-2xl mx-auto">Solving complex infrastructure challenges with modern solutions.</p>
    </div>
    
    <div class="space-y-20">
      
      <!-- Project 1 -->
      <a href="/case-studies/probabilistic-deployment-orchestration" class="group relative grid md:grid-cols-12 gap-8 items-center block">
        <!-- Content -->
        <div class="md:col-span-7 md:pr-8 order-2 md:order-1">
          <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent-cyan transition-colors">AI-Powered Release Orchestration for Multi-Tenant SaaS</h3>
          <p class="text-muted mb-6 text-lg leading-relaxed">
            Intelligent deployment system using probabilistic reasoning to decide which tenants need upgrades. Analyzes Jira tickets + tenant usage via RAG. Saves $17K annually, reduces incidents 50%, cuts planning from 2 hours to 10 minutes.
          </p>
          
          <div class="flex flex-wrap gap-2 mb-8">
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">Azure AI Foundry</span>
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">Qdrant</span>
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">.NET Core</span>
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">Docker</span>
          </div>
          
          <div class="flex items-center gap-4">
             <div class="h-px bg-white/10 flex-grow"></div>
             <span class="text-xs text-accent-cyan font-mono flex items-center gap-2">
               READ CASE STUDY
               <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
             </span>
          </div>
        </div>
        
        <!-- Visual -->
        <div class="md:col-span-5 order-1 md:order-2">
          <div class="aspect-video bg-card-dark rounded-xl border border-white/10 flex items-center justify-center relative overflow-hidden group-hover:shadow-2xl group-hover:shadow-accent-cyan/20 transition-all duration-500">
             <img src="/images/RAG Powered Recommendation Engine.png" alt="RAG Recommendation Engine Architecture" class="w-full h-full object-contain p-2" />
          </div>
        </div>
      </a>

      <!-- Project 2 -->
      <a href="/case-studies/multi-tenant-aks-migration" class="group relative grid md:grid-cols-12 gap-8 items-center block">
        <!-- Visual -->
        <div class="md:col-span-5">
          <div class="aspect-video bg-card-dark rounded-xl border border-white/10 flex items-center justify-center relative overflow-hidden group-hover:shadow-2xl group-hover:shadow-accent-cyan/20 transition-all duration-500">
             <img src="/images/multi-tenant-app-design.png" alt="Multi-Tenant Architecture" class="w-full h-full object-contain p-2" />
          </div>
        </div>

        <!-- Content -->
        <div class="md:col-span-7 md:pl-8">
          <h3 class="text-2xl font-bold text-white mb-4 group-hover:text-accent-cyan transition-colors">Multi-Tenant Kubernetes Migration: Solving the Version Lock-In Problem</h3>
          <p class="text-muted mb-6 text-lg leading-relaxed">
            How to support independent tenant versions in Kubernetes. Real AKS migration case study: 22% cost reduction, 30-min onboarding, zero-downtime upgrades with YARP routing.
          </p>
          
          <div class="flex flex-wrap gap-2 mb-8">
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">AKS</span>
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">AGIC</span>
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">YARP</span>
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">Helm</span>
            <span class="px-3 py-1 bg-white/5 text-gray-300 text-xs font-mono rounded-full border border-white/10">ArgoCD</span>
          </div>
          
          <div class="flex items-center gap-4">
             <div class="h-px bg-white/10 flex-grow"></div>
             <span class="text-xs text-accent-cyan font-mono flex items-center gap-2">
               READ CASE STUDY
               <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
             </span>
          </div>
        </div>
      </a>

    </div>
    
    <!-- View All Link -->
    <div class="text-center mt-12">
      <a href="/case-studies" class="inline-flex items-center gap-2 px-6 py-3 bg-card-dark border border-white/10 hover:border-white/30 text-gray-300 hover:text-white font-medium rounded-lg transition-all duration-300 hover:-translate-y-1">
        <span>View All Case Studies</span>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </a>
    </div>
  </div>
</section>

<style>
  .bg-grid-pattern {
    background-image: radial-gradient(rgba(255, 255, 255, 0.1) 1px, transparent 1px);
    background-size: 20px 20px;
  }
</style>
