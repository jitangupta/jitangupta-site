---
// Hero animation for /services/build-along-session.
// Shape of the engagement: blank canvas -> outer frame draws -> content fills
// -> a working button appears -> a live status indicator starts pulsing.
// Story: "we build your tool, it ships by end of day, it keeps running."
// The build sequence runs once. The live pulse loops (functional: shows the
// shipped thing is still running).
// prefers-reduced-motion: end state, no animation.
---

<div class="ba" aria-hidden="true">
	<svg viewBox="0 0 600 220" xmlns="http://www.w3.org/2000/svg" class="ba-svg">
		<!-- Outer frame: the app/tool window -->
		<rect class="ba-frame" x="140" y="40" width="320" height="140" rx="10" />

		<!-- Header divider line -->
		<line class="ba-header" x1="148" y1="68" x2="452" y2="68" />

		<!-- Content lines (representing rows of content/data) -->
		<line class="ba-line ba-line-1" x1="160" y1="92" x2="380" y2="92" />
		<line class="ba-line ba-line-2" x1="160" y1="112" x2="420" y2="112" />
		<line class="ba-line ba-line-3" x1="160" y1="132" x2="340" y2="132" />

		<!-- CTA button (the working action) -->
		<g class="ba-cta-group">
			<rect class="ba-cta" x="160" y="148" width="80" height="22" rx="6" />
			<text class="ba-cta-text" x="200" y="163" text-anchor="middle">Ship</text>
		</g>

		<!-- Live status indicator (top-right corner of the frame) -->
		<g class="ba-live">
			<circle class="ba-live-pulse" cx="440" cy="55" r="4.5" />
			<circle class="ba-live-dot" cx="440" cy="55" r="3.5" />
		</g>

		<!-- Caption -->
		<text class="ba-caption" x="300" y="205" text-anchor="middle">Working by end of day</text>
	</svg>
</div>

<style>
	.ba {
		--ba-stroke: #477056;
		--ba-fill-bg: #ffffff;
		--ba-text: #475569;
		--ba-cta-bg: #477056;
		--ba-cta-text: #ffffff;
		--ba-live: #588B67;
		width: 100%;
		max-width: 560px;
		margin: 0 auto;
	}

	.ba-svg {
		width: 100%;
		height: auto;
		display: block;
	}

	/* Outer frame: drawn via stroke-dashoffset */
	.ba-frame {
		fill: var(--ba-fill-bg);
		stroke: var(--ba-stroke);
		stroke-width: 2;
		stroke-linejoin: round;
		stroke-dasharray: 920;
		stroke-dashoffset: 920;
	}

	.ba-header {
		stroke: var(--ba-stroke);
		stroke-width: 1.5;
		stroke-linecap: round;
		opacity: 0.35;
		stroke-dasharray: 304;
		stroke-dashoffset: 304;
	}

	.ba-line {
		stroke: var(--ba-stroke);
		stroke-width: 2;
		stroke-linecap: round;
		opacity: 0.55;
		stroke-dasharray: 280;
		stroke-dashoffset: 280;
	}

	.ba-cta-group {
		opacity: 0;
		transform: scale(0.85);
		transform-box: fill-box;
		transform-origin: center;
		transition:
			opacity 0.45s ease-out,
			transform 0.55s cubic-bezier(0.34, 1.2, 0.64, 1);
	}

	.ba-cta {
		fill: var(--ba-cta-bg);
	}

	.ba-cta-text {
		fill: var(--ba-cta-text);
		font-size: 11px;
		font-weight: 600;
		font-family: inherit;
	}

	.ba-live-dot {
		fill: var(--ba-live);
		opacity: 0;
		transition: opacity 0.4s ease-out;
	}

	.ba-live-pulse {
		fill: var(--ba-live);
		opacity: 0;
		transform-box: fill-box;
		transform-origin: center;
	}

	.ba-caption {
		fill: var(--ba-text);
		font-size: 14px;
		font-weight: 600;
		font-family: inherit;
		letter-spacing: 0.01em;
		opacity: 0;
		transition: opacity 0.5s ease-out;
	}

	/* === Active sequence === */

	/* Phase 1: outer frame draws */
	.ba.is-active .ba-frame {
		transition: stroke-dashoffset 0.9s ease-out 0.1s;
		stroke-dashoffset: 0;
	}

	/* Phase 2: header line */
	.ba.is-active .ba-header {
		transition: stroke-dashoffset 0.5s ease-out 1s;
		stroke-dashoffset: 0;
	}

	/* Phase 3: content lines (staggered) */
	.ba.is-active .ba-line-1 {
		transition: stroke-dashoffset 0.5s ease-out 1.4s;
		stroke-dashoffset: 0;
	}
	.ba.is-active .ba-line-2 {
		transition: stroke-dashoffset 0.5s ease-out 1.7s;
		stroke-dashoffset: 0;
	}
	.ba.is-active .ba-line-3 {
		transition: stroke-dashoffset 0.5s ease-out 2s;
		stroke-dashoffset: 0;
	}

	/* Phase 4: CTA button pops in */
	.ba.is-active .ba-cta-group {
		opacity: 1;
		transform: scale(1);
		transition-delay: 2.4s;
	}

	/* Phase 5: live indicator dot appears, then pulses forever */
	.ba.is-active .ba-live-dot {
		opacity: 1;
		transition-delay: 2.9s;
	}

	.ba.is-active .ba-live-pulse {
		animation: ba-live-pulse 2.4s ease-out 3.2s infinite;
	}

	@keyframes ba-live-pulse {
		0% {
			opacity: 0.55;
			transform: scale(1);
		}
		70% {
			opacity: 0;
			transform: scale(3);
		}
		100% {
			opacity: 0;
			transform: scale(3);
		}
	}

	/* Phase 6: caption */
	.ba.is-active .ba-caption {
		opacity: 1;
		transition-delay: 3.4s;
	}

	@media (prefers-reduced-motion: reduce) {
		.ba-frame,
		.ba-header,
		.ba-line,
		.ba-cta-group,
		.ba-cta-text,
		.ba-live-dot,
		.ba-live-pulse,
		.ba-caption {
			transition: none !important;
			animation: none !important;
		}
		.ba-frame { stroke-dashoffset: 0 !important; }
		.ba-header { stroke-dashoffset: 0 !important; }
		.ba-line { stroke-dashoffset: 0 !important; }
		.ba-cta-group { opacity: 1 !important; transform: scale(1) !important; }
		.ba-live-dot { opacity: 1 !important; }
		.ba-live-pulse { opacity: 0 !important; }
		.ba-caption { opacity: 1 !important; }
	}
</style>

<script>
	const init = () => {
		const el = document.querySelector<HTMLElement>('.ba');
		if (!el) return;

		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (reduced) {
			el.classList.add('is-active');
			return;
		}

		const obs = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-active');
					obs.unobserve(entry.target);
				}
			});
		}, { threshold: 0.4 });

		obs.observe(el);
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>
