---
// Hero animation for /services/team-ai-training.
// Shape of the engagement: a team of mixed AI proficiency arrives uneven,
// leaves on a shared baseline. Six person figures scattered, slide to a
// shared line, baseline draws underneath, caption settles. Runs once.
// prefers-reduced-motion: end state, no animation.
---

<div class="tt" aria-hidden="true">
	<svg viewBox="0 0 600 220" xmlns="http://www.w3.org/2000/svg" class="tt-svg">
		<!-- Baseline (drawn last) -->
		<line class="tt-baseline" x1="60" y1="148" x2="540" y2="148" />

		<!-- Six people at varied starting heights.
		     Each is a head circle + shoulder/torso arc, drawn relative to a
		     translated inner group so CSS transforms on the outer group
		     animate cleanly. -->
		<g class="tt-person tt-person-1">
			<g transform="translate(100,68)">
				<circle cx="0" cy="-5" r="4.5" />
				<path d="M-8 6 a 8 8 0 0 1 16 0 Z" />
			</g>
		</g>
		<g class="tt-person tt-person-2">
			<g transform="translate(186,168)">
				<circle cx="0" cy="-5" r="4.5" />
				<path d="M-8 6 a 8 8 0 0 1 16 0 Z" />
			</g>
		</g>
		<g class="tt-person tt-person-3">
			<g transform="translate(272,90)">
				<circle cx="0" cy="-5" r="4.5" />
				<path d="M-8 6 a 8 8 0 0 1 16 0 Z" />
			</g>
		</g>
		<g class="tt-person tt-person-4">
			<g transform="translate(358,180)">
				<circle cx="0" cy="-5" r="4.5" />
				<path d="M-8 6 a 8 8 0 0 1 16 0 Z" />
			</g>
		</g>
		<g class="tt-person tt-person-5">
			<g transform="translate(444,58)">
				<circle cx="0" cy="-5" r="4.5" />
				<path d="M-8 6 a 8 8 0 0 1 16 0 Z" />
			</g>
		</g>
		<g class="tt-person tt-person-6">
			<g transform="translate(514,158)">
				<circle cx="0" cy="-5" r="4.5" />
				<path d="M-8 6 a 8 8 0 0 1 16 0 Z" />
			</g>
		</g>

		<!-- Caption appears once aligned -->
		<text class="tt-caption" x="300" y="200" text-anchor="middle">Bring your team together</text>
	</svg>
</div>

<style>
	.tt {
		--tt-stroke: #477056;
		--tt-fill: #588B67;
		--tt-text: #475569;
		width: 100%;
		max-width: 560px;
		margin: 0 auto;
	}

	.tt-svg {
		width: 100%;
		height: auto;
		display: block;
	}

	.tt-baseline {
		stroke: var(--tt-stroke);
		fill: none;
		stroke-width: 2;
		stroke-linecap: round;
		stroke-dasharray: 480;
		stroke-dashoffset: 480;
	}

	.tt-person circle,
	.tt-person path {
		fill: var(--tt-fill);
		stroke: var(--tt-stroke);
		stroke-width: 1.5;
		stroke-linejoin: round;
	}

	.tt-person {
		opacity: 0;
		transform: scale(0.4);
		transform-box: fill-box;
		transform-origin: center;
		transition:
			opacity 0.4s ease-out,
			transform 0.5s cubic-bezier(0.34, 1.2, 0.64, 1);
	}

	.tt-caption {
		fill: var(--tt-text);
		font-size: 14px;
		font-weight: 600;
		font-family: inherit;
		letter-spacing: 0.01em;
		opacity: 0;
		transition: opacity 0.5s ease-out;
	}

	/* Phase 1: people pop in scattered (staggered) */
	.tt.is-active .tt-person-1 { opacity: 1; transform: scale(1); transition-delay: 0.1s, 0.1s; }
	.tt.is-active .tt-person-2 { opacity: 1; transform: scale(1); transition-delay: 0.2s, 0.2s; }
	.tt.is-active .tt-person-3 { opacity: 1; transform: scale(1); transition-delay: 0.3s, 0.3s; }
	.tt.is-active .tt-person-4 { opacity: 1; transform: scale(1); transition-delay: 0.4s, 0.4s; }
	.tt.is-active .tt-person-5 { opacity: 1; transform: scale(1); transition-delay: 0.5s, 0.5s; }
	.tt.is-active .tt-person-6 { opacity: 1; transform: scale(1); transition-delay: 0.6s, 0.6s; }

	/* Phase 2: people slide to baseline at y=140 (feet on line at y=148).
	   Each translateY = (140 - starting cy). */
	.tt.is-active .tt-person-1 { animation: tt-align-1 0.7s cubic-bezier(0.4, 0, 0.2, 1) 1.5s forwards; }
	.tt.is-active .tt-person-2 { animation: tt-align-2 0.7s cubic-bezier(0.4, 0, 0.2, 1) 1.5s forwards; }
	.tt.is-active .tt-person-3 { animation: tt-align-3 0.7s cubic-bezier(0.4, 0, 0.2, 1) 1.5s forwards; }
	.tt.is-active .tt-person-4 { animation: tt-align-4 0.7s cubic-bezier(0.4, 0, 0.2, 1) 1.5s forwards; }
	.tt.is-active .tt-person-5 { animation: tt-align-5 0.7s cubic-bezier(0.4, 0, 0.2, 1) 1.5s forwards; }
	.tt.is-active .tt-person-6 { animation: tt-align-6 0.7s cubic-bezier(0.4, 0, 0.2, 1) 1.5s forwards; }

	@keyframes tt-align-1 { to { transform: translateY(72px) scale(1); } }
	@keyframes tt-align-2 { to { transform: translateY(-28px) scale(1); } }
	@keyframes tt-align-3 { to { transform: translateY(50px) scale(1); } }
	@keyframes tt-align-4 { to { transform: translateY(-40px) scale(1); } }
	@keyframes tt-align-5 { to { transform: translateY(82px) scale(1); } }
	@keyframes tt-align-6 { to { transform: translateY(-18px) scale(1); } }

	/* Phase 3: baseline draws under the aligned people */
	.tt.is-active .tt-baseline {
		stroke-dashoffset: 0;
		transition: stroke-dashoffset 0.7s ease-out 2.3s;
	}

	/* Phase 4: caption fades in */
	.tt.is-active .tt-caption {
		opacity: 1;
		transition-delay: 3s;
	}

	@media (prefers-reduced-motion: reduce) {
		.tt-person,
		.tt-baseline,
		.tt-caption {
			transition: none !important;
			animation: none !important;
		}
		.tt-person {
			opacity: 1 !important;
		}
		.tt-person-1 { transform: translateY(72px); }
		.tt-person-2 { transform: translateY(-28px); }
		.tt-person-3 { transform: translateY(50px); }
		.tt-person-4 { transform: translateY(-40px); }
		.tt-person-5 { transform: translateY(82px); }
		.tt-person-6 { transform: translateY(-18px); }
		.tt-baseline {
			stroke-dashoffset: 0 !important;
		}
		.tt-caption {
			opacity: 1 !important;
		}
	}
</style>

<script>
	const init = () => {
		const el = document.querySelector<HTMLElement>('.tt');
		if (!el) return;

		const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
		if (reduced) {
			el.classList.add('is-active');
			return;
		}

		const obs = new IntersectionObserver((entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					entry.target.classList.add('is-active');
					obs.unobserve(entry.target);
				}
			});
		}, { threshold: 0.4 });

		obs.observe(el);
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>
