---

---

<!-- Merged Hero Section with Two Columns -->
<section
  class="relative min-h-screen flex items-center justify-center overflow-hidden pt-20"
>
  <!-- Background Elements -->
  <div
    class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-900/20 via-primary-dark to-primary-dark z-0 pointer-events-none"
  >
    <div
      class="absolute top-[-10%] right-[-5%] w-[500px] h-[500px] rounded-full bg-blue-900/20 blur-[100px]"
    >
    </div>
    <div
      class="absolute bottom-[-10%] left-[-5%] w-[500px] h-[500px] rounded-full bg-indigo-900/10 blur-[100px]"
    >
    </div>
  </div>

  <!-- Background Image -->
  <div class="absolute inset-0 z-0">
    <img
      src="/images/hero-bg.png"
      alt="Background"
      class="w-full h-full object-cover opacity-50"
    />
    <div
      class="absolute inset-0 bg-gradient-to-b from-primary-dark/80 via-primary-dark/50 to-primary-dark"
    >
    </div>
  </div>

  <!-- Two Column Grid Layout -->
  <div class="container-custom z-10 py-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <!-- Left Column: Hero Content -->
      <div class="text-center lg:text-left">
        <div
          class="inline-block px-3 py-1 mb-6 border border-accent-cyan/30 rounded-full bg-accent-cyan/10 backdrop-blur-sm"
        >
          <span class="text-sm font-mono text-accent-cyan tracking-wide"
            >CLOUD & PLATFORM ENGINEER</span
          >
        </div>

        <h1
          class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 leading-tight tracking-tight"
        >
          I help SaaS companies scale <br class="hidden md:block" />
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-accent-cyan to-accent-purple"
            >Kubernetes infrastructure</span
          >
        </h1>

        <p class="text-lg md:text-xl text-muted mb-10 leading-relaxed">
          I help SaaS companies running 50+ tenants migrate to Kubernetes without breaking production.
        </p>

        <div
          class="flex flex-col sm:flex-row gap-6 justify-center lg:justify-start items-center mb-12"
        >
          <a
            href="mailto:hi@jitangupta.com"
            class="group relative px-8 py-4 bg-accent-cyan hover:bg-accent-cyan/90 text-[#0a0a0f] font-bold rounded-lg transition-all duration-300 shadow-[0_0_20px_rgba(0,212,255,0.3)] hover:shadow-[0_0_30px_rgba(0,212,255,0.5)] hover:-translate-y-1 flex items-center gap-3 min-w-[200px] justify-center border border-accent-cyan"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg
            >
            <span>Let's Talk</span>
          </a>
          <a
            href="#projects"
            class="group px-8 py-4 bg-card-dark border border-white/10 hover:border-white/30 text-gray-300 hover:text-white font-medium rounded-lg transition-all duration-300 hover:-translate-y-1 flex items-center gap-3 min-w-[200px] justify-center"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"
              ></path></svg
            >
            <span>View Work</span>
          </a>
        </div>
      </div>

      <!-- Right Column: Intersection SVG -->
      <div class="flex flex-col items-center justify-center max-w-lg mx-auto">
        <div class="text-center mb-8">
          <!-- <span
            class="inline-block px-3 py-1 mb-4 border border-accent-cyan/30 rounded-full bg-accent-cyan/10 backdrop-blur-sm text-xs font-mono text-accent-cyan tracking-widest uppercase"
            >Where I Work</span
          >
          <h2 class="text-2xl md:text-3xl font-bold mb-2">The Intersection</h2>
          <p class="text-muted text-sm md:text-base">
            Where Software Engineering, DevOps, and AI meet
          </p> -->
        </div>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 1000 500"
          id="intersection-hero"
          class="w-full h-auto"
        >
          <defs>
            <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#0a0a0f"></stop>
              <stop offset="50%" stop-color="#0d0d14"></stop>
              <stop offset="100%" stop-color="#0a0a0f"></stop>
            </linearGradient>

            <linearGradient id="cyanGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#00d4ff" stop-opacity="0.25"></stop>
              <stop offset="100%" stop-color="#00d4ff" stop-opacity="0.05"
              ></stop>
            </linearGradient>

            <linearGradient id="purpleGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#8b5cf6" stop-opacity="0.25"></stop>
              <stop offset="100%" stop-color="#8b5cf6" stop-opacity="0.05"
              ></stop>
            </linearGradient>

            <linearGradient id="pinkGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#ec4899" stop-opacity="0.25"></stop>
              <stop offset="100%" stop-color="#ec4899" stop-opacity="0.05"
              ></stop>
            </linearGradient>

            <linearGradient id="centerGrad" x1="0%" y1="0%" x2="100%" y2="100%">
              <stop offset="0%" stop-color="#00d4ff"></stop>
              <stop offset="50%" stop-color="#8b5cf6"></stop>
              <stop offset="100%" stop-color="#ec4899"></stop>
            </linearGradient>

            <filter id="glowCyan" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="blur"></feGaussianBlur>
              <feMerge>
                <feMergeNode in="blur"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>

            <filter
              id="glowPurple"
              x="-50%"
              y="-50%"
              width="200%"
              height="200%"
            >
              <feGaussianBlur stdDeviation="6" result="blur"></feGaussianBlur>
              <feMerge>
                <feMergeNode in="blur"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>

            <filter id="glowPink" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="blur"></feGaussianBlur>
              <feMerge>
                <feMergeNode in="blur"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>

            <filter
              id="centerGlow"
              x="-100%"
              y="-100%"
              width="300%"
              height="300%"
            >
              <feGaussianBlur stdDeviation="12" result="blur"></feGaussianBlur>
              <feMerge>
                <feMergeNode in="blur"></feMergeNode>
                <feMergeNode in="SourceGraphic"></feMergeNode>
              </feMerge>
            </filter>

            <pattern
              id="grid1"
              width="40"
              height="40"
              patternUnits="userSpaceOnUse"
            >
              <path
                d="M 40 0 L 0 0 0 40"
                fill="none"
                stroke="#1a1a2e"
                stroke-width="0.5"></path>
            </pattern>
          </defs>

          <!-- Background (removed solid background, keeping only grid) -->
          <g id="background">
            <rect width="1200" height="600" fill="url(#grid1)" opacity="0.2"
            ></rect>
          </g>

          <!-- Particles -->
          <g id="particles" class="animate-fade">
            <circle cx="100" cy="100" r="2" fill="#00d4ff" opacity="0.3"
            ></circle>
            <circle cx="200" cy="450" r="1.5" fill="#8b5cf6" opacity="0.4"
            ></circle>
            <circle cx="1050" cy="150" r="2" fill="#ec4899" opacity="0.3"
            ></circle>
            <circle cx="950" cy="500" r="1.5" fill="#00d4ff" opacity="0.4"
            ></circle>
            <circle cx="150" cy="350" r="1" fill="#8b5cf6" opacity="0.5"
            ></circle>
            <circle cx="1100" cy="400" r="1" fill="#ec4899" opacity="0.4"
            ></circle>
          </g>

          <!-- Venn Diagram Container -->
          <g transform="translate(600, 290)">
            <!-- SOFTWARE ENGINEERING (Top) -->
            <g id="se-circle" class="animate-fade">
              <circle
                cx="0"
                cy="-85"
                r="140"
                fill="url(#cyanGrad)"
                stroke="#00d4ff"
                stroke-width="1.5"
                filter="url(#glowCyan)"></circle>
              <g
                transform="translate(0, -160)"
                fill="none"
                stroke="#00d4ff"
                stroke-width="2"
                opacity="0.9"
              >
                <path d="M-12 -8 L-20 0 L-12 8"></path>
                <path d="M12 -8 L20 0 L12 8"></path>
              </g>
              <text
                x="0"
                y="-180"
                text-anchor="middle"
                fill="#00d4ff"
                font-family="system-ui, -apple-system, sans-serif"
                font-size="11"
                font-weight="600"
                letter-spacing="1.5">SOFTWARE ENGINEERING</text
              >
              <text
                x="0"
                y="-130"
                text-anchor="middle"
                fill="#64748b"
                font-family="system-ui, -apple-system, sans-serif"
                font-size="10">Backend · APIs · .NET</text
              >
            </g>

            <!-- DEVOPS (Bottom Left) -->
            <g id="devops-circle" class="animate-fade">
              <circle
                cx="-100"
                cy="65"
                r="140"
                fill="url(#purpleGrad)"
                stroke="#8b5cf6"
                stroke-width="1.5"
                filter="url(#glowPurple)"></circle>
              <g
                transform="translate(-145, 75)"
                fill="none"
                stroke="#8b5cf6"
                stroke-width="2"
                opacity="0.9"
              >
                <path
                  d="M-10 0 C-10 -7 -3 -7 0 0 C3 7 10 7 10 0 C10 -7 3 -7 0 0 C-3 7 -10 7 -10 0"
                ></path>
              </g>
              <text
                x="-145"
                y="115"
                text-anchor="middle"
                fill="#8b5cf6"
                font-family="system-ui, -apple-system, sans-serif"
                font-size="11"
                font-weight="600"
                letter-spacing="1.5">DEVOPS</text
              >
              <text
                x="-145"
                y="138"
                text-anchor="middle"
                fill="#64748b"
                font-family="system-ui, -apple-system, sans-serif"
                font-size="10">AKS · ArgoCD · Helm</text
              >
            </g>

            <!-- AI/ML (Bottom Right) -->
            <g id="ai-circle" class="animate-fade">
              <circle
                cx="100"
                cy="65"
                r="140"
                fill="url(#pinkGrad)"
                stroke="#ec4899"
                stroke-width="1.5"
                filter="url(#glowPink)"></circle>
              <g transform="translate(145, 75)" fill="#ec4899" opacity="0.9">
                <circle cx="0" cy="0" r="3.5"></circle>
                <circle cx="-10" cy="-7" r="2"></circle>
                <circle cx="10" cy="-7" r="2"></circle>
                <circle cx="-10" cy="7" r="2"></circle>
                <circle cx="10" cy="7" r="2"></circle>
                <line
                  x1="0"
                  y1="0"
                  x2="-10"
                  y2="-7"
                  stroke="#ec4899"
                  stroke-width="1"></line>
                <line
                  x1="0"
                  y1="0"
                  x2="10"
                  y2="-7"
                  stroke="#ec4899"
                  stroke-width="1"></line>
                <line
                  x1="0"
                  y1="0"
                  x2="-10"
                  y2="7"
                  stroke="#ec4899"
                  stroke-width="1"></line>
                <line
                  x1="0"
                  y1="0"
                  x2="10"
                  y2="7"
                  stroke="#ec4899"
                  stroke-width="1"></line>
              </g>
              <text
                x="145"
                y="115"
                text-anchor="middle"
                fill="#ec4899"
                font-family="system-ui, -apple-system, sans-serif"
                font-size="11"
                font-weight="600"
                letter-spacing="1.5">AI / MLOPS</text
              >
              <text
                x="145"
                y="138"
                text-anchor="middle"
                fill="#64748b"
                font-family="system-ui, -apple-system, sans-serif"
                font-size="10">RAG · LLMs · Qdrant</text
              >
            </g>

            <!-- Intersection dots -->
            <g id="intersection-dots" class="animate-fade" opacity="0.6">
              <circle cx="-50" cy="-15" r="3" fill="#00d4ff"></circle>
              <circle cx="50" cy="-15" r="3" fill="#ec4899"></circle>
              <circle cx="0" cy="65" r="3" fill="#8b5cf6"></circle>
            </g>

            <!-- Center core -->
            <g id="center-core" class="animate-fade">
              <circle
                cx="0"
                cy="12"
                r="42"
                fill="#0a0a0f"
                stroke="url(#centerGrad)"
                stroke-width="2.5"
                filter="url(#centerGlow)"></circle>
              <g id="center-pulse">
                <circle
                  cx="0"
                  cy="12"
                  r="35"
                  fill="none"
                  stroke="url(#centerGrad)"
                  stroke-width="1"
                  opacity="0.4"></circle>
                <circle
                  cx="0"
                  cy="12"
                  r="28"
                  fill="none"
                  stroke="url(#centerGrad)"
                  stroke-width="0.5"
                  opacity="0.25"></circle>
              </g>
            </g>

            <!-- Center label -->
            <g id="center-label" class="animate-fade">
              <text
                x="0"
                y="8"
                text-anchor="middle"
                fill="#ffffff"
                font-family="system-ui, -apple-system, sans-serif"
                font-size="10"
                font-weight="600"
                letter-spacing="0.5">WHERE</text
              >
              <text
                x="0"
                y="22"
                text-anchor="middle"
                fill="#ffffff"
                font-family="system-ui, -apple-system, sans-serif"
                font-size="10"
                font-weight="600"
                letter-spacing="0.5">I WORK</text
              >
            </g>
          </g>

          <!-- Tagline -->
          <g id="tagline" class="animate-fade">
            <text
              x="600"
              y="530"
              text-anchor="middle"
              fill="#64748b"
              font-family="system-ui, -apple-system, sans-serif"
              font-size="12"
              letter-spacing="0.3"
              >Building infrastructure where code, operations, and intelligence
              converge</text
            >
          </g>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  /* Intersection Hero Animations */
  #intersection-hero .animate-fade {
    opacity: 0;
    transition: opacity 0.7s ease-out;
  }

  #intersection-hero.animate .animate-fade {
    opacity: 1;
  }

  #intersection-hero.animate #particles {
    transition-delay: 0s;
  }
  #intersection-hero.animate #se-circle {
    transition-delay: 0.2s;
  }
  #intersection-hero.animate #devops-circle {
    transition-delay: 0.4s;
  }
  #intersection-hero.animate #ai-circle {
    transition-delay: 0.6s;
  }
  #intersection-hero.animate #intersection-dots {
    transition-delay: 0.8s;
  }
  #intersection-hero.animate #center-core {
    transition-delay: 0.9s;
  }
  #intersection-hero.animate #center-label {
    transition-delay: 1.1s;
  }
  #intersection-hero.animate #tagline {
    transition-delay: 1.3s;
  }

  @keyframes pulse {
    0%,
    100% {
      opacity: 0.4;
    }
    50% {
      opacity: 0.15;
    }
  }

  #intersection-hero.animate #center-pulse circle {
    animation: pulse 2.5s ease-in-out infinite;
  }

  #intersection-hero.animate #center-pulse circle:nth-child(2) {
    animation-delay: 0.4s;
  }

  @media (prefers-reduced-motion: reduce) {
    #intersection-hero .animate-fade {
      transition: none !important;
      opacity: 1 !important;
    }

    #intersection-hero #center-pulse circle {
      animation: none !important;
    }
  }
</style>

<script>
  // Intersection observer for the SVG animation
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const svg = entry.target;
          if (svg) {
            setTimeout(() => svg.classList.add("animate"), 150);
          }
        }
      });
    },
    { threshold: 0.25 },
  );

  const svg = document.getElementById("intersection-hero");
  if (svg) {
    observer.observe(svg);
  }
</script>
