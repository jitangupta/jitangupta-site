---
interface FAQItem {
  question: string;
  answer: string;
}

interface Props {
  faq: FAQItem[];
}

const { faq } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map(({ question, answer }) => ({
    "@type": "Question",
    "name": question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": answer
    }
  }))
};
---
{faq && faq.length > 0 && (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
)}
