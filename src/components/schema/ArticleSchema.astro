---
import { SITE_URL } from '../../consts';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  url: string;
  image?: string;
}

const { title, description, pubDate, updatedDate, url, image } = Astro.props;

const schema: Record<string, unknown> = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": title,
  "description": description,
  "datePublished": pubDate.toISOString(),
  "dateModified": (updatedDate ?? pubDate).toISOString(),
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": url
  },
  "author": {
    "@type": "Person",
    "name": "Jitan Gupta",
    "url": SITE_URL
  },
  "publisher": {
    "@type": "Person",
    "name": "Jitan Gupta",
    "url": SITE_URL
  }
};

if (image) {
  schema.image = image.startsWith('http') ? image : new URL(image, SITE_URL).toString();
}
---
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
