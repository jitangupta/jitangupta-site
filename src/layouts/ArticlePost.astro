---
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import CommonCTA from '../components/CommonCTA.astro';
import Chatwoot from '../components/chatwoot.astro';
import ArticleSchema from '../components/schema/ArticleSchema.astro';
import FAQPageSchema from '../components/schema/FAQPageSchema.astro';
import VideoObjectSchema from '../components/schema/VideoObjectSchema.astro';

type Props = CollectionEntry<'learn'>['data'];

const { title, titleTag, description, pubDate, updatedDate, heroImage, articleTag, faq, videos } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();

---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />
		<ArticleSchema
			title={title}
			description={description}
			pubDate={pubDate}
			updatedDate={updatedDate}
			url={canonical}
			image={heroImage}
		/>
		{faq && faq.length > 0 && <FAQPageSchema faq={faq} />}
		{videos && videos.map((v) => (
			<VideoObjectSchema
				name={v.name}
				description={v.description ?? title}
				thumbnailUrl={`https://i.ytimg.com/vi/${v.youtubeId}/hqdefault.jpg`}
				uploadDate={v.uploadDate ?? pubDate.toISOString()}
				contentUrl={`https://www.youtube.com/watch?v=${v.youtubeId}`}
				embedUrl={`https://www.youtube.com/embed/${v.youtubeId}`}
			/>
		))}
		<style is:global>
			.content-slot {
				color: #364153;
				font-size: 18px;
			}
			.content-slot h2 {
				color: #eb7329 !important;
				margin-top: 25px;
				margin-bottom: 0px;
				font-size: 30px;
			}

			.content-slot h3 {
				color: #1e2939  !important;
				margin-top: 20px;
				margin-bottom: 5px;
				font-size: 25px;
			}

			.content-slot h2 + h3 {
				margin-top: 0px;
			}

			.content-slot h2:first-child {
				margin-top: 0px;
			}

			.content-slot p {
				color: #364153;
				font-size: 18px;
			}

			.content-slot ul {
				list-style-type: auto;
				margin-left: 20px;
				font-size: 18px;
			}

			.content-slot ul li > ul {
				list-style-type: disc;
			}

			.content-slot strong {
				color: #364153;
				font-weight: 600;
			}

			.content-slot p strong {
				margin-top: 15px;
			}

			.content-slot strong a:hover{
				text-decoration: underline;
			}
			@media screen and (max-width: 768px) {
				.content-slot h2 {
					font-size: 22px;
				}
				.content-slot h3 {
					font-size: 20px;
				}
				.content-slot p, .content-slot ul li {
					font-size: 17px;
				}
			}

			.content-slot ol {
				list-style-type: auto;
				margin:5px 0 5px 20px;
			}
			.content-slot ul {
				list-style-type: disc;
				margin-left: 20px;
			}
			
		</style>
	</head>

	<body>
		<Header />
		<section class="bg-[#F8FAFC] mx-2">
			<div class="bg-white max-w-screen-xl mx-auto px-5 md:px-15 py-10 rounded-b-2xl">
				<!-- Tags -->
				<a href="/learn/" class="px-5 inline-block rounded-3xl cursor-pointer m-1 bg-sky-300 hover:bg-gray-800 hover:text-white transition">Learn</a>
				{articleTag && <span class="px-5 inline-block rounded-3xl cursor-pointer bg-yellow-300 hover:bg-gray-800 hover:text-white transition">🛠️ {articleTag}</span>}

				<!-- Title -->
				<h1 class="text-3xl md:text-5xl lg:text-6xl mt-8 font-bold" style="line-height: 1.2;">{title}</h1>
				{titleTag && <h2 class="text-2xl md:text-3xl lg:text-4xl mb-4">{titleTag}</h2>}

				<!-- Publish Info & Share -->
				<div class="flex flex-wrap sm:flex-nowrap items-center text-sm gap-x-2 gap-y-1">
					<img src="/articles/author.png" class="w-10 sm:w-12 rounded-full mr-3">
					
					<h3 class="text-gray-700 whitespace-nowrap">Jitan Gupta</h3>
					
					<span class="mx-2 text-gray-400 hidden sm:inline">/</span>
				
					<div class="text-gray-700">
						<FormattedDate date={pubDate} />
						<div class="text-xs text-gray-500 sm:inline-block">
							{
								updatedDate && (
									<span class="block sm:inline">Last updated on <FormattedDate date={updatedDate} /></span>
								)
							}
						</div>
					</div>
				
					<span class="mx-2 text-gray-400 hidden sm:inline">/</span>
				
					<span class="text-gray-700">Share:</span>
				
					<div class="flex gap-2">
						<a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(Astro.request.url)}`} 
						target="_blank" 
						rel="noopener noreferrer" class="text-gray-900 hover:text-gray-800 transition">
							<svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M13.982 10.622 20.54 3h-1.554l-5.693 6.618L8.745 3H3.5l6.876 10.007L3.5 21h1.554l6.012-6.989L15.868 21h5.245l-7.131-10.378Zm-2.128 2.474-.697-.997-5.543-7.93H8l4.474 6.4.697.996 5.815 8.318h-2.387l-4.745-6.787Z"></path></svg>
						</a>
						<a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(Astro.request.url)}`} 
						target="_blank" 
						rel="noopener noreferrer" class="text-gray-900 hover:text-gray-800 transition">
							<svg width="22" height="22" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M19.7,3H4.3C3.582,3,3,3.582,3,4.3v15.4C3,20.418,3.582,21,4.3,21h15.4c0.718,0,1.3-0.582,1.3-1.3V4.3 C21,3.582,20.418,3,19.7,3z M8.339,18.338H5.667v-8.59h2.672V18.338z M7.004,8.574c-0.857,0-1.549-0.694-1.549-1.548 c0-0.855,0.691-1.548,1.549-1.548c0.854,0,1.547,0.694,1.547,1.548C8.551,7.881,7.858,8.574,7.004,8.574z M18.339,18.338h-2.669 v-4.177c0-0.996-0.017-2.278-1.387-2.278c-1.389,0-1.601,1.086-1.601,2.206v4.249h-2.667v-8.59h2.559v1.174h0.037 c0.356-0.675,1.227-1.387,2.526-1.387c2.703,0,3.203,1.779,3.203,4.092V18.338z"></path></svg>
						</a>
						<a  href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(Astro.request.url)}`} 
						target="_blank" 
						rel="noopener noreferrer" class="text-gray-900 hover:text-gray-800 transition">
							<svg width="20" height="20" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M12 2C6.5 2 2 6.5 2 12c0 5 3.7 9.1 8.4 9.9v-7H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.4 2.9h-2.3v7C18.3 21.1 22 17 22 12c0-5.5-4.5-10-10-10z"></path></svg>
						</a>
					</div>
				</div>
				
				<!-- Banner -->
				
				<div class="absolute py-10 md:py-18 left-0 sm:left-auto">
					{heroImage && <img src={heroImage} alt="" class="rounded-3xl w-full max-w-2xl md:w-2xl" />}
				</div>
				<div class="p-10 sm:p-32"></div>
			</div>
		</section>
		
		<section class="pt-36 bg-[#F8FAFC] px-5 md:px-0">
			<div class="flex flex-col md:flex-row mx-auto max-w-6xl px-0 py-8">
				<!-- Blog Content -->
				<main class="w-full md:w-3/4 content-slot">
					<slot />

					{videos && videos.length > 0 && (
						<section class="mt-12">
							<h2>Watch on YouTube</h2>
							<div class="space-y-6">
								{videos.map((v) => (
									<div>
										<div class="aspect-video w-full max-w-3xl rounded-xl overflow-hidden border border-gray-200">
											<iframe
												src={`https://www.youtube.com/embed/${v.youtubeId}`}
												title={v.name}
												loading="lazy"
												class="w-full h-full"
												frameborder="0"
												allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
												allowfullscreen
											></iframe>
										</div>
										<p class="mt-2 text-sm text-gray-600">{v.name}</p>
									</div>
								))}
							</div>
						</section>
					)}

					{faq && faq.length > 0 && (
						<section class="mt-12">
							<h2>Frequently Asked Questions</h2>
							<div class="space-y-3">
								{faq.map((item) => (
									<details class="bg-white border border-gray-200 rounded-xl p-4 open:shadow-sm">
										<summary class="font-semibold text-gray-900 cursor-pointer">{item.question}</summary>
										<div class="mt-3 text-gray-700 leading-relaxed" set:html={item.answer} />
									</details>
								))}
							</div>
						</section>
					)}
				</main>

				<!-- Table Of Content -->
				<aside class="hidden md:block md:w-1/4 pl-6">
					<div class="sticky top-4 p-4 bg-white shadow-lg rounded-lg">
						<h2 class="text-lg font-semibold mb-2">Table of Contents</h2>
						<ul class="text-sm space-y-2">
							{Astro.props.headings && Astro.props.headings.map(heading => (
								<li class="p-0.5" style={`margin-left: ${heading.depth * 10}px;`}>
									<a class="text-gray-500 hover:text-gray-800 transition toc" href={`#${heading.text.replace(/\s+/g, '-').toLowerCase()}`}>{heading.text}</a>
								</li>
							))}
						</ul>
					</div>
				</aside>
			</div>
		</section>

		<CommonCTA />
		
		<Footer />
		<script is:inline src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
		<Chatwoot />
	</body>
</html>
