---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SiteHeader from '../components/SiteHeader.astro';
import ArticleSchema from '../components/schema/ArticleSchema.astro';
import FAQPageSchema from '../components/schema/FAQPageSchema.astro';
import VideoObjectSchema from '../components/schema/VideoObjectSchema.astro';

type Props = CollectionEntry<'learn'>['data'] & { headings?: { depth: number; slug: string; text: string }[] };

const { title, titleTag, description, pubDate, updatedDate, heroImage, articleTag, faq, videos, headings = [] } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url).toString();

const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
const published = dateFmt.format(pubDate);
const updated = updatedDate ? dateFmt.format(updatedDate) : null;
const sections = headings.filter((h) => h.depth === 2);
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
    <ArticleSchema
      title={title}
      description={description}
      pubDate={pubDate}
      updatedDate={updatedDate}
      url={canonical}
      image={heroImage}
    />
    {faq && faq.length > 0 && <FAQPageSchema faq={faq} />}
    {videos && videos.map((v) => (
      <VideoObjectSchema
        name={v.name}
        description={v.description ?? title}
        thumbnailUrl={`https://i.ytimg.com/vi/${v.youtubeId}/hqdefault.jpg`}
        uploadDate={v.uploadDate ?? pubDate.toISOString()}
        contentUrl={`https://www.youtube.com/watch?v=${v.youtubeId}`}
        embedUrl={`https://www.youtube.com/embed/${v.youtubeId}`}
      />
    ))}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <style is:global>
      :root,
      html[data-theme="paper"] {
        --bg: oklch(0.985 0.008 80);
        --bg-tint: oklch(0.965 0.012 80);
        --ink: oklch(0.18 0.012 60);
        --ink-2: oklch(0.30 0.012 60);
        --muted: oklch(0.50 0.012 60);
        --hairline: oklch(0.88 0.010 80);
        --hairline-strong: oklch(0.78 0.012 80);
        --accent: oklch(0.62 0.20 32);
        --accent-ink: oklch(0.98 0.005 80);
        --selection: oklch(0.85 0.14 32 / 0.45);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Geist", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: "ss01","ss02","cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
      }

      ::selection { background: var(--selection); }
      body { min-height: 100vh; overflow-x: hidden; }

      a { color: inherit; text-decoration: none; text-underline-offset: 3px; transition: color 150ms ease, opacity 150ms ease; }
      a:hover { color: var(--accent); }

      p { margin: 0; }
      ul, ol { margin: 0; padding: 0; list-style: none; }
      img { max-width: 100%; display: block; }

      .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
      @media (max-width: 540px) { .wrap { padding: 0 20px; } }

      .mono { font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace; }

      .eyebrow {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .eyebrow::before { content: ""; width: 18px; height: 1px; background: var(--hairline-strong); }

      h1, h2, h3, h4 { margin: 0; font-weight: 500; letter-spacing: -0.02em; }

      .btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 12px 18px; border: 1px solid var(--hairline-strong);
        border-radius: 999px; font-size: 14.5px; font-weight: 500;
        color: var(--ink); background: transparent; cursor: pointer;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
        text-decoration: none;
      }
      .btn:hover { background: var(--bg-tint); color: var(--ink); border-color: var(--ink); }
      .btn.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .arrow { width: 14px; height: 14px; display: inline-block; vertical-align: -1px; }
      .btn .arrow { transition: transform 200ms ease; }
      .btn:hover .arrow { transform: translateX(3px); }

      /* ===== FOOTER ===== */
      .site-footer { border-top: 1px solid var(--hairline); padding: 56px 0 40px; }
      .site-footer .grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 56px; }
      .site-footer h4 { font-family: "Geist Mono", monospace; font-size: 12px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; font-weight: 500; }
      .site-footer ul li { padding: 4px 0; }
      .site-footer ul li a { color: var(--ink-2); font-size: 14.5px; }
      .site-footer .meta { display: flex; justify-content: space-between; align-items: center; font-size: 13px; color: var(--muted); padding-top: 24px; border-top: 1px solid var(--hairline); }
      @media (max-width: 820px) { .site-footer .grid { grid-template-columns: 1fr 1fr; } }
      @media (max-width: 540px) { .site-footer .grid { grid-template-columns: 1fr; } }

      /* ===== MOTION ===== */
      .reveal { opacity: 0; transform: translateY(10px); transition: opacity 600ms cubic-bezier(.2,.7,.2,1), transform 600ms cubic-bezier(.2,.7,.2,1); }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) { .reveal { opacity: 1; transform: none; transition: none; } html { scroll-behavior: auto; } }

      /* ===== PAGE-SPECIFIC ===== */
      .progress-track { position: fixed; top: 0; left: 0; right: 0; height: 2px; z-index: 60; pointer-events: none; }
      .progress-track .bar { height: 100%; background: var(--accent); transform-origin: 0 50%; transform: scaleX(0); }

      .page-hero { padding: clamp(48px, 7vh, 88px) 0 48px; }
      .back-link { font-family: "Geist Mono", monospace; font-size: 12.5px; color: var(--muted); display: inline-block; margin-bottom: 28px; }
      .back-link:hover { color: var(--ink); }
      .page-hero h1 { font-size: clamp(30px, 4vw, 56px); line-height: 1.06; letter-spacing: -0.03em; text-wrap: balance; margin-top: 16px; max-width: 26ch; }
      .page-hero .subtitle { font-size: clamp(18px, 1.8vw, 24px); color: var(--ink-2); margin-top: 12px; font-weight: 400; letter-spacing: -0.015em; }
      .hero-meta { display: flex; flex-wrap: wrap; gap: 8px 24px; margin-top: 28px; font-family: "Geist Mono", monospace; font-size: 12px; letter-spacing: 0.03em; text-transform: uppercase; color: var(--muted); }

      .hero-image-wrap { padding: 0 0 48px; border-bottom: 1px solid var(--hairline); }
      .hero-image-wrap img { width: 100%; max-height: 480px; object-fit: cover; border-radius: 8px; border: 1px solid var(--hairline); }

      .author-row { display: flex; align-items: center; gap: 12px; padding: 20px 0; border-bottom: 1px solid var(--hairline); }
      .author-row img { width: 40px; height: 40px; border-radius: 50%; display: block; flex-shrink: 0; }
      .author-row .name { font-size: 15px; font-weight: 500; color: var(--ink); }
      .author-row .date-line { font-size: 13px; color: var(--muted); margin-top: 2px; }
      .share-links { margin-left: auto; display: flex; align-items: center; gap: 10px; }
      .share-links a { color: var(--muted); transition: color 150ms ease; display: flex; }
      .share-links a:hover { color: var(--ink); }

      .content-zone { padding: 56px 0 80px; }
      .content-grid { display: grid; grid-template-columns: minmax(0, 1fr) 248px; gap: 64px; align-items: start; }
      @media (max-width: 1000px) { .content-grid { grid-template-columns: minmax(0, 1fr); } .toc-aside { display: none; } }

      .toc-aside { position: sticky; top: 88px; }
      .toc-title { font-family: "Geist Mono", monospace; font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--muted); margin-bottom: 14px; }
      .toc a { display: block; padding: 6px 0 6px 14px; font-size: 13.5px; line-height: 1.4; color: var(--muted); border-left: 1px solid var(--hairline); transition: color 150ms ease, border-color 150ms ease; }
      .toc a:hover { color: var(--ink); }
      .toc a.active { color: var(--ink); border-left-color: var(--accent); }

      /* ===== PROSE ===== */
      .prose { font-size: 16.5px; line-height: 1.65; color: var(--ink-2); }
      .prose h2 { font-size: clamp(22px, 2.4vw, 28px); color: var(--ink); margin: 40px 0 12px; }
      .prose h3 { font-size: 19px; color: var(--ink); margin: 30px 0 8px; letter-spacing: -0.015em; }
      .prose h4 { font-size: 16.5px; color: var(--ink); margin: 24px 0 6px; }
      .prose h1 a, .prose h2 a, .prose h3 a, .prose h4 a { color: inherit; text-decoration: none; }
      .prose p { margin: 13px 0; text-wrap: pretty; }
      .prose ul, .prose ol { margin: 13px 0; padding-left: 24px; }
      .prose ul { list-style: disc; }
      .prose ol { list-style: decimal; }
      .prose ul ul { list-style: circle; margin: 4px 0; }
      .prose li { margin: 5px 0; }
      .prose li::marker { color: var(--muted); }
      .prose strong { color: var(--ink); font-weight: 600; }
      .prose a { color: var(--accent); text-decoration: underline; text-decoration-color: color-mix(in oklch, var(--accent) 40%, transparent); }
      .prose a:hover { text-decoration-color: var(--accent); }
      .prose blockquote { margin: 18px 0; border-left: 2px solid var(--accent); padding: 4px 0 4px 18px; color: var(--ink); }
      .prose code { font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace; font-size: 0.86em; }
      .prose :not(pre) > code { background: var(--bg-tint); border: 1px solid var(--hairline); border-radius: 4px; padding: 1px 5px; color: var(--ink); white-space: nowrap; }
      .prose pre { margin: 18px 0; padding: 18px; border-radius: 8px; border: 1px solid var(--hairline); overflow-x: auto; font-size: 13.5px; line-height: 1.55; }
      .prose img { border: 1px solid var(--hairline); border-radius: 8px; margin: 22px 0; }
      .prose hr { border: none; border-top: 1px solid var(--hairline); margin: 32px 0; }
      .prose table { width: 100%; border-collapse: collapse; margin: 18px 0; font-size: 14.5px; display: block; overflow-x: auto; }
      .prose th { font-family: "Geist Mono", monospace; font-size: 11.5px; letter-spacing: 0.04em; text-transform: uppercase; color: var(--muted); font-weight: 500; text-align: left; padding: 10px 14px 10px 0; border-bottom: 1px solid var(--hairline-strong); }
      .prose td { padding: 10px 14px 10px 0; border-bottom: 1px solid var(--hairline); vertical-align: top; }

      /* ===== FAQ ===== */
      .faq-list { margin-top: 40px; border-top: 1px solid var(--hairline); }
      .faq-item { border-bottom: 1px solid var(--hairline); }
      .faq-item summary { list-style: none; display: flex; justify-content: space-between; align-items: baseline; gap: 16px; padding: 18px 0; font-size: 16.5px; font-weight: 500; color: var(--ink); cursor: pointer; }
      .faq-item summary::-webkit-details-marker { display: none; }
      .faq-item summary::after { content: "+"; font-family: "Geist Mono", monospace; font-size: 18px; color: var(--muted); flex-shrink: 0; }
      .faq-item[open] summary::after { content: "−"; }
      .faq-answer { padding: 0 0 18px; font-size: 15.5px; line-height: 1.65; color: var(--ink-2); }

      /* ===== VIDEOS ===== */
      .video-grid { display: flex; flex-direction: column; gap: 24px; margin-top: 24px; }
      .video-embed { border-radius: 8px; overflow: hidden; border: 1px solid var(--hairline); aspect-ratio: 16/9; width: 100%; max-width: 760px; }
      .video-embed iframe { width: 100%; height: 100%; display: block; }
      .video-caption { margin-top: 8px; font-size: 13px; color: var(--muted); }

      /* ===== END CTA ===== */
      .end-cta { border-top: 1px solid var(--hairline); padding: 56px 0; }
      .end-cta .row { display: grid; grid-template-columns: 1fr auto; gap: 40px; align-items: end; }
      @media (max-width: 820px) { .end-cta .row { grid-template-columns: 1fr; align-items: start; } }
      .end-cta h2 { font-size: clamp(28px, 3.6vw, 44px); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance; }
    </style>
  </head>

  <body>

    <div class="progress-track" aria-hidden="true"><div class="bar" id="progress-bar"></div></div>

    <SiteHeader />

    <main>

      <section class="page-hero">
        <div class="wrap reveal">
          <a class="back-link" href="/writing">← All writing</a>
          <div><span class="eyebrow">Writing{articleTag && ` · ${articleTag}`}</span></div>
          <h1>{title}</h1>
          {titleTag && <p class="subtitle">{titleTag}</p>}
          <div class="hero-meta">
            <span>{published}{updated && ` · Updated ${updated}`}</span>
            {sections.length > 0 && <span>{sections.length} sections</span>}
          </div>
        </div>
      </section>

      {heroImage && (
        <div class="hero-image-wrap">
          <div class="wrap reveal">
            <img src={heroImage} alt={title} />
          </div>
        </div>
      )}

      <section class="content-zone">
        <div class="wrap">

          <div class="author-row reveal">
            <img src="/articles/author.png" alt="Jitan Gupta" />
            <div>
              <div class="name">Jitan Gupta</div>
              <div class="date-line">{published}{updated && ` · Updated ${updated}`}</div>
            </div>
            <div class="share-links">
              <a href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on X">
                <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M13.982 10.622 20.54 3h-1.554l-5.693 6.618L8.745 3H3.5l6.876 10.007L3.5 21h1.554l6.012-6.989L15.868 21h5.245l-7.131-10.378Zm-2.128 2.474-.697-.997-5.543-7.93H8l4.474 6.4.697.996 5.815 8.318h-2.387l-4.745-6.787Z"/></svg>
              </a>
              <a href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`} target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.7,3H4.3C3.582,3,3,3.582,3,4.3v15.4C3,20.418,3.582,21,4.3,21h15.4c0.718,0,1.3-0.582,1.3-1.3V4.3C21,3.582,20.418,3,19.7,3zM8.339,18.338H5.667v-8.59h2.672V18.338zM7.004,8.574c-0.857,0-1.549-0.694-1.549-1.548c0-0.855,0.691-1.548,1.549-1.548c0.854,0,1.547,0.694,1.547,1.548C8.551,7.881,7.858,8.574,7.004,8.574zM18.339,18.338h-2.669v-4.177c0-0.996-0.017-2.278-1.387-2.278c-1.389,0-1.601,1.086-1.601,2.206v4.249h-2.667v-8.59h2.559v1.174h0.037c0.356-0.675,1.227-1.387,2.526-1.387c2.703,0,3.203,1.779,3.203,4.092V18.338z"/></svg>
              </a>
            </div>
          </div>

          <div class="content-grid" style="margin-top: 40px;">
            <article class="prose reveal">
              <slot />

              {videos && videos.length > 0 && (
                <section style="margin-top: 48px; border-top: 1px solid var(--hairline); padding-top: 40px;">
                  <h2>Watch on YouTube</h2>
                  <div class="video-grid">
                    {videos.map((v) => (
                      <div>
                        <div class="video-embed">
                          <iframe
                            src={`https://www.youtube.com/embed/${v.youtubeId}`}
                            title={v.name}
                            loading="lazy"
                            frameborder="0"
                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                            allowfullscreen
                          ></iframe>
                        </div>
                        <p class="video-caption">{v.name}</p>
                      </div>
                    ))}
                  </div>
                </section>
              )}

              {faq && faq.length > 0 && (
                <section style="margin-top: 48px; border-top: 1px solid var(--hairline); padding-top: 40px;">
                  <h2>Frequently Asked Questions</h2>
                  <div class="faq-list">
                    {faq.map((item) => (
                      <details class="faq-item">
                        <summary>{item.question}</summary>
                        <div class="faq-answer" set:html={item.answer} />
                      </details>
                    ))}
                  </div>
                </section>
              )}
            </article>

            {sections.length > 0 && (
              <aside class="toc-aside">
                <div class="toc-title">On this page</div>
                <nav class="toc" id="toc" aria-label="Table of contents">
                  {sections.map((h) => (
                    <a href={`#${h.slug}`} data-slug={h.slug}>{h.text}</a>
                  ))}
                </nav>
              </aside>
            )}
          </div>
        </div>
      </section>

      <section class="end-cta">
        <div class="wrap">
          <div class="row">
            <div>
              <span class="eyebrow">Keep reading</span>
              <h2 style="margin-top: 14px;">More practical writing from the builder's side.</h2>
            </div>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <a class="btn primary" href="/writing">
                All writing
                <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
              </a>
              <a class="btn" href="/contact">Get in touch</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="grid">
          <div>
            <a href="/"><img src="/JitanGupta%20Logo.png" alt="Jitan Gupta" style="height:44px;width:auto;display:block;mix-blend-mode:multiply;margin-bottom:12px;" /></a>
            <p style="font-size:14.5px; max-width: 42ch; color: var(--ink-2); line-height: 1.6;">
              Engineer building AI infrastructure and developer tooling, in public. Mumbai, India.
            </p>
          </div>
          <div>
            <h4>Sitemap</h4>
            <ul>
              <li><a href="/builds">Builds</a></li>
              <li><a href="/frameworks">Frameworks</a></li>
              <li><a href="/case-studies">Case studies</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4>Elsewhere</h4>
            <ul>
              <li><a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
              <li><a href="https://www.youtube.com/@jitangupta" target="_blank" rel="noopener noreferrer">YouTube ↗</a></li>
              <li><a href="https://www.linkedin.com/in/jitangupta/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a></li>
            </ul>
          </div>
          <div>
            <h4>Speak with me</h4>
            <ul>
              <li><a href="/contact">Speaking & podcasts</a></li>
              <li><a href="/contact">Collaboration</a></li>
              <li><a href="/contact">Anything serious</a></li>
            </ul>
          </div>
        </div>
        <div class="meta">
          <span>© 2026 Jitan Gupta. All rights reserved.</span>
          <span class="mono">Built in public · Mumbai → web</span>
        </div>
      </div>
    </footer>

    <script>
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight) { el.classList.add('in'); }
        else { io.observe(el); }
      });
      setTimeout(() => {
        document.querySelectorAll('.reveal:not(.in)').forEach((el) => el.classList.add('in'));
      }, 1500);

      // TOC scrollspy
      const tocLinks = Array.from(document.querySelectorAll('#toc a')) as HTMLAnchorElement[];
      if (tocLinks.length) {
        const spy = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const id = entry.target.id;
            tocLinks.forEach((l) => l.classList.toggle('active', l.dataset.slug === id));
          });
        }, { rootMargin: '-80px 0px -60% 0px', threshold: 0 });
        document.querySelectorAll('.prose h2[id]').forEach((h) => spy.observe(h));
      }

      // Reading progress bar
      const bar = document.getElementById('progress-bar');
      const onScroll = () => {
        if (!bar) return;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
        bar.style.transform = `scaleX(${p})`;
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    </script>

  </body>
</html>
