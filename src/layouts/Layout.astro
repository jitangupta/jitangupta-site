---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Chatwoot from '../components/chatwoot.astro';
import "../styles/global.css";

// const title = "Jitan Gupta";
// const description = "Jitan Gupta is a full-stack engineer turned an entrepreneur.";
const { title, description, pubDate, updatedDate, heroImage, pageTheme } = Astro.props;
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={heroImage} />		
	</head>
	<body>
		<Header pageTheme={pageTheme} />

		<slot />

		<Footer />
		<script is:inline src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
		<Chatwoot />
		<!-- Yandex.Metrika counter -->
		{import.meta.env.MODE === "production" &&
		<script is:inline>
			(function(m,e,t,r,i,k,a){m[i]=m[i]||function(){(m[i].a=m[i].a||[]).push(arguments)};
			m[i].l=1*new Date();
			for (var j = 0; j < document.scripts.length; j++) {if (document.scripts[j].src === r) { return; }}
			k=e.createElement(t),a=e.getElementsByTagName(t)[0],k.async=1,k.src=r,a.parentNode.insertBefore(k,a)})
			(window, document, "script", "https://mc.yandex.ru/metrika/tag.js", "ym");
			ym(100451952, "init", { clickmap:true, trackLinks:true, accurateTrackBounce:true, webvisor:true });
		</script>
		<noscript><div><img src="https://mc.yandex.ru/watch/100451952" style="position:absolute; left:-9999px;" alt="" /></div></noscript>
		}
		<!-- /Yandex.Metrika counter -->
	</body>
</html>
