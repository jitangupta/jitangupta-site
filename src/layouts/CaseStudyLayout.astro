---
import '../styles/global.css';
import type { CollectionEntry  } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CommonCTA from '../components/CommonCTA.astro';
import Contact from '../components/Contact.astro';
import Chatwoot from '../components/chatwoot.astro';

type Props = CollectionEntry<'caseStudies'>['data'];

const { title, pageTitle, seoTitle, summary, description, pubDate, updatedDate, heroImage, articleTag, stats,
	testimonial, testimonialAuthor, testimonialAuthorTitle, testimonialAuthorCompany, testimonialAuthorImage,
	keywords, author, robots, ogType, canonicalUrl
 } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "TechArticle",
  "headline": seoTitle || title,
  "description": description,
  "author": {
    "@type": "Person",
    "name": author || "Jitan Gupta",
    "url": "https://jitangupta.com"
  },
  "datePublished": pubDate,
  "dateModified": updatedDate || pubDate,
  "image": new URL(heroImage || '/jitan-bg.png', Astro.url),
  "publisher": {
    "@type": "Person",
    "name": "Jitan Gupta"
  },
  "articleSection": articleTag || "Tech",
  "keywords": keywords
};
---

<html lang="en">
	<head>
		<BaseHead 
			title={seoTitle || title} 
			description={description} 
			image={heroImage}
			keywords={keywords}
			author={author}
			robots={robots}
			ogType={ogType || 'article'}
			canonicalUrl={canonicalUrl}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(schema)} />
		<style is:global>
			body {
				background-color: #0d1117;
				color: #c9d1d9;
			}
			
			/* TOC Styles */
			.toc-link {
				color: #8b949e;
				transition: color 0.2s;
			}
			.toc-link:hover {
				color: #58a6ff;
			}

			/* Fix SVG and Image Sizing in Prose */
			.prose img {
				height: auto !important;
				width: 100%;
				max-width: 100%;
			}

			/* SVG images get white background for visibility */
			.prose img[src$=".svg"] {
				background-color: white;
				padding: 1rem;
				border-radius: 0.5rem;
			}
		</style>
	</head>

	<body class="bg-[#0d1117] text-[#c9d1d9] antialiased">
		<Header />

		<!-- Hero -->
		<section class="bg-[#0d1117] pt-16 pb-10 border-b border-gray-800">
			<div class="container-custom">
				<div class="grid lg:grid-cols-12 gap-12 items-center">				
					<div class="lg:col-span-7">
						<!-- Tags -->
						<div class="mb-6">
							<span class="inline-block px-3 py-1 text-xs font-mono text-blue-400 bg-blue-900/20 border border-blue-900/50 rounded-full">
								CASE STUDY
							</span>
							{articleTag && (
								<span class="inline-block ml-2 px-3 py-1 text-xs font-mono text-gray-400 bg-gray-800 border border-gray-700 rounded-full">
									{articleTag}
								</span>
							)}
						</div>

						<h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 leading-tight">{pageTitle}</h1>
						<p class="text-xl text-gray-400 mb-8 leading-relaxed">{summary}</p>
						
						<a href="/#contact" class="inline-flex items-center justify-center px-6 py-3 text-base font-medium text-white bg-blue-600 hover:bg-blue-500 rounded-lg transition-all duration-300 shadow-[0_0_20px_rgba(37,99,235,0.3)] hover:shadow-[0_0_30px_rgba(37,99,235,0.5)]">
							Start Your Migration
						</a> 					
					</div>    
					<div class="lg:col-span-5">
						{heroImage && (
							<div class="relative rounded-xl overflow-hidden border border-gray-800 shadow-2xl bg-[#161b22]">
								<div class="absolute inset-0 bg-blue-500/10 mix-blend-overlay"></div>
								<img src={heroImage} alt={seoTitle} class="w-full h-auto object-cover" />
							</div>
						)}
					</div>           
				</div>
			</div>
		</section>
		
		<!-- Stats -->
		{stats && stats.length > 0 && (
			<section class="py-12 border-b border-gray-800 bg-[#161b22]/50">
				<div class="container-custom">	
					<div class="grid grid-cols-1 md:grid-cols-3 gap-8">
						{stats.map((item) => (
							<div class="text-center p-6 rounded-xl bg-[#0d1117] border border-gray-800">
								<h2 class="text-4xl md:text-5xl font-bold text-blue-400 mb-2">{item.percentage}</h2>
								<p class="text-gray-400 font-medium">{item.description}</p>
							</div>
						))}
					</div>
				</div>
			</section>
		)}
	 	
		<!-- testimonial -->
		{
			testimonial && 
			<section class="py-16 border-b border-gray-800">
				<div class="container-custom">	
					<blockquote class="text-center max-w-4xl mx-auto">
						<svg class="w-12 h-12 text-gray-700 mb-6 mx-auto" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 18 14">
							<path d="M6 0H2a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4v1a3 3 0 0 1-3 3H2a1 1 0 0 0 0 2h1a5.006 5.006 0 0 0 5-5V2a2 2 0 0 0-2-2Zm10 0h-4a2 2 0 0 0-2 2v4a2 2 0 0 0 2 2h4v1a3 3 0 0 1-3 3h-1a1 1 0 0 0 0 2h1a5.006 5.006 0 0 0 5-5V2a2 2 0 0 0-2-2Z"/>
						</svg>
						<p class="text-2xl md:text-3xl font-medium text-white mb-8 leading-relaxed">"{testimonial}"</p>
						{
							testimonialAuthor && 
							<div class="flex items-center justify-center gap-4">
								{testimonialAuthorImage && <img src={testimonialAuthorImage} alt={testimonialAuthor} class="w-12 h-12 rounded-full border border-gray-700" />}
								<div class="text-left">
									<cite class="block text-white font-bold not-italic">{testimonialAuthor}</cite>
									<cite class="block text-gray-500 text-sm not-italic">{testimonialAuthorTitle}, {testimonialAuthorCompany}</cite>
								</div>
							</div>
						}
					</blockquote>
				</div>
			</section>
		}

		<!-- case study details & TOC -->
		<section class="py-16">
			<div class="container-custom">
				<div class="flex flex-col lg:flex-row gap-12">
					<!-- Blog Content -->
					<main class="w-full lg:w-3/4 prose prose-invert prose-lg prose-blue max-w-none">
						<slot />
					</main>		
			
					<!-- Table Of Content -->
					<aside class="hidden lg:block lg:w-1/4">
						<div class="sticky top-24 p-4 bg-[#161b22] border border-gray-800 rounded-xl">
							<h2 class="text-xs font-bold text-white uppercase tracking-wider mb-4">Table of Contents</h2>
							<ul class="text-xs space-y-2">
								{Astro.props.headings && Astro.props.headings.map(heading => (
									<li class="" style={`margin-left: ${(heading.depth - 1) * 12}px;`}>
										<a class="toc-link block hover:translate-x-1 transition-transform" href={`#${heading.text.replace(/\s+/g, '-').toLowerCase()}`}>{heading.text}</a>
									</li>
								))}
							</ul>
						</div>
					</aside>				 		
				</div>
			</div>
		</section>

		<!--<CommonCTA /> -->
		<Contact />

		<Footer />
		<script is:inline src="https://cdn.jsdelivr.net/npm/flowbite@3.1.2/dist/flowbite.min.js"></script>
		
		<!-- Mermaid Support -->
		<script type="module">
			import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
			mermaid.initialize({ startOnLoad: false, theme: 'dark' });

			async function runMermaid() {
				// Find all code blocks
				const codeBlocks = document.querySelectorAll('pre > code');
				
				codeBlocks.forEach(block => {
					// Check if it's explicitly mermaid or if the content looks like mermaid
					const isMermaid = block.classList.contains('language-mermaid') || 
									  block.textContent.trim().startsWith('graph') || 
									  block.textContent.trim().startsWith('sequenceDiagram') ||
									  block.textContent.trim().startsWith('classDiagram') ||
									  block.textContent.trim().startsWith('stateDiagram') ||
									  block.textContent.trim().startsWith('erDiagram') ||
									  block.textContent.trim().startsWith('gantt') ||
									  block.textContent.trim().startsWith('pie') ||
									  block.textContent.trim().startsWith('flowchart');

					if (isMermaid) {
						const pre = block.parentElement;
						const content = block.textContent;
						const div = document.createElement('div');
						div.className = 'mermaid';
						div.textContent = content;
						pre.replaceWith(div);
					}
				});

				await mermaid.run({
					nodes: document.querySelectorAll('.mermaid'),
				});
			}

			document.addEventListener('DOMContentLoaded', runMermaid);
		</script>
		<!-- <Chatwoot /> -->
	</body>
</html>
