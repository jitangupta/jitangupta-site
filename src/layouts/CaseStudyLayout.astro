---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import SiteHeader from '../components/SiteHeader.astro';

type Heading = { depth: number; slug: string; text: string };
type Props = CollectionEntry<'caseStudies'>['data'] & { headings?: Heading[] };

const {
  pageTitle, seoTitle, summary, description, pubDate, updatedDate, heroImage, articleTag, stats,
  aiBridge, testimonial, testimonialAuthor, testimonialAuthorTitle, testimonialAuthorCompany,
  headings = [],
} = Astro.props;

const lede = summary ?? description;
const sections = headings.filter((h) => h.depth === 2);
const dateFmt = new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' });
const published = dateFmt.format(pubDate);
const updated = updatedDate ? dateFmt.format(updatedDate) : null;
---

<!doctype html>
<html lang="en" data-theme="paper">
  <head>
    <BaseHead title={seoTitle} description={description} image={heroImage} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600&family=Geist+Mono:wght@400;500&display=swap"
    />
    <style is:global>
      :root,
      html[data-theme="paper"] {
        --bg: oklch(0.985 0.008 80);
        --bg-tint: oklch(0.965 0.012 80);
        --ink: oklch(0.18 0.012 60);
        --ink-2: oklch(0.30 0.012 60);
        --muted: oklch(0.50 0.012 60);
        --hairline: oklch(0.88 0.010 80);
        --hairline-strong: oklch(0.78 0.012 80);
        --accent: oklch(0.62 0.20 32);
        --accent-ink: oklch(0.98 0.005 80);
        --selection: oklch(0.85 0.14 32 / 0.45);
      }

      *, *::before, *::after { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }

      html {
        background: var(--bg);
        color: var(--ink);
        font-family: "Geist", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
        font-size: 17px;
        line-height: 1.55;
        font-feature-settings: "ss01","ss02","cv11";
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        scroll-behavior: smooth;
      }

      ::selection { background: var(--selection); }
      body { min-height: 100vh; overflow-x: hidden; }

      a {
        color: inherit;
        text-decoration: none;
        text-underline-offset: 3px;
        transition: color 150ms ease, opacity 150ms ease;
      }
      a:hover { color: var(--accent); }

      p { margin: 0; }
      ul, ol { margin: 0; padding: 0; list-style: none; }
      img { max-width: 100%; display: block; }

      .wrap { max-width: 1240px; margin: 0 auto; padding: 0 32px; }
      @media (max-width: 540px) { .wrap { padding: 0 20px; } }

      .mono {
        font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;
        font-feature-settings: "ss01","ss02";
      }

      .eyebrow {
        font-family: "Geist Mono", ui-monospace, monospace;
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        display: inline-flex;
        align-items: center;
        gap: 8px;
      }
      .eyebrow::before {
        content: "";
        width: 18px;
        height: 1px;
        background: var(--hairline-strong);
      }

      h1, h2, h3, h4 { margin: 0; font-weight: 500; letter-spacing: -0.02em; }

      .lede {
        font-size: clamp(18px, 1.4vw, 22px);
        line-height: 1.5;
        color: var(--ink-2);
        text-wrap: pretty;
        max-width: 62ch;
      }

      .body { font-size: 17px; line-height: 1.6; color: var(--ink-2); text-wrap: pretty; }
      .small { font-size: 14px; color: var(--muted); }

      .btn {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 12px 18px;
        border: 1px solid var(--hairline-strong);
        border-radius: 999px;
        font-size: 14.5px;
        font-weight: 500;
        color: var(--ink);
        background: transparent;
        cursor: pointer;
        transition: background 150ms ease, border-color 150ms ease, color 150ms ease;
      }
      .btn:hover { background: var(--bg-tint); color: var(--ink); border-color: var(--ink); }
      .btn.primary { background: var(--ink); color: var(--bg); border-color: var(--ink); }
      .btn.primary:hover { background: var(--accent); border-color: var(--accent); color: var(--accent-ink); }
      .btn .arrow { transition: transform 200ms ease; }
      .btn:hover .arrow { transform: translateX(3px); }
      .arrow { width: 14px; height: 14px; display: inline-block; vertical-align: -1px; }

      .site-footer { border-top: 1px solid var(--hairline); padding: 56px 0 40px; }
      .site-footer .grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr 1fr;
        gap: 40px;
        margin-bottom: 56px;
      }
      .site-footer h4 {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
        font-weight: 500;
      }
      .site-footer ul li { padding: 4px 0; }
      .site-footer ul li a { color: var(--ink-2); font-size: 14.5px; }
      .site-footer .meta {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 13px;
        color: var(--muted);
        padding-top: 24px;
        border-top: 1px solid var(--hairline);
      }
      @media (max-width: 820px) { .site-footer .grid { grid-template-columns: 1fr 1fr; } }

      .reveal {
        opacity: 0;
        transform: translateY(10px);
        transition: opacity 600ms cubic-bezier(.2,.7,.2,1), transform 600ms cubic-bezier(.2,.7,.2,1);
      }
      .reveal.in { opacity: 1; transform: none; }
      @media (prefers-reduced-motion: reduce) {
        .reveal { opacity: 1; transform: none; transition: none; }
        html { scroll-behavior: auto; }
        .acc-body { transition: none !important; }
      }

      /* ===== PAGE-SPECIFIC ===== */

      .progress-track {
        position: fixed;
        top: 0; left: 0; right: 0;
        height: 2px;
        z-index: 60;
        pointer-events: none;
      }
      .progress-track .bar {
        height: 100%;
        background: var(--accent);
        transform-origin: 0 50%;
        transform: scaleX(0);
      }

      .page-hero { padding: clamp(48px, 7vh, 88px) 0 48px; }
      .back-link {
        font-family: "Geist Mono", monospace;
        font-size: 12.5px;
        color: var(--muted);
        display: inline-block;
        margin-bottom: 28px;
      }
      .page-hero h1 {
        font-size: clamp(34px, 4.6vw, 64px);
        line-height: 1.04;
        letter-spacing: -0.03em;
        text-wrap: balance;
        margin-top: 16px;
        max-width: 22ch;
      }
      .hero-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px 24px;
        margin-top: 28px;
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .glance {
        border-top: 1px solid var(--hairline);
        border-bottom: 1px solid var(--hairline);
        padding: 40px 0;
      }
      .glance-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: start;
      }
      @media (max-width: 820px) { .glance-grid { grid-template-columns: 1fr; gap: 32px; } }
      .metrics {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
        padding: 20px;
        background: var(--bg-tint);
        border-radius: 4px;
      }
      @media (max-width: 540px) { .metrics { grid-template-columns: 1fr; } }
      .metrics .m .v {
        font-size: 26px;
        font-weight: 500;
        letter-spacing: -0.02em;
        color: var(--ink);
        display: block;
      }
      .metrics .m .k {
        font-size: 13px;
        color: var(--muted);
        line-height: 1.45;
        display: block;
        margin-top: 6px;
      }
      .lessons {
        border-left: 2px solid var(--accent);
        padding: 6px 0 6px 18px;
        font-size: 15px;
        color: var(--ink);
        line-height: 1.55;
        font-style: italic;
        max-width: 52ch;
      }
      .lessons::before {
        content: "Lesson, today";
        display: block;
        font-style: normal;
        color: var(--muted);
        font-family: "Geist Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        margin-bottom: 6px;
      }

      .quote-band { padding: 48px 0; border-bottom: 1px solid var(--hairline); }
      .quote-band blockquote {
        margin: 0;
        font-size: clamp(18px, 1.8vw, 23px);
        line-height: 1.5;
        letter-spacing: -0.01em;
        color: var(--ink);
        max-width: 56ch;
        text-wrap: pretty;
      }
      .quote-band cite {
        display: block;
        margin-top: 18px;
        font-style: normal;
        font-size: 14px;
        color: var(--muted);
      }

      .content-zone { padding: 56px 0 80px; }
      .content-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 264px;
        gap: 64px;
        align-items: start;
      }
      @media (max-width: 1000px) {
        .content-grid { grid-template-columns: minmax(0, 1fr); }
        .toc-aside { display: none; }
      }

      /* --- Reading controls (mobile + top of article) --- */
      .read-controls {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding-bottom: 18px;
      }
      .read-controls .hint {
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
      }
      .ctrl-btn {
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--ink-2);
        background: transparent;
        border: 1px solid var(--hairline-strong);
        border-radius: 999px;
        padding: 7px 14px;
        cursor: pointer;
        transition: border-color 150ms ease, color 150ms ease, background 150ms ease;
        white-space: nowrap;
      }
      .ctrl-btn:hover { border-color: var(--ink); color: var(--ink); background: var(--bg-tint); }

      /* --- TOC --- */
      .toc-aside { position: sticky; top: 88px; }
      .toc-title {
        font-family: "Geist Mono", monospace;
        font-size: 11px;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--muted);
        margin-bottom: 14px;
      }
      .toc a {
        display: block;
        padding: 6px 0 6px 14px;
        font-size: 13.5px;
        line-height: 1.4;
        color: var(--muted);
        border-left: 1px solid var(--hairline);
        transition: color 150ms ease, border-color 150ms ease;
      }
      .toc a:hover { color: var(--ink); }
      .toc a.active { color: var(--ink); border-left-color: var(--accent); }
      .toc .toc-foot { margin-top: 18px; }

      /* --- Accordion sections (built by JS from h2 blocks) --- */
      .acc { border-top: 1px solid var(--hairline); scroll-margin-top: 84px; }
      .acc:last-child { border-bottom: 1px solid var(--hairline); }
      .acc-head {
        width: 100%;
        display: flex;
        align-items: baseline;
        gap: 16px;
        padding: 20px 0;
        background: none;
        border: none;
        cursor: pointer;
        text-align: left;
        font: inherit;
        color: var(--ink);
      }
      .acc-num {
        font-family: "Geist Mono", monospace;
        font-size: 12px;
        color: var(--muted);
        flex-shrink: 0;
      }
      .acc-title {
        flex: 1;
        font-size: clamp(18px, 2vw, 23px);
        font-weight: 500;
        letter-spacing: -0.02em;
        line-height: 1.2;
        text-wrap: balance;
      }
      .acc-head:hover .acc-title { color: var(--accent); }
      .acc-mins {
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
        color: var(--muted);
        flex-shrink: 0;
        white-space: nowrap;
      }
      .acc-chev {
        width: 14px; height: 14px;
        flex-shrink: 0;
        align-self: center;
        color: var(--muted);
        transition: transform 250ms ease;
      }
      .acc.open .acc-chev { transform: rotate(180deg); }
      .acc-body {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 350ms cubic-bezier(.2,.7,.2,1);
      }
      .acc.open .acc-body { grid-template-rows: 1fr; }
      .acc-inner { overflow: hidden; min-width: 0; }
      .acc-inner > :last-child { margin-bottom: 32px; }

      /* --- Prose --- */
      .prose { font-size: 16.5px; line-height: 1.65; color: var(--ink-2); }
      .prose h2 {
        font-size: clamp(22px, 2.4vw, 28px);
        color: var(--ink);
        margin: 40px 0 12px;
      }
      .prose h3 {
        font-size: 19px;
        color: var(--ink);
        margin: 30px 0 8px;
        letter-spacing: -0.015em;
      }
      .prose h4 { font-size: 16.5px; color: var(--ink); margin: 24px 0 6px; }
      .prose p { margin: 13px 0; text-wrap: pretty; }
      .prose ul, .prose ol { margin: 13px 0; padding-left: 24px; }
      .prose ul { list-style: disc; }
      .prose ol { list-style: decimal; }
      .prose ul ul { list-style: circle; margin: 4px 0; }
      .prose li { margin: 5px 0; }
      .prose li::marker { color: var(--muted); }
      .prose strong { color: var(--ink); font-weight: 600; }
      .prose a { color: var(--accent); text-decoration: underline; text-decoration-color: color-mix(in oklch, var(--accent) 40%, transparent); }
      .prose a:hover { text-decoration-color: var(--accent); }
      .prose blockquote {
        margin: 18px 0;
        border-left: 2px solid var(--accent);
        padding: 4px 0 4px 18px;
        color: var(--ink);
      }
      .prose code {
        font-family: "Geist Mono", ui-monospace, "SF Mono", Menlo, monospace;
        font-size: 0.86em;
      }
      .prose :not(pre) > code {
        background: var(--bg-tint);
        border: 1px solid var(--hairline);
        border-radius: 4px;
        padding: 1px 5px;
        color: var(--ink);
        white-space: nowrap;
      }
      .prose pre {
        margin: 18px 0;
        padding: 18px;
        border-radius: 8px;
        border: 1px solid var(--hairline);
        overflow-x: auto;
        font-size: 13.5px;
        line-height: 1.55;
      }
      .prose img {
        border: 1px solid var(--hairline);
        border-radius: 8px;
        margin: 22px 0;
      }
      .prose hr { border: none; border-top: 1px solid var(--hairline); margin: 32px 0; }
      .prose table {
        width: 100%;
        border-collapse: collapse;
        margin: 18px 0;
        font-size: 14.5px;
        display: block;
        overflow-x: auto;
      }
      .prose th {
        font-family: "Geist Mono", monospace;
        font-size: 11.5px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        color: var(--muted);
        font-weight: 500;
        text-align: left;
        padding: 10px 14px 10px 0;
        border-bottom: 1px solid var(--hairline-strong);
      }
      .prose td {
        padding: 10px 14px 10px 0;
        border-bottom: 1px solid var(--hairline);
        vertical-align: top;
      }
      .mermaid-diagram {
        background: #fff;
        border: 1px solid var(--hairline);
        border-radius: 8px;
        padding: 18px;
        margin: 22px 0;
        overflow-x: auto;
      }
      .mermaid-diagram svg { max-width: 100%; height: auto; }

      /* trailing/leading section dividers are redundant inside accordions */
      .acc-inner > hr:first-child,
      .acc-inner > hr:last-child,
      .prose > hr:last-child { display: none; }

      .end-cta {
        border-top: 1px solid var(--hairline);
        padding: 56px 0;
      }
      .end-cta .row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 40px;
        align-items: end;
      }
      @media (max-width: 820px) { .end-cta .row { grid-template-columns: 1fr; align-items: start; } }
      .end-cta h2 {
        font-size: clamp(28px, 3.6vw, 44px);
        line-height: 1.05;
        letter-spacing: -0.025em;
        text-wrap: balance;
      }
    </style>
  </head>

  <body>

    <div class="progress-track" aria-hidden="true"><div class="bar" id="progress-bar"></div></div>

    <SiteHeader />

    <main>

      <section class="page-hero">
        <div class="wrap reveal">
          <a class="back-link" href="/case-studies">← All case studies</a>
          <div>
            <span class="eyebrow">Case study{articleTag && ` · ${articleTag}`}</span>
          </div>
          <h1>{pageTitle}</h1>
          <p class="lede" style="margin-top: 22px;">{lede}</p>
          <div class="hero-meta">
            <span>{published}{updated && ` · Updated ${updated}`}</span>
            <span id="total-read">&nbsp;</span>
            <span>{sections.length} sections</span>
          </div>
        </div>
      </section>

      {stats && stats.length > 0 && (
        <section class="glance">
          <div class="wrap reveal">
            <div class="glance-grid">
              <div class="metrics">
                {stats.map((item) => (
                  <div class="m">
                    <span class="v">{item.percentage}</span>
                    <span class="k">{item.description}</span>
                  </div>
                ))}
              </div>
              {aiBridge && <p class="lessons">{aiBridge}</p>}
            </div>
          </div>
        </section>
      )}

      {testimonial && (
        <section class="quote-band">
          <div class="wrap reveal">
            <span class="eyebrow">What the client said</span>
            <blockquote style="margin-top: 20px;">“{testimonial}”</blockquote>
            {testimonialAuthor && (
              <cite>{testimonialAuthor} — {testimonialAuthorTitle}, {testimonialAuthorCompany}</cite>
            )}
          </div>
        </section>
      )}

      <section class="content-zone">
        <div class="wrap">
          <div class="content-grid">
            <div>
              <div class="read-controls" id="read-controls" hidden>
                <span class="hint">Tap a section to read it</span>
                <button class="ctrl-btn" id="expand-all" type="button">Expand all</button>
              </div>
              <article class="prose" id="cs-article">
                <slot />
              </article>
            </div>

            <aside class="toc-aside">
              <div class="toc-title">On this page</div>
              <nav class="toc" id="toc" aria-label="Table of contents">
                {sections.map((h) => (
                  <a href={`#${h.slug}`} data-slug={h.slug}>{h.text}</a>
                ))}
              </nav>
            </aside>
          </div>
        </div>
      </section>

      <section class="end-cta">
        <div class="wrap">
          <div class="row">
            <div>
              <span class="eyebrow">Keep reading</span>
              <h2 style="margin-top: 14px;">More production work, and what it taught me about AI.</h2>
            </div>
            <div style="display: flex; gap: 12px; flex-wrap: wrap;">
              <a class="btn primary" href="/case-studies">
                All case studies
                <svg class="arrow" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h8M7.5 3.5L11 7l-3.5 3.5"/></svg>
              </a>
              <a class="btn" href="/contact">Get in touch</a>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="wrap">
        <div class="grid">
          <div>
            <a class="brand" href="/"><img src="/JitanGupta%20Logo.png" alt="Jitan Gupta" style="height:44px;width:auto;display:block;mix-blend-mode:multiply;" /></a>
            <p class="body" style="font-size:14.5px; max-width: 42ch; margin-top: 12px;">
              Engineer building AI infrastructure and developer tooling, in public. Mumbai, India.
            </p>
          </div>
          <div>
            <h4>Sitemap</h4>
            <ul>
              <li><a href="/builds">Builds</a></li>
              <li><a href="/frameworks">Frameworks</a></li>
              <li><a href="/case-studies">Case studies</a></li>
              <li><a href="/about">About</a></li>
              <li><a href="/contact">Contact</a></li>
            </ul>
          </div>
          <div>
            <h4>Elsewhere</h4>
            <ul>
              <li><a href="https://github.com/jitangupta" target="_blank" rel="noopener noreferrer">GitHub ↗</a></li>
              <li><a href="https://www.youtube.com/@jitangupta" target="_blank" rel="noopener noreferrer">YouTube ↗</a></li>
              <li><a href="https://www.linkedin.com/in/jitangupta/" target="_blank" rel="noopener noreferrer">LinkedIn ↗</a></li>
            </ul>
          </div>
          <div>
            <h4>Speak with me</h4>
            <ul>
              <li><a href="/contact">Speaking & podcasts</a></li>
              <li><a href="/contact">Collaboration</a></li>
              <li><a href="/contact">Anything serious</a></li>
            </ul>
          </div>
        </div>
        <div class="meta">
          <span>© 2026 Jitan Gupta. All rights reserved.</span>
          <span class="mono">Built in public · Mumbai → web</span>
        </div>
      </div>
    </footer>

    <script>
      // ---------- Reveal-on-scroll (matches the rest of the site) ----------
      const io = new IntersectionObserver((entries) => {
        entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
      }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
      document.querySelectorAll('.reveal').forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight) { el.classList.add('in'); }
        else { io.observe(el); }
      });
      setTimeout(() => {
        document.querySelectorAll('.reveal:not(.in)').forEach((el) => el.classList.add('in'));
      }, 1500);

      // ---------- Build collapsible sections from the rendered markdown ----------
      const article = document.getElementById('cs-article');
      const WPM = 200;
      const readMins = (text: string) =>
        Math.max(1, Math.round(text.trim().split(/\s+/).length / WPM));

      const sections: HTMLElement[] = [];

      if (article) {
        const children = Array.from(article.children);
        const frag = document.createDocumentFragment();
        let inner: HTMLElement | null = null;
        let idx = 0;

        for (const node of children) {
          if (node.tagName === 'H2') {
            idx += 1;
            const sec = document.createElement('section');
            sec.className = 'acc';
            sec.id = node.id;

            const head = document.createElement('button');
            head.type = 'button';
            head.className = 'acc-head';
            head.setAttribute('aria-expanded', 'false');

            const num = document.createElement('span');
            num.className = 'acc-num';
            num.textContent = String(idx).padStart(2, '0');

            const title = document.createElement('span');
            title.className = 'acc-title';
            title.textContent = node.textContent ?? '';

            const mins = document.createElement('span');
            mins.className = 'acc-mins';

            head.append(num, title, mins);
            head.insertAdjacentHTML(
              'beforeend',
              '<svg class="acc-chev" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5.5L7 9.5l4-4"/></svg>'
            );

            const body = document.createElement('div');
            body.className = 'acc-body';
            inner = document.createElement('div');
            inner.className = 'acc-inner';
            body.append(inner);

            sec.append(head, body);
            frag.append(sec);
            sections.push(sec);
            node.remove();
          } else if (inner) {
            inner.append(node);
          } else {
            frag.append(node);
          }
        }

        article.textContent = '';
        article.append(frag);

        // read-time per section + total
        let totalMins = 0;
        for (const sec of sections) {
          const body = sec.querySelector('.acc-inner') as HTMLElement;
          const m = readMins(body.textContent ?? '');
          totalMins += m;
          (sec.querySelector('.acc-mins') as HTMLElement).textContent = `${m} min`;
        }
        const totalEl = document.getElementById('total-read');
        if (totalEl) totalEl.textContent = `${totalMins} min full read`;

        const setOpen = (sec: HTMLElement, open: boolean) => {
          sec.classList.toggle('open', open);
          sec.querySelector('.acc-head')?.setAttribute('aria-expanded', String(open));
        };

        for (const sec of sections) {
          sec.querySelector('.acc-head')?.addEventListener('click', () => {
            setOpen(sec, !sec.classList.contains('open'));
          });
        }

        // open the first section, or the one targeted by the URL hash
        const fromHash = window.location.hash
          ? sections.find((s) => `#${s.id}` === window.location.hash)
          : null;
        if (fromHash) {
          setOpen(fromHash, true);
          requestAnimationFrame(() => fromHash.scrollIntoView());
        } else if (sections.length) {
          setOpen(sections[0], true);
        }

        // expand/collapse all
        const controls = document.getElementById('read-controls');
        const expandBtn = document.getElementById('expand-all');
        if (controls && sections.length) controls.hidden = false;
        expandBtn?.addEventListener('click', () => {
          const shouldOpen = sections.some((s) => !s.classList.contains('open'));
          sections.forEach((s) => setOpen(s, shouldOpen));
          expandBtn.textContent = shouldOpen ? 'Collapse all' : 'Expand all';
        });

        // TOC: open the section you navigate to + scrollspy
        const tocLinks = Array.from(document.querySelectorAll('#toc a')) as HTMLAnchorElement[];
        const openHash = () => {
          const target = sections.find((s) => `#${s.id}` === window.location.hash);
          if (target) setOpen(target, true);
        };
        tocLinks.forEach((link) => link.addEventListener('click', () => {
          const target = sections.find((s) => s.id === link.dataset.slug);
          if (target) setOpen(target, true);
        }));
        window.addEventListener('hashchange', openHash);

        const spy = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            tocLinks.forEach((l) => l.classList.toggle('active', l.dataset.slug === entry.target.id));
          });
        }, { rootMargin: '-80px 0px -70% 0px', threshold: 0 });
        sections.forEach((s) => spy.observe(s));
      }

      // ---------- Reading progress bar ----------
      const bar = document.getElementById('progress-bar');
      const onScroll = () => {
        if (!bar) return;
        const max = document.documentElement.scrollHeight - window.innerHeight;
        const p = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
        bar.style.transform = `scaleX(${p})`;
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    </script>

    <script is:inline type="module">
      // Render ```mermaid code fences as diagrams (only loads mermaid when needed)
      const blocks = document.querySelectorAll(
        'pre[data-language="mermaid"], pre.language-mermaid'
      );
      if (blocks.length) {
        try {
          const { default: mermaid } = await import(
            'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs'
          );
          mermaid.initialize({
            startOnLoad: false,
            theme: 'neutral',
            fontFamily: 'Geist, system-ui, sans-serif',
          });
          let i = 0;
          for (const pre of blocks) {
            try {
              const { svg } = await mermaid.render(`mmd-${i++}`, pre.textContent ?? '');
              const div = document.createElement('div');
              div.className = 'mermaid-diagram';
              div.innerHTML = svg;
              pre.replaceWith(div);
            } catch { /* leave the code block as-is */ }
          }
        } catch { /* CDN unavailable — code block fallback is fine */ }
      }
    </script>

  </body>
</html>
